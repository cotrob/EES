---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
---

<BaseLayout
  title="Research Resources | EES"
  description="Access our published research, testing videos, and technical documentation from our laboratory and field installations."
>
  <section class="page-header">
    <div class="container">
      <h1>Research Resources</h1>
      <p>Papers, testing videos, and technical documentation.</p>
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      <h2>Resources</h2>
      <p>
        Access our published research, testing videos, and technical documentation from our laboratory and field installations.
      </p>

      <h3>Academic Research</h3>
      <p>
        Peer-reviewed publications covering thermal comfort, radiant ceiling systems, heat pumps, and renewable energy integration.
      </p>
      <p><a href="/laboratory/written-papers">View research papers &rarr;</a></p>

      <h3>Testing Videos</h3>
      <p>
        Video from our test facility and real-world installations.
      </p>
      <p><a href="/laboratory/footage">View testing videos &rarr;</a></p>

      <h3>Products</h3>
      <p>
        Technical details on products developed and tested in our facility.
      </p>
      <p><a href="/laboratory/products">View products &rarr;</a></p>
    </div>
  </section>
  <ScrollIndicator />
</BaseLayout>
