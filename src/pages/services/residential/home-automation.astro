---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import ServiceHero from '../../../components/sections/ServiceHero.astro';
import HugeIcon from '../../../components/HugeIcon.astro';
import SmartAcIcon from '@hugeicons/core-free-icons/SmartAcIcon';
import Sun01Icon from '@hugeicons/core-free-icons/Sun01Icon';
import WashingMachineIcon from '@hugeicons/core-free-icons/WashingMachineIcon';
import EvChargingIcon from '@hugeicons/core-free-icons/EvChargingIcon';
import DishWasherIcon from '@hugeicons/core-free-icons/DishWasherIcon';
import PoolIcon from '@hugeicons/core-free-icons/PoolIcon';
import BatteryFullIcon from '@hugeicons/core-free-icons/BatteryFullIcon';
import SmartPhone01Icon from '@hugeicons/core-free-icons/SmartPhone01Icon';
import ArrowRight01Icon from '@hugeicons/core-free-icons/ArrowRight01Icon';
import ArrowDownRight01Icon from '@hugeicons/core-free-icons/ArrowDownRight01Icon';
---

<BaseLayout
  title="Home Automation & Energy Management Geelong | Smart Home | EES"
  description="Home energy management and smart automation in Geelong. Automate high-energy appliances to run on solar, control heating zones, and maximise your battery savings."
>
  <ServiceHero
    title="Home Automation & Energy Management"
    illustration="/image/illustrations/rediential_home automatiosn.png"
    illustrationAlt="Home automation and energy management illustration"
  />


  <!-- Intro: Our approach -->
  <section class="approach-section">
    <div class="container">
      <div class="approach-layout">
        <div class="approach-heading">
          <p class="section-label">The Final Step</p>
          <h2>Your Solar and<br />Battery Are Only<br />as Smart as<br />Your Home</h2>
          <div class="approach-arrow">
            <HugeIcon icon={ArrowDownRight01Icon} />
          </div>
        </div>
        <div class="approach-text">
          <p>
            You've got solar generating free electricity during the day. You've got a battery storing the excess. But if your dishwasher, washing machine, dryer, and air conditioner are all running at 6pm when you get home from work, they're pulling from the battery or the grid instead of using the free solar that was available all day.
          </p>
          <p>
            Home automation fixes this. We set up your high energy appliances to run during the day, even when you're not home, using solar electricity that would otherwise go to waste. The result is more of your solar gets used, your battery stays fuller for evening and VPP trading, and your energy costs drop further.
          </p>
          <div class="approach-image">
            <img src="/image/WIP/environmental-service-pod/esp-electrical-controls-interior.webp" alt="EES home energy management system controls" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .approach-section {
      padding: 8rem 0 4rem;
      background: #fff;
    }

    .approach-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: start;
      max-width: 1000px;
      margin: 0 auto;
    }

    .approach-heading {
      position: relative;
      padding-right: 80px;
      text-align: right;
    }

    .approach-heading h2 {
      margin-bottom: 0;
    }

    .approach-arrow {
      position: absolute;
      top: 0;
      right: 0;
      width: 50px;
      height: 50px;
      background: #C2D456;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0E2B47;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .approach-arrow.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .approach-arrow :global(svg) {
      width: 33px;
      height: 33px;
      stroke-width: 3;
      opacity: 0;
      transform: translate(-8px, -8px);
      transition: opacity 0.35s ease 0.3s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
    }

    .approach-arrow.animate-in :global(svg) {
      opacity: 1;
      transform: translate(0, 0);
    }

    .approach-text p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .approach-text p:last-child {
      margin-bottom: 0;
    }

    .approach-image {
      margin: 1.5rem 0;
    }

    .approach-image img {
      width: 77%;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .approach-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .approach-heading {
        padding-right: 0;
        text-align: center;
      }

      .approach-heading h2 {
        display: inline;
      }

      .approach-arrow {
        position: relative;
        top: auto;
        right: auto;
        display: inline-flex;
        vertical-align: top;
        margin-left: 0.5rem;
      }

      .approach-image {
        margin-top: 1.5rem;
      }

      .approach-image img {
        width: 90%;
        display: block;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    const arrow = document.querySelector('.approach-arrow');
    if (arrow) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { arrow.classList.add('animate-in'); obs.disconnect(); } });
      }, { threshold: 0.5 });
      obs.observe(arrow);
    }
  </script>


  <!-- How it works: 4-step flow -->
  <section class="automation-basics-section">
    <div class="container">
      <p class="section-label">How It Works</p>
      <h2>Solar to Smart Savings</h2>

      <svg width="0" height="0" style="position:absolute;">
        <defs>
          <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C0D446" />
            <stop offset="100%" stop-color="#2061B7" />
          </linearGradient>
        </defs>
      </svg>

      <div class="automation-basics-flow">
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={Sun01Icon} gradient="icon-gradient" />
          </div>
          <h3>Solar generates excess</h3>
          <p>Your panels produce more electricity than your home needs during the day. Instead of exporting it for almost nothing, automation puts it to work.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={SmartPhone01Icon} gradient="icon-gradient" />
          </div>
          <h3>Smart switches detect surplus</h3>
          <p>Shelly smart switches and relays monitor your solar production and battery level in real time, identifying when free energy is available.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={SmartAcIcon} gradient="icon-gradient" />
          </div>
          <h3>Appliances run automatically</h3>
          <p>High-energy loads like hot water, washing machines, and air conditioning start automatically during peak solar hours, even when you're not home.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon basics-icon--battery">
            <HugeIcon icon={BatteryFullIcon} gradient="icon-gradient" />
          </div>
          <h3>Battery stays full</h3>
          <p>Because appliances ran on solar during the day, your battery is at 95% by 5pm instead of 70% — more energy available for evening use and VPP trading.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .automation-basics-section {
      padding: 5rem 0;
      background: #f8f9fa;
    }

    .automation-basics-section .section-label,
    .automation-basics-section h2 {
      text-align: center;
    }

    .automation-basics-section h2 {
      margin-bottom: 3rem;
    }

    .automation-basics-flow {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0.75rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .basics-step {
      text-align: center;
      flex: 1;
      max-width: 200px;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .basics-arrow {
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    @keyframes arrow-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1.3); }
    }

    /* Everything flips in together */
    .automation-basics-flow.in-view .basics-step:nth-child(1) { transition-delay: 0s; transform: rotateY(0); opacity: 1; }
    .automation-basics-flow.in-view > :nth-child(2) { transition-delay: 0.15s; transform: rotateY(0); opacity: 1; }
    .automation-basics-flow.in-view .basics-step:nth-child(3) { transition-delay: 0.3s; transform: rotateY(0); opacity: 1; }
    .automation-basics-flow.in-view > :nth-child(4) { transition-delay: 0.45s; transform: rotateY(0); opacity: 1; }
    .automation-basics-flow.in-view .basics-step:nth-child(5) { transition-delay: 0.6s; transform: rotateY(0); opacity: 1; }
    .automation-basics-flow.in-view > :nth-child(6) { transition-delay: 0.75s; transform: rotateY(0); opacity: 1; }
    .automation-basics-flow.in-view .basics-step:nth-child(7) { transition-delay: 0.9s; transform: rotateY(0); opacity: 1; }

    /* Arrows pulse 1.5x after all flips finish */
    .automation-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse 0.35s ease 1.5s forwards; }
    .automation-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse 0.35s ease 1.65s forwards; }
    .automation-basics-flow.in-view > :nth-child(6) { animation: arrow-pulse 0.35s ease 1.8s forwards; }

    .basics-icon {
      width: 48px;
      height: 48px;
      margin: 0 auto 1rem;
    }

    .basics-icon :global(svg) {
      width: 100%;
      height: 100%;
    }

    .basics-icon--battery :global(path:nth-child(n+3)) {
      stroke-width: 3.5;
    }

    .basics-step h3 {
      font-size: 0.95rem;
      color: #0E2B47;
      margin-bottom: 0.4rem;
    }

    .basics-step p {
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .basics-arrow {
      width: 28px;
      flex-shrink: 0;
      color: #2061B7;
      margin-top: 0.5rem;
    }

    .basics-arrow svg {
      width: 100%;
      height: auto;
    }

    @media (max-width: 768px) {
      .automation-basics-flow {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .basics-step {
        max-width: 300px;
      }

      .basics-arrow {
        transform: rotateY(180deg) rotate(90deg);
        width: 24px;
        margin: 0;
      }

      @keyframes arrow-pulse-mobile {
        0% { transform: rotate(90deg) scale(1); }
        50% { transform: rotate(90deg) scale(1.5); }
        100% { transform: rotate(90deg) scale(1.3); }
      }

      .automation-basics-flow.in-view > .basics-arrow { transform: rotateY(0) rotate(90deg); opacity: 1; }
      .automation-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse-mobile 0.35s ease 1.5s forwards; }
      .automation-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse-mobile 0.35s ease 1.65s forwards; }
      .automation-basics-flow.in-view > :nth-child(6) { animation: arrow-pulse-mobile 0.35s ease 1.8s forwards; }
    }
  </style>

  <script>
    const flow = document.querySelector('.automation-basics-flow');
    if (flow) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { flow.classList.add('in-view'); observer.disconnect(); } });
      }, { threshold: 0.3 });
      observer.observe(flow);
    }
  </script>


  <!-- Guarantees -->
  <section class="guarantees-section">
    <div class="guarantees-section__slant"></div>
    <div class="guarantees-section__texture"></div>
    <div class="container">
      <p class="section-label" style="text-align:center;">What You Get</p>
      <h2 style="text-align:center; margin-bottom: 2.5rem;">Our Guarantees</h2>

      <div class="guarantees-grid">
        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">6</span>
            <span class="guarantee-tile__label">Appliances<br />automated</span>
          </div>
        </div>

        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">10 year</span>
            <span class="guarantee-tile__label">Workmanship<br />warranty</span>
          </div>
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">48hr</span>
            <span class="guarantee-tile__label">Fault<br />response time</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">$0</span>
            <span class="guarantee-tile__label">Consultation<br />fee</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .guarantees-section {
      position: relative;
      padding: 5rem 0 6rem;
      background: #f4f5f7;
      overflow: hidden;
    }

    .guarantees-section__slant {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: #eceef1;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
      z-index: 0;
    }

    .guarantees-section__texture {
      position: absolute;
      bottom: -500px;
      left: -100px;
      width: 1000px;
      height: 1000px;
      background: url('/image/textures/WhatWeDo_Texture.svg') no-repeat center / contain;
      transform: rotate(30deg);
      z-index: 0;
      pointer-events: none;
      opacity: 1;
    }

    .guarantees-section .container {
      position: relative;
      z-index: 1;
    }

    .guarantees-grid {
      display: flex;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .guarantee-tile {
      position: relative;
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 528 / 521;
      margin-right: -20px;
    }

    .guarantee-tile:last-child {
      margin-right: 0;
    }

    .guarantee-tile__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
    }

    .guarantee-tile__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 1.5rem;
    }

    .guarantee-tile__value {
      display: block;
      font-size: 2.25rem;
      font-weight: 800;
      color: #0E2B47;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .guarantee-tile__label {
      display: block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #0E2B47;
      line-height: 1.4;
    }

    .guarantee-tile__badge {
      position: absolute;
      bottom: -34px;
      left: 50%;
      transform: translateX(-50%);
      width: 86px;
      height: 86px;
      z-index: 2;
    }

    @media (max-width: 768px) {
      .guarantees-grid {
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .guarantee-tile {
        width: calc(50% - 0.75rem);
        flex-shrink: 0;
        margin-right: 0;
      }

      .guarantee-tile__value {
        font-size: 1.75rem;
      }

      .guarantee-tile__label {
        font-size: 0.85rem;
      }

      .guarantee-tile__badge {
        width: 67px;
        height: 67px;
        bottom: -22px;
        left: 50%;
        transform: translateX(-50%);
      }

      .guarantees-section__texture {
        width: 600px;
        height: 600px;
        bottom: -300px;
        left: -80px;
      }
    }
  </style>


  <!-- Automation levels comparison table -->
  <section class="automation-tiers-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="tiers-decoration" aria-hidden="true" />
    <div class="container">
      <div class="spec-cards-header">
        <p class="section-label">Automation Levels</p>
        <h2>Start Simple, Add Over Time</h2>
      </div>

      <div class="tier-comparison-table">
        <table>
          <thead>
            <!-- Card row -->
            <tr class="tier-card-row">
              <th></th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Essential</h3>
                <p class="tier-desc">Start with the two biggest energy consumers — hot water scheduling and pool pump automation. The simplest setup with immediate impact on solar utilisation.</p>
                <span class="tier-badge">Best for: Getting started</span>
              </th>
              <th class="tier-card-cell tier-card-cell--popular">
                <div class="tier-card-top-bar"></div>
                <div class="tier-popular-tag">Most Popular</div>
                <h3>Standard</h3>
                <p class="tier-desc">Add air conditioning and laundry automation. Your home maintains temperature during the day on solar and appliances run before you get home.</p>
                <span class="tier-badge">Best for: Most households</span>
              </th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Complete</h3>
                <p class="tier-desc">Full home energy management including EV charging, dishwasher scheduling, and zone-by-zone climate control. Maximum solar utilisation and VPP earnings.</p>
                <span class="tier-badge">Best for: Full optimisation</span>
              </th>
            </tr>
            <!-- Column label row -->
            <tr class="tier-label-row">
              <th>Feature</th>
              <th>Essential</th>
              <th>Standard</th>
              <th>Complete</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Appliances Controlled</td>
              <td>Hot water + pool pump</td>
              <td>+ AC + washing machine</td>
              <td>+ EV charging + dishwasher + zones</td>
            </tr>
            <tr>
              <td>Shelly Devices Needed</td>
              <td>2–3 devices</td>
              <td>4–6 devices</td>
              <td>8+ devices</td>
            </tr>
            <tr>
              <td>Solar Utilisation Improvement</td>
              <td>15–25% more self-consumption</td>
              <td>30–45% more</td>
              <td>50%+ more</td>
            </tr>
            <tr>
              <td>Battery Level at 5pm</td>
              <td>~80% (vs 70% without)</td>
              <td>~90%</td>
              <td>~95%</td>
            </tr>
            <tr>
              <td>VPP Earning Impact</td>
              <td>Moderate improvement</td>
              <td>Significant improvement</td>
              <td>Maximum earnings potential</td>
            </tr>
            <tr>
              <td>Setup Complexity</td>
              <td>Simple (half day)</td>
              <td>Standard (1 day)</td>
              <td>Comprehensive (1–2 days)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile stacked cards (hidden on desktop) -->
      <div class="tier-mobile-cards">
        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Essential</h3>
            <p>Start with the two biggest energy consumers — hot water scheduling and pool pump automation. The simplest setup with immediate impact on solar utilisation.</p>
            <span class="tier-badge">Best for: Getting started</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Appliances Controlled</dt><dd>Hot water + pool pump</dd></div>
            <div><dt>Shelly Devices Needed</dt><dd>2–3 devices</dd></div>
            <div><dt>Solar Utilisation Improvement</dt><dd>15–25% more self-consumption</dd></div>
            <div><dt>Battery Level at 5pm</dt><dd>~80% (vs 70% without)</dd></div>
            <div><dt>VPP Earning Impact</dt><dd>Moderate improvement</dd></div>
            <div><dt>Setup Complexity</dt><dd>Simple (half day)</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card tier-mobile-card--popular">
          <div class="tier-mobile-card__header">
            <div class="tier-popular-tag">Most Popular</div>
            <h3>Standard</h3>
            <p>Add air conditioning and laundry automation. Your home maintains temperature during the day on solar and appliances run before you get home.</p>
            <span class="tier-badge">Best for: Most households</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Appliances Controlled</dt><dd>+ AC + washing machine</dd></div>
            <div><dt>Shelly Devices Needed</dt><dd>4–6 devices</dd></div>
            <div><dt>Solar Utilisation Improvement</dt><dd>30–45% more</dd></div>
            <div><dt>Battery Level at 5pm</dt><dd>~90%</dd></div>
            <div><dt>VPP Earning Impact</dt><dd>Significant improvement</dd></div>
            <div><dt>Setup Complexity</dt><dd>Standard (1 day)</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Complete</h3>
            <p>Full home energy management including EV charging, dishwasher scheduling, and zone-by-zone climate control. Maximum solar utilisation and VPP earnings.</p>
            <span class="tier-badge">Best for: Full optimisation</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Appliances Controlled</dt><dd>+ EV charging + dishwasher + zones</dd></div>
            <div><dt>Shelly Devices Needed</dt><dd>8+ devices</dd></div>
            <div><dt>Solar Utilisation Improvement</dt><dd>50%+ more</dd></div>
            <div><dt>Battery Level at 5pm</dt><dd>~95%</dd></div>
            <div><dt>VPP Earning Impact</dt><dd>Maximum earnings potential</dd></div>
            <div><dt>Setup Complexity</dt><dd>Comprehensive (1–2 days)</dd></div>
          </dl>
        </div>
      </div>

      <div class="tier-detail-cta">
        <a href="/services/consultation" class="btn btn-primary">Get a Free Solar Quote</a>
