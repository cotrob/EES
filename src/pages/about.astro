---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import SplitFeature from '../components/sections/SplitFeature.astro';
import IconFeatureGrid from '../components/sections/IconFeatureGrid.astro';
import RelatedNav from '../components/sections/RelatedNav.astro';
---

<BaseLayout
  title="About EES | CEC Accredited Solar & Energy Installer Geelong"
  description="EES is a CEC-accredited solar and energy services company in Geelong, specialising in solar, batteries, heat pumps, hydronic heating, and home automation."
>
  <section class="page-header">
    <div class="container">
      <h1>About EES</h1>
      <p>Local energy experts based in Geelong.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_19_TopCut_.webp" alt="EES headquarters in Moolap, Geelong" bg="white">
    <p class="section-label">Who We Are</p>
    <h2>More Than a Solar Installer</h2>
    <p>
      Environmental Energy Services (EES) is a Geelong-based energy company that designs, installs, and supports complete home and commercial energy systems — solar, batteries, heat pumps, hydronic heating and cooling, and smart automation.
    </p>
    <p>
      We take a whole-of-home approach to energy, designing systems where every component works together — not in isolation. Our goal is to reduce your energy costs, improve your comfort, and move your property toward energy independence.
    </p>
  </SplitFeature>

  <IconFeatureGrid
    label="Our Difference"
    heading="What Makes Us Different"
    bg="light"
    columns={3}
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
        title: 'We Build Our Own Products',
        description: 'Hydronic ceiling panels and the Environmental Service Pod are designed, manufactured, and tested in-house at our research facility.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
        title: 'We Do the Research',
        description: 'Our TestCell is built to ASHRAE-55 and ISO 7730 standards for real-world thermal comfort and energy efficiency testing.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>',
        title: 'We Install What We Design',
        description: 'CEC-accredited electricians install every system. No subcontractors, no third-party handoffs.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
        title: 'Commission & Test Every System',
        description: 'We walk you through the monitoring and make sure everything is working correctly before we leave.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
        title: '10-Year Workmanship Warranty',
        description: 'Every installation is backed by our warranty and ongoing local support. We\'re here for the long term.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
        title: 'Local Geelong Team',
        description: 'Based in Moolap, servicing Greater Geelong, Torquay, Surf Coast, Bellarine, and Golden Plains.'
      },
    ]}
  />

  <section class="accreditations-inline">
    <div class="container">
      <p class="section-label" style="text-align: center;">Accreditations</p>
      <h2 style="text-align: center; font-size: 2.25rem; font-weight: 700; color: #0E2B47; margin-bottom: 2rem;">Our Credentials</h2>
      <div class="accreditations-logos">
        <div class="accreditation-logo"><img src="/image/_logos_partners/clean-energy-council-member.webp" alt="Clean Energy Council Member" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/cec-approved-seller.webp" alt="CEC Approved Seller" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/solar-accreditation-australia.webp" alt="Solar Accreditation Australia" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/smart-energy-council.webp" alt="Smart Energy Council" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/tesla-energy-certified.webp" alt="Tesla Energy Certified Installer" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/energy-safe-victoria.webp" alt="Energy Safe Victoria" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/solar-victoria.webp" alt="Solar Victoria" /></div>
        <div class="accreditation-logo accreditation-logo--large"><img src="/image/_logos_partners/enphase.webp" alt="Enphase Silver Installer" /></div>
        <div class="accreditation-logo accreditation-logo--large"><img src="/image/_logos_partners/newenergytech_approvaed seller.webp" alt="New Energy Tech Approved Seller" /></div>
        <div class="accreditation-logo accreditation-logo--medium"><img src="/image/_logos_partners/sigenergy-certified-installer.webp" alt="Sigenergy Certified Installer" /></div>
      </div>
    </div>
  </section>

  <SplitFeature image="/image/WIP/TestRoom_webp/testroom-aerial-facility-close.webp" alt="EES research facility aerial view" reverse bg="light">
    <p class="section-label">Research & Development</p>
    <h2>Purpose-Built Research Facility</h2>
    <p>
      We operate a purpose-built research facility with a full-scale TestCell for thermal comfort and energy efficiency testing. This facility allows us to test products under controlled, measurable conditions before they go into homes.
    </p>
    <p>Products developed in our facility include:</p>
    <ul>
      <li><a href="/laboratory/hydronic-ceiling-panels">Hydronic ceiling panels</a> — suspended radiant panels for heating and cooling</li>
      <li><a href="/laboratory/environmental-service-pod">Environmental Service Pod</a> — an integrated modular system combining solar, battery, heat pump, and thermal storage</li>
    </ul>
  </SplitFeature>

  <section class="team-section">
    <div class="container">
      <h2 class="team-heading">The Team</h2>
      <div class="team-grid">
        <div class="team-member">
          <img src="/image/photos_team/DrMarkLuther_clean_transparent.png" alt="Mark B. Luther" loading="lazy" />
          <h3>Mark B. Luther</h3>
          <p class="team-role">Director (Arch.D. - Architect)</p>
          <p>Honorary Professor of Deakin University after 27 years of service. He specialises in Architecture Science and Environmental Technology. Inventor of the Environmental Service Pod and the Autonomatic Hydronic Ceiling Panel.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/LincolnLuther_clean_transparent.png" alt="Lincoln B. Luther" loading="lazy" />
          <h3>Lincoln B. Luther</h3>
          <p class="team-role">Manager of Sales</p>
          <p>Over 4 years industry experience in the renewables energy sector with a background in Economics, Banking and Finance. He specialises in solar, battery and renewable building services.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/Matthew Ellison_02_clean_transparent.png" alt="Matthew Ellison" loading="lazy" />
          <h3>Matthew Ellison</h3>
          <p class="team-role">Manager of Installations</p>
          <p>Senior electrician experienced in Solar PV and Battery installations in commercial and residential projects. Also involved with electrical research and design on the Environmental Service Pod and Hydronic Control.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/HungQDo_clean_transparent.png" alt="Hung Q. Do" loading="lazy" />
          <h3>Hung Q. Do</h3>
          <p class="team-role">Research Development</p>
          <p>PhD candidate specialising in hydronic ceiling innovative systems. His research focuses on effective conditioning through hydronic control in commercial buildings.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/placeholder.svg" alt="Pat Sandall" loading="lazy" />
          <h3>Pat Sandall</h3>
          <p class="team-role">Head Electrician, A Grade</p>
          <p>A Grade electrician leading EES field installations across solar, battery, and integrated energy systems for residential and commercial projects.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/placeholder.svg" alt="Caleb Nowson" loading="lazy" />
          <h3>Caleb Nowson</h3>
          <p class="team-role">Business Development Manager</p>
          <p>Manages business development and client relationships, connecting homeowners and businesses with the right energy solutions.</p>
        </div>
      </div>
    </div>
  </section>

  <RelatedNav
    links={[
      { href: '/services/residential', title: 'Residential Systems', description: 'Solar, battery, heat pump solutions' },
      { href: '/services/commercial', title: 'Commercial Systems', description: 'Solar and battery for business' },
      { href: '/services/consultation', title: 'Free Consultation', description: 'Book a no-obligation assessment' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to work with a local team that designs, installs, and supports?</p>
      <a href="/services/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>

<style>
  .team-section {
    padding: 4rem 0;
    background: #fff;
  }

  .team-heading {
    font-size: 2rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .team-member {
    text-align: center;
  }

  .team-member img {
    width: 160px;
    height: 160px;
    object-fit: cover;
    object-position: top center;
    border-radius: 50%;
    background: #fff;
    border: 3px solid transparent;
    background-image: linear-gradient(#fff, #fff), linear-gradient(135deg, #C0D446 0%, #e5e7eb 30%, #e5e7eb 100%);
    background-origin: border-box;
    background-clip: padding-box, border-box;
    margin: 0 auto 1rem;
    display: block;
  }

  .team-member h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-size: 0.8rem;
    color: #2061B7;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .team-member > p:last-child {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
  }

  .accreditations-inline {
    padding: 4rem 0;
    background: #fff;
  }

  .accreditations-logos {
    display: grid;
    grid-template-columns: repeat(4, auto);
    align-items: center;
    justify-content: center;
    gap: 2.5rem 3rem;
    margin: 0 auto;
  }

  .accreditation-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .accreditation-logo img {
    height: 52px;
    width: auto;
    max-width: none;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .accreditation-logo--large img {
    height: 85px;
  }

  .accreditation-logo--medium img {
    height: 65px;
  }

  .accreditation-logo img:hover {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .accreditations-logos {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 500px;
    }
  }

  @media (max-width: 500px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
