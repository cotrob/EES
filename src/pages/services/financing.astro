---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import SplitFeature from '../../components/sections/SplitFeature.astro';
import SpecCards from '../../components/sections/SpecCards.astro';
import IconFeatureGrid from '../../components/sections/IconFeatureGrid.astro';
import RelatedNav from '../../components/sections/RelatedNav.astro';
---

<BaseLayout
  title="Solar Financing & Payment Plans | Interest-Free Options | EES"
  description="Solar and battery financing options including interest-free plans. Government rebates, green loans, and buy-now-pay-later available."
>
  <section class="page-header">
    <div class="container">
      <h1>Financing Options</h1>
      <p>Flexible ways to pay for your solar, battery, or energy system.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_17_TopCut_.webp" alt="EES solar installation" bg="white">
    <p class="section-label">Affordable Energy</p>
    <h2>Making Energy Upgrades Affordable</h2>
    <p>
      A solar, battery, or heat pump system pays for itself over time through reduced energy bills — but the upfront cost can be a barrier. We offer several financing options so you can start saving now without a large upfront payment.
    </p>
  </SplitFeature>

  <SpecCards
    label="Payment Options"
    heading="Choose How You Pay"
    cards={[
      {
        title: 'Interest-Free Plans',
        body: 'Spread the cost of your system over time with no interest charges. Start saving on energy bills from day one while paying off the system in manageable instalments.',
        footer: 'No interest charges'
      },
      {
        title: 'Green Loans',
        body: 'Several Australian lenders offer green loans for energy-efficient home improvements. These typically offer lower interest rates than standard personal loans because they\'re secured against a cost-reducing asset.',
        footer: 'Lower interest rates'
      },
      {
        title: 'Buy Now, Pay Later',
        body: 'Get your system installed immediately and pay in regular instalments over an agreed period. No large deposit required for qualifying systems.',
        footer: 'No large deposit'
      },
    ]}
  />

  <IconFeatureGrid
    label="Government Support"
    heading="Rebates and Incentives"
    description="Several government programs reduce the upfront cost of your system."
    bg="light"
    columns={2}
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/></svg>',
        title: 'Federal STC Rebate',
        description: 'Small-scale Technology Certificates provide a point-of-sale discount on solar and heat pump installations. Applied directly to your quote.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg>',
        title: 'Victorian Solar Rebate',
        description: 'Solar Victoria rebates for eligible properties based on property value and household income. We handle the application for you.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="7" width="12" height="10" rx="1"/><line x1="10" y1="7" x2="10" y2="4"/><line x1="14" y1="7" x2="14" y2="4"/><path d="M10 17v3"/><path d="M14 17v3"/></svg>',
        title: 'Victorian Battery Rebate',
        description: 'A separate rebate for home battery installations through Solar Victoria. Can be combined with the solar rebate.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
        title: 'Victorian Energy Upgrades (VEU)',
        description: 'Incentives for energy-efficient upgrades including heat pumps and hot water systems. Rebate values vary by product and location.'
      },
    ]}
  />

  <SplitFeature image="/image/WIP/environmental-service-pod/esp-complete-system-front-photo.webp" alt="Environmental Service Pod complete system" reverse bg="white">
    <p class="section-label">What Can Be Financed?</p>
    <h2>Finance Any Energy System</h2>
    <p>Financing isn't just for solar panels. We can arrange payment plans for:</p>
    <ul>
      <li>Solar panel systems</li>
      <li>Battery storage</li>
      <li>Heat pump hot water systems</li>
      <li>Hydronic heating and cooling</li>
      <li>Home automation and energy management</li>
      <li>Complete system packages (solar + battery + heat pump)</li>
    </ul>
  </SplitFeature>

  <RelatedNav
    links={[
      { href: '/services/consultation', title: 'Free Consultation', description: 'Discuss your financing options in person' },
      { href: '/services/residential', title: 'Residential Systems', description: 'See what systems are available' },
      { href: '/services/faq', title: 'FAQ', description: 'Common questions about rebates and costs' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to discuss financing and rebates for your system?</p>
      <a href="/services/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>
