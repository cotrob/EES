---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
---

<BaseLayout
  title="About EES | Family-Owned Solar & Energy Installer Geelong"
  description="Meet the team behind EES. Family-owned and operated from Moolap, Geelong. CEC accredited solar, battery, heat pump, and energy system specialists with a research lab on site."
>
  <!-- ── Hero: Full-bleed photo with editorial overlay ── -->
  <section class="about-hero">
    <div class="about-hero-bg">
      <img src="/image/photos_EESshed/Aboutus_exterior.webp" alt="EES facility exterior in Moolap, Geelong" />
      <div class="about-hero-overlay"></div>
    </div>
    <div class="about-hero-content">
      <p class="about-hero-label">About EES</p>
      <h1>A family business<br />built on research,<br />run by <span class="hero-accent">electricians</span></h1>
      <p class="about-hero-sub">Based in Moolap, Geelong. Servicing Greater Geelong, Melbourne &amp; Regional Victoria.</p>
    </div>
    <img src="/image/icon/Brand_wave_dots_white.svg" alt="" class="about-hero-wave" aria-hidden="true" />
  </section>

  <!-- ── Intro strip ── -->
  <section class="intro-strip">
    <div class="container">
      <div class="intro-strip-inner">
        <div class="intro-stat">
          <span class="intro-stat-number">10+</span>
          <span class="intro-stat-label">Years operating<br />in Geelong</span>
        </div>
        <div class="intro-stat">
          <span class="intro-stat-number">10yr</span>
          <span class="intro-stat-label">Workmanship<br />warranty</span>
        </div>
        <div class="intro-stat">
          <span class="intro-stat-number">5000+</span>
          <span class="intro-stat-label">Panels installed<br />&amp; counting</span>
        </div>
      </div>
    </div>
  </section>
  <div class="intro-curve">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L0,40 Q720,80 1440,40 L1440,0 Z" fill="#0E2B47" />
    </svg>
  </div>

  <!-- ── Our Story ── -->
  <section class="story-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="story-wave" aria-hidden="true" />
    <div class="container">
      <div class="story-layout">
        <div class="story-col-left">
          <p class="section-label">Our Story</p>
          <h2 class="story-heading">What if a home could<br />heat, cool, and power<br /><strong>itself?</strong></h2>
          <p class="story-lead">That question led to the founding of Environmental Energy Services in Moolap, Geelong.</p>
        </div>
        <div class="story-col-right">
          <p>What began as a research project has grown into a full-service energy company with its own laboratory, its own products, and a team of qualified electricians and researchers working under one roof.</p>
          <p>We're not a marketing company that outsources installations. We hold our own REC Electrical Licence. Our team <strong>designs, installs, and supports every system we put in</strong>. Your warranty sits with a real brick-and-mortar business here in Geelong, not a call centre somewhere else.</p>
          <p>We come from a research and academic background. Our founding director, Dr Mark Luther, is an Honorary Professor of Deakin University after 27 years of service. That research-first thinking runs through everything we do, from how we analyse your energy data to how we design your system.</p>
        </div>
      </div>
      <div class="story-photos">
        <div class="story-photo story-photo--wide">
          <img src="/image/photos_EESshed/Group%20131%20(1).png" alt="EES team members outside the Moolap facility" loading="lazy" />
        </div>
        <div class="story-photo story-photo--tall">
          <img src="/image/photos_EESshed/Group%20132.png" alt="EES headquarters in Moolap, Geelong" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── What Makes Us Different ── -->
  <section class="difference-section">
    <div class="container">
      <div class="difference-header">
        <p class="section-label section-label--light">What Makes Us Different</p>
        <h2>We don't just install.<br />We understand your home.</h2>
      </div>
      <div class="difference-grid">
        <div class="difference-card">
          <div class="difference-number">01</div>
          <h3>Your whole energy picture</h3>
          <p>We look at everything together. Solar, battery, heat pump, hot water, automation, and whether it makes sense to move away from gas. Every recommendation is based on how you actually use energy and what you're planning for the future.</p>
        </div>
        <div class="difference-card">
          <div class="difference-number">02</div>
          <h3>Designed from your data</h3>
          <p>We pull your interval metering data down to half-hour increments so we can see exactly where your power goes and when. That way we can size your system properly and make sure it's working with your household, not against it.</p>
        </div>
        <div class="difference-card">
          <div class="difference-number">03</div>
          <h3>Monitored every morning</h3>
          <p>Every system we install is connected to our monitoring portal. Our team checks performance each morning, and we've contacted clients about faults before they even noticed. If something critical comes up, we respond within 48 business hours.</p>
        </div>
        <div class="difference-card">
          <div class="difference-number">04</div>
          <h3>Experience with quality homes</h3>
          <p>Around 50 to 60 percent of our work is in architectural and designed homes. We work alongside architects and builders to run cabling neatly, match finishes, and make sure the system suits the property.</p>
        </div>
        <div class="difference-card">
          <div class="difference-number">05</div>
          <h3>10-year workmanship warranty</h3>
          <p>That's double the legal minimum. We've been operating for over a decade, and your warranty sits with a real local business, not a call centre. We stand behind our work because we're here for the long run.</p>
        </div>
        <div class="difference-card">
          <div class="difference-number">06</div>
          <h3>Support after installation</h3>
          <p>We stay in touch after your system is in. Whether it's checking in about a better electricity plan, setting up a VPP, or helping you get more out of what you've got, we're always happy to have a chat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── The Team ── -->
  <section class="team-section">
    <div class="container">
      <div class="team-header">
        <p class="section-label">The People</p>
        <h2>Meet our team</h2>
        <p class="team-intro">From research to installation to ongoing support, every part of EES is handled in-house by people who know what they're doing.</p>
      </div>
      <div class="team-grid">
        <div class="team-member">
          <img src="/image/photos_team/DrMarkLuther_clean_transparent.png" alt="Dr Mark Luther" loading="lazy" />
          <h3>Dr Mark B. Luther</h3>
          <p class="team-role">Director (Arch.D.)</p>
          <p>Honorary Professor of Deakin University after 27 years of service. Specialises in Architecture Science and Environmental Technology. Inventor of the Environmental Service Pod and the Autonomatic Hydronic Ceiling Panel.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/LincolnLuther_clean_transparent.png" alt="Lincoln Luther" loading="lazy" />
          <h3>Lincoln B. Luther</h3>
          <p class="team-role">Manager of Sales</p>
          <p>Over 4 years industry experience in renewables with a background in Economics, Banking and Finance. Leads every consultation, system design, and energy analysis. The first person you'll speak to.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/Matthew Ellison_02_clean_transparent.png" alt="Matthew Ellison" loading="lazy" />
          <h3>Matthew Ellison</h3>
          <p class="team-role">Manager of Installations</p>
          <p>Senior electrician experienced in residential and commercial solar PV and battery installations. Checks every system every morning through back-to-base monitoring. Also involved in research and design on the Environmental Service Pod.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/placeholder.svg" alt="Pat Sandall" loading="lazy" />
          <h3>Pat Sandall</h3>
          <p class="team-role">Head Electrician, A Grade</p>
          <p>A Grade electrician leading EES field installations across solar, battery, and integrated energy systems for residential and commercial projects.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/placeholder.svg" alt="Caleb Nowson" loading="lazy" />
          <h3>Caleb Nowson</h3>
          <p class="team-role">Business Development Manager</p>
          <p>Manages business development and client relationships, connecting homeowners and businesses with the right energy solutions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Accreditations ── -->
  <section class="accreditations-section">
    <div class="container">
      <p class="section-label" style="text-align: center;">Accreditations</p>
      <h2 class="accreditations-heading">Our Credentials</h2>
      <div class="accreditations-logos">
        <div class="accreditation-logo"><img src="/image/_logos_partners/clean-energy-council-member.webp" alt="Clean Energy Council Member" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/cec-approved-seller.webp" alt="CEC Approved Seller" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/solar-accreditation-australia.webp" alt="Solar Accreditation Australia" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/smart-energy-council.webp" alt="Smart Energy Council" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/tesla-energy-certified.webp" alt="Tesla Energy Certified Installer" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/energy-safe-victoria.webp" alt="Energy Safe Victoria" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/solar-victoria.webp" alt="Solar Victoria" /></div>
        <div class="accreditation-logo accreditation-logo--large"><img src="/image/_logos_partners/enphase.webp" alt="Enphase Silver Installer" /></div>
        <div class="accreditation-logo accreditation-logo--large"><img src="/image/_logos_partners/newenergytech_approvaed seller.webp" alt="New Energy Tech Approved Seller" /></div>
        <div class="accreditation-logo accreditation-logo--medium"><img src="/image/_logos_partners/sigenergy-certified-installer.webp" alt="Sigenergy Certified Installer" /></div>
      </div>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>

<style>
  /* ── Force solid dark nav on white page ── */
  :global(.header-v2::before) {
    background: rgba(14, 43, 71, 0.95) !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  /* ── Hero ── */
  .about-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
  }

  .about-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(14, 43, 71, 0.92) 0%,
      rgba(14, 43, 71, 0.6) 40%,
      rgba(14, 43, 71, 0.3) 100%
    );
  }

  .about-hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1rem 5rem;
    width: 100%;
  }

  .about-hero-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #C2D456;
    margin-bottom: 1rem;
  }

  .about-hero h1 {
    font-size: 3.2rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .hero-accent {
    color: #C2D456;
  }

  .about-hero-sub {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 480px;
    line-height: 1.6;
  }

  .about-hero-wave {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 45%;
    opacity: 0.06;
    z-index: 1;
    pointer-events: none;
  }

  /* ── Intro stat strip ── */
  .intro-strip {
    background: #0E2B47;
    padding: 0;
    position: relative;
    z-index: 3;
  }

  .intro-strip-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .intro-stat {
    padding: 2rem 1.5rem;
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }

  .intro-stat:last-child {
    border-right: none;
  }

  .intro-stat-number {
    display: block;
    font-size: 2.2rem;
    font-weight: 800;
    color: #C2D456;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .intro-stat-label {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.4;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── Curve divider ── */
  .intro-curve {
    line-height: 0;
    margin-top: -1px;
  }

  .intro-curve svg {
    display: block;
    width: 100%;
    height: 50px;
  }

  /* ── Our Story ── */
  .story-section {
    padding: 6rem 0 4rem;
    background: #fff;
    position: relative;
    overflow: hidden;
  }

  .story-wave {
    position: absolute;
    right: -8%;
    bottom: -10%;
    transform: rotate(100deg);
    opacity: 0.12;
    pointer-events: none;
    height: 80%;
    width: auto;
    z-index: 0;
  }

  .story-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .story-col-left .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0E2B47;
    margin-bottom: 0.75rem;
  }

  .story-heading {
    font-size: 2.3rem;
    font-weight: 300;
    color: #0E2B47;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .story-heading strong {
    font-weight: 700;
  }

  .story-lead {
    font-size: 1.1rem;
    color: #0E2B47;
    font-weight: 500;
    line-height: 1.5;
  }

  .story-col-right p {
    color: #444;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .story-col-right p strong {
    font-weight: 700;
    color: #0E2B47;
  }

  .story-photos {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .story-photo {
    border-radius: 12px;
    overflow: hidden;
  }

  .story-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .story-photo--wide img {
    aspect-ratio: 16 / 9;
  }

  .story-photo--tall img {
    aspect-ratio: 3 / 4;
  }

  /* ── What Makes Us Different ── */
  .difference-section {
    padding: 5rem 0;
    background: #f7f8f4;
  }

  .difference-header {
    margin-bottom: 3.5rem;
  }

  .section-label--light {
    color: #0E2B47 !important;
  }

  .difference-header .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0E2B47;
    margin-bottom: 0.75rem;
  }

  .difference-header h2 {
    font-size: 2.3rem;
    font-weight: 700;
    color: #0E2B47;
    line-height: 1.2;
    max-width: 520px;
  }

  .difference-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .difference-card {
    background: #fff;
    border-radius: 12px;
    padding: 2rem 1.75rem;
    border: 1px solid #e8e9e4;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .difference-card:hover {
    border-color: #C2D456;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .difference-number {
    font-size: 0.75rem;
    font-weight: 800;
    color: #C2D456;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
  }

  .difference-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 0.75rem;
  }

  .difference-card p {
    font-size: 0.88rem;
    color: #555;
    line-height: 1.65;
  }

  /* ── Team ── */
  .team-section {
    padding: 5rem 0;
    background: #fff;
  }

  .team-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .team-header .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0E2B47;
    margin-bottom: 0.75rem;
  }

  .team-header h2 {
    font-size: 2.3rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 0.75rem;
  }

  .team-intro {
    font-size: 0.95rem;
    color: #555;
    max-width: 560px;
    line-height: 1.6;
    margin: 0 auto;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .team-member {
    text-align: center;
  }

  .team-member img {
    width: 160px;
    height: 160px;
    object-fit: cover;
    object-position: top center;
    border-radius: 50%;
    background: #fff;
    border: 3px solid transparent;
    background-image: linear-gradient(#fff, #fff), linear-gradient(135deg, #C0D446 0%, #e5e7eb 30%, #e5e7eb 100%);
    background-origin: border-box;
    background-clip: padding-box, border-box;
    margin: 0 auto 1rem;
    display: block;
  }

  .team-member h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 0.2rem;
  }

  .team-role {
    font-size: 0.78rem;
    color: #2061B7;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }

  .team-member > p:last-child {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.6;
    max-width: 320px;
    margin: 0 auto;
  }

  /* ── Accreditations ── */
  .accreditations-section {
    padding: 4rem 0;
    background: #f8f9fa;
  }

  .accreditations-section .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0E2B47;
    margin-bottom: 0.5rem;
  }

  .accreditations-heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 2rem;
  }

  .accreditations-logos {
    display: grid;
    grid-template-columns: repeat(4, auto);
    align-items: center;
    justify-content: center;
    gap: 2.5rem 3rem;
    margin: 0 auto;
  }

  .accreditation-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .accreditation-logo img {
    height: 52px;
    width: auto;
    max-width: none;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .accreditation-logo--large img {
    height: 85px;
  }

  .accreditation-logo--medium img {
    height: 65px;
  }

  .accreditation-logo img:hover {
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .about-hero h1 {
      font-size: 2.4rem;
    }

    .story-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .story-heading {
      font-size: 1.8rem;
    }

    .story-photos {
      grid-template-columns: 1fr 1fr;
    }

    .difference-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .intro-strip-inner {
      grid-template-columns: repeat(2, 1fr);
    }

    .intro-stat {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .intro-stat:nth-child(2) {
      border-right: none;
    }

    .intro-stat:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }

  @media (max-width: 600px) {
    .about-hero {
      min-height: 55vh;
    }

    .about-hero h1 {
      font-size: 1.8rem;
    }

    .about-hero-content {
      padding: 3rem 1rem 3.5rem;
    }

    .story-section {
      padding: 4rem 0 3rem;
    }

    .story-heading {
      font-size: 1.6rem;
    }

    .story-photos {
      grid-template-columns: 1fr;
    }

    .story-photo--tall img {
      aspect-ratio: 16 / 9;
    }

    .difference-grid {
      grid-template-columns: 1fr;
    }

    .difference-header h2 {
      font-size: 1.6rem;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }

    .intro-strip-inner {
      grid-template-columns: 1fr 1fr;
    }

    .accreditations-logos {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 500px;
    }

  }
</style>
