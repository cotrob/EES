---
interface Link {
  href: string;
  title: string;
  description: string;
}

interface Props {
  heading?: string;
  links: Link[];
}

const { heading = 'Continue Exploring', links } = Astro.props;
---

<section class="related-nav">
  <div class="container">
    <h2>{heading}</h2>
    <div class="related-grid">
      {links.map((link) => (
        <a href={link.href} class="related-card">
          <div class="related-card-text">
            <h3>{link.title}</h3>
            <p>{link.description}</p>
          </div>
          <span class="related-arrow">&rarr;</span>
        </a>
      ))}
    </div>
  </div>
</section>
