---
interface Props {
  image: string;
  alt: string;
  reverse?: boolean;
  bg?: 'white' | 'light' | 'cream';
  flat?: boolean;
}

const { image, alt, reverse = false, bg = 'white', flat = false } = Astro.props;

const bgMap = {
  white: '#fff',
  light: '#f8f9fa',
  cream: 'rgba(240, 238, 217, 0.25)',
};
---

<section class={`split-feature ${reverse ? 'split-feature--reverse' : ''}`} style={`background: ${bgMap[bg]};`}>
  <div class="container">
    <div class="split-layout">
      <div class="split-text">
        <slot />
      </div>
      <div class={`split-image ${flat ? 'split-image--flat' : ''}`}>
        <img src={image} alt={alt} loading="lazy" />
      </div>
    </div>
  </div>
</section>
