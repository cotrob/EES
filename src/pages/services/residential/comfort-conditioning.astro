---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import IconFeatureGrid from '../../../components/sections/IconFeatureGrid.astro';
import FaqGroup from '../../../components/sections/FaqGroup.astro';
import ServiceHero from '../../../components/sections/ServiceHero.astro';
import HugeIcon from '../../../components/HugeIcon.astro';
import { hugeIconToSvg } from '../../../lib/hugeicon-svg';
import SmileIcon from '@hugeicons/core-free-icons/SmileIcon';
import Pulse01Icon from '@hugeicons/core-free-icons/Pulse01Icon';
import ZapIcon from '@hugeicons/core-free-icons/ZapIcon';
import ShieldEnergyIcon from '@hugeicons/core-free-icons/ShieldEnergyIcon';
import HeaterIcon from '@hugeicons/core-free-icons/HeaterIcon';
import DropletIcon from '@hugeicons/core-free-icons/DropletIcon';
import Sun01Icon from '@hugeicons/core-free-icons/Sun01Icon';
import SmartPhone01Icon from '@hugeicons/core-free-icons/SmartPhone01Icon';
import ArrowRight01Icon from '@hugeicons/core-free-icons/ArrowRight01Icon';
import ArrowDownRight01Icon from '@hugeicons/core-free-icons/ArrowDownRight01Icon';
---

<BaseLayout
  title="Hydronic Heating & Cooling Geelong | Radiant Ceiling Panels | EES"
  description="Hydronic heating and cooling systems in Geelong. Radiant ceiling panels that heat and cool your home silently at a third of the running cost. Replace gas ducted heating with renewable energy."
>
  <ServiceHero
    title="Hydronic Heating & Cooling"
    illustration="/image/illustrations/Residential  Solar Systems.png"
    illustrationAlt="Hydronic heating and cooling system illustration"
  />


  <!-- Intro: Our approach -->
  <section class="approach-section">
    <div class="container">
      <div class="approach-layout">
        <div class="approach-heading">
          <p class="section-label">A Better Way to Heat and Cool</p>
          <h2>Your Gas Ducted<br />Heater Is the Most<br />Expensive Appliance<br />in Your Home</h2>
          <div class="approach-arrow">
            <HugeIcon icon={ArrowDownRight01Icon} />
          </div>
        </div>
        <div class="approach-text">
          <p>
            Gas ducted central heating blows warm air through ducts in your ceiling. It's noisy, it circulates dust, it creates hot and cold spots, and gas prices in Victoria have been climbing faster than electricity for years.
          </p>
          <p>
            Hydronic radiant panels are the opposite. They heat and cool your home by radiating energy directly from the ceiling, the same way the sun warms the earth. No fans, no dust, no noise. And when paired with solar, the running cost drops to nearly zero.
          </p>
          <div class="approach-image">
            <img src="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-installed-ceiling-residential.webp" alt="Hydronic radiant ceiling panel installed in a residential home" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .approach-section {
      padding: 8rem 0 4rem;
      background: #fff;
    }

    .approach-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: start;
      max-width: 1000px;
      margin: 0 auto;
    }

    .approach-heading {
      position: relative;
      padding-right: 80px;
      text-align: right;
    }

    .approach-heading h2 {
      margin-bottom: 0;
    }

    .approach-arrow {
      position: absolute;
      top: 0;
      right: 0;
      width: 50px;
      height: 50px;
      background: #C2D456;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0E2B47;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .approach-arrow.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .approach-arrow :global(svg) {
      width: 33px;
      height: 33px;
      stroke-width: 3;
      opacity: 0;
      transform: translate(-8px, -8px);
      transition: opacity 0.35s ease 0.3s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
    }

    .approach-arrow.animate-in :global(svg) {
      opacity: 1;
      transform: translate(0, 0);
    }

    .approach-text p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .approach-text p:last-child {
      margin-bottom: 0;
    }

    .approach-image {
      margin: 1.5rem 0;
    }

    .approach-image img {
      width: 77%;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .approach-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .approach-heading {
        padding-right: 0;
        text-align: center;
      }

      .approach-heading h2 {
        display: inline;
      }

      .approach-arrow {
        position: relative;
        top: auto;
        right: auto;
        display: inline-flex;
        vertical-align: top;
        margin-left: 0.5rem;
      }

      .approach-image {
        margin-top: 1.5rem;
      }

      .approach-image img {
        width: 90%;
        display: block;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    const arrow = document.querySelector('.approach-arrow');
    if (arrow) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { arrow.classList.add('animate-in'); obs.disconnect(); } });
      }, { threshold: 0.5 });
      obs.observe(arrow);
    }
  </script>


  <!-- How it works: hydronic flow -->
  <section class="hydronic-basics-section">
    <div class="container">
      <p class="section-label">How It Works</p>
      <h2>From Heat Pump to Comfortable Home</h2>

      <svg width="0" height="0" style="position:absolute;">
        <defs>
          <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C0D446" />
            <stop offset="100%" stop-color="#2061B7" />
          </linearGradient>
        </defs>
      </svg>

      <div class="hydronic-basics-flow">
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={HeaterIcon} gradient="icon-gradient" />
          </div>
          <h3>Heat pump heats or cools water</h3>
          <p>An electric heat pump generates warm water for heating or chilled water for cooling, using roughly a third of the energy of a gas system.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={DropletIcon} gradient="icon-gradient" />
          </div>
          <h3>Water circulates through panels</h3>
          <p>Warm or chilled water flows through serpentine tubes inside ceiling-mounted panels via a low-voltage pump system.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={Sun01Icon} gradient="icon-gradient" />
          </div>
          <h3>Panels radiate into the room</h3>
          <p>The panels radiate warmth downward in winter or absorb heat upward in summer. No fans, no ducts, no noise.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={SmartPhone01Icon} gradient="icon-gradient" />
          </div>
          <h3>Sensors adjust automatically</h3>
          <p>Temperature sensors in each zone monitor conditions and adjust water flow to maintain your set point without you lifting a finger.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hydronic-basics-section {
      padding: 5rem 0;
      background: #f8f9fa;
    }

    .hydronic-basics-section .section-label,
    .hydronic-basics-section h2 {
      text-align: center;
    }

    .hydronic-basics-section h2 {
      margin-bottom: 3rem;
    }

    .hydronic-basics-flow {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0.75rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .basics-step {
      text-align: center;
      flex: 1;
      max-width: 200px;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .basics-arrow {
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    @keyframes arrow-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1.3); }
    }

    /* Everything flips in together */
    .hydronic-basics-flow.in-view .basics-step:nth-child(1) { transition-delay: 0s; transform: rotateY(0); opacity: 1; }
    .hydronic-basics-flow.in-view > :nth-child(2) { transition-delay: 0.15s; transform: rotateY(0); opacity: 1; }
    .hydronic-basics-flow.in-view .basics-step:nth-child(3) { transition-delay: 0.3s; transform: rotateY(0); opacity: 1; }
    .hydronic-basics-flow.in-view > :nth-child(4) { transition-delay: 0.45s; transform: rotateY(0); opacity: 1; }
    .hydronic-basics-flow.in-view .basics-step:nth-child(5) { transition-delay: 0.6s; transform: rotateY(0); opacity: 1; }
    .hydronic-basics-flow.in-view > :nth-child(6) { transition-delay: 0.75s; transform: rotateY(0); opacity: 1; }
    .hydronic-basics-flow.in-view .basics-step:nth-child(7) { transition-delay: 0.9s; transform: rotateY(0); opacity: 1; }

    /* Arrows pulse 1.5x after all flips finish */
    .hydronic-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse 0.35s ease 1.5s forwards; }
    .hydronic-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse 0.35s ease 1.65s forwards; }
    .hydronic-basics-flow.in-view > :nth-child(6) { animation: arrow-pulse 0.35s ease 1.8s forwards; }

    .basics-icon {
      width: 48px;
      height: 48px;
      margin: 0 auto 1rem;
    }

    .basics-icon :global(svg) {
      width: 100%;
      height: 100%;
    }

    .basics-step h3 {
      font-size: 0.95rem;
      color: #0E2B47;
      margin-bottom: 0.4rem;
    }

    .basics-step p {
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .basics-arrow {
      width: 28px;
      flex-shrink: 0;
      color: #2061B7;
      margin-top: 0.5rem;
    }

    .basics-arrow svg {
      width: 100%;
      height: auto;
    }

    @media (max-width: 768px) {
      .hydronic-basics-flow {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .basics-step {
        max-width: 300px;
      }

      .basics-arrow {
        transform: rotateY(180deg) rotate(90deg);
        width: 24px;
        margin: 0;
      }

      @keyframes arrow-pulse-mobile {
        0% { transform: rotate(90deg) scale(1); }
        50% { transform: rotate(90deg) scale(1.5); }
        100% { transform: rotate(90deg) scale(1.3); }
      }

      .hydronic-basics-flow.in-view > .basics-arrow { transform: rotateY(0) rotate(90deg); opacity: 1; }
      .hydronic-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse-mobile 0.35s ease 1.5s forwards; }
      .hydronic-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse-mobile 0.35s ease 1.65s forwards; }
      .hydronic-basics-flow.in-view > :nth-child(6) { animation: arrow-pulse-mobile 0.35s ease 1.8s forwards; }
    }
  </style>

  <script>
    const flow = document.querySelector('.hydronic-basics-flow');
    if (flow) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { flow.classList.add('in-view'); observer.disconnect(); } });
      }, { threshold: 0.3 });
      observer.observe(flow);
    }
  </script>


  <!-- Guarantees -->
  <section class="guarantees-section">
    <div class="guarantees-section__slant"></div>
    <div class="guarantees-section__texture"></div>
    <div class="container">
      <p class="section-label" style="text-align:center;">With Every Hydronic System</p>
      <h2 style="text-align:center; margin-bottom: 2.5rem;">Our Guarantees</h2>

      <div class="guarantees-grid">
        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">1/3</span>
            <span class="guarantee-tile__label">Running cost<br />vs ducted gas</span>
          </div>
        </div>

        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">0 dB</span>
            <span class="guarantee-tile__label">Silent<br />operation</span>
          </div>
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">10 year</span>
            <span class="guarantee-tile__label">Workmanship<br />warranty</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">~$0</span>
            <span class="guarantee-tile__label">Running cost<br />with solar</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .guarantees-section {
      position: relative;
      padding: 5rem 0 6rem;
      background: #f4f5f7;
      overflow: hidden;
    }

    .guarantees-section__slant {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: #eceef1;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
      z-index: 0;
    }

    .guarantees-section__texture {
      position: absolute;
      bottom: -500px;
      left: -100px;
      width: 1000px;
      height: 1000px;
      background: url('/image/textures/WhatWeDo_Texture.svg') no-repeat center / contain;
      transform: rotate(30deg);
      z-index: 0;
      pointer-events: none;
      opacity: 1;
    }

    .guarantees-section .container {
      position: relative;
      z-index: 1;
    }

    .guarantees-grid {
      display: flex;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .guarantee-tile {
      position: relative;
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 528 / 521;
      margin-right: -20px;
    }

    .guarantee-tile:last-child {
      margin-right: 0;
    }

    .guarantee-tile__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
    }

    .guarantee-tile__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 1.5rem;
    }

    .guarantee-tile__value {
      display: block;
      font-size: 2.25rem;
      font-weight: 800;
      color: #0E2B47;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .guarantee-tile__label {
      display: block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #0E2B47;
      line-height: 1.4;
    }

    .guarantee-tile__badge {
      position: absolute;
      bottom: -28px;
      left: 50%;
      transform: translateX(-50%);
      width: 72px;
      height: 72px;
      z-index: 2;
    }

    @media (max-width: 768px) {
      .guarantees-grid {
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .guarantee-tile {
        width: calc(50% - 0.75rem);
        flex-shrink: 0;
        margin-right: 0;
      }

      .guarantee-tile__value {
        font-size: 1.75rem;
      }

      .guarantee-tile__label {
        font-size: 0.85rem;
      }

      .guarantee-tile__badge {
        width: 56px;
        height: 56px;
        bottom: -18px;
        left: 50%;
        transform: translateX(-50%);
      }

      .guarantees-section__texture {
        width: 600px;
        height: 600px;
        bottom: -300px;
        left: -80px;
      }
    }
  </style>


  <!-- Comparison table -->
  <section class="conditioning-tiers-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="tiers-decoration" aria-hidden="true" />
    <div class="container">
      <div class="spec-cards-header">
        <p class="section-label">Heating Systems Compared</p>
        <h2>Why Hydronic Is Different</h2>
      </div>

      <div class="tier-comparison-table">
        <table>
          <thead>
            <!-- Card row -->
            <tr class="tier-card-row">
              <th></th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Gas Ducted Heating</h3>
                <p class="tier-desc">Blows heated air through ceiling ducts. Common in older homes but noisy, dusty, and increasingly expensive with rising gas prices.</p>
                <span class="tier-badge">Best for: Existing gas homes</span>
              </th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Reverse Cycle AC</h3>
                <p class="tier-desc">Electric split or ducted system that heats and cools by moving refrigerant. Efficient but creates draughts and uneven temperatures.</p>
                <span class="tier-badge">Best for: Budget retrofits</span>
              </th>
              <th class="tier-card-cell tier-card-cell--popular">
                <div class="tier-card-top-bar"></div>
                <div class="tier-popular-tag">Premium Comfort</div>
                <h3>Hydronic Radiant Panels</h3>
                <p class="tier-desc">Ceiling-mounted panels that radiate warmth or cooling silently from above. Powered by a heat pump and solar for near-zero running costs.</p>
                <span class="tier-badge">Best for: Premium comfort</span>
              </th>
            </tr>
            <!-- Column label row -->
            <tr class="tier-label-row">
              <th>Feature</th>
              <th>Gas Ducted Heating</th>
              <th>Reverse Cycle AC</th>
              <th>Hydronic Radiant Panels</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Running Cost</td>
              <td>High (gas + connection fee)</td>
              <td>Medium (electricity)</td>
              <td>Low (heat pump + solar)</td>
            </tr>
            <tr>
              <td>Noise Level</td>
              <td>Moderate (fan + ductwork)</td>
              <td>Moderate (compressor + fan)</td>
              <td>Silent (no moving parts)</td>
            </tr>
            <tr>
              <td>Air Quality</td>
              <td>Poor (circulates dust & allergens)</td>
              <td>Moderate (filters help)</td>
              <td>Excellent (no airflow)</td>
            </tr>
            <tr>
              <td>Temperature Evenness</td>
              <td>Poor (hot spots near vents, cold corners)</td>
              <td>Moderate (better with zoning)</td>
              <td>Excellent (even radiant distribution)</td>
            </tr>
            <tr>
              <td>Solar Compatible</td>
              <td>No (gas)</td>
              <td>Yes (runs on electricity)</td>
              <td>Yes (heat pump + solar)</td>
            </tr>
            <tr>
              <td>Maintenance</td>
              <td>High (duct cleaning, gas servicing)</td>
              <td>Medium (filter changes, refrigerant)</td>
              <td>Low (no filters, no ducts, no servicing)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile stacked cards (hidden on desktop) -->
      <div class="tier-mobile-cards">
        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Gas Ducted Heating</h3>
            <p>Blows heated air through ceiling ducts. Common in older homes but noisy, dusty, and increasingly expensive with rising gas prices.</p>
            <span class="tier-badge">Best for: Existing gas homes</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Running Cost</dt><dd>High (gas + connection fee)</dd></div>
            <div><dt>Noise Level</dt><dd>Moderate (fan + ductwork)</dd></div>
            <div><dt>Air Quality</dt><dd>Poor (circulates dust & allergens)</dd></div>
            <div><dt>Temperature Evenness</dt><dd>Poor (hot spots near vents, cold corners)</dd></div>
            <div><dt>Solar Compatible</dt><dd>No (gas)</dd></div>
            <div><dt>Maintenance</dt><dd>High (duct cleaning, gas servicing)</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Reverse Cycle AC</h3>
            <p>Electric split or ducted system that heats and cools by moving refrigerant. Efficient but creates draughts and uneven temperatures.</p>
            <span class="tier-badge">Best for: Budget retrofits</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Running Cost</dt><dd>Medium (electricity)</dd></div>
            <div><dt>Noise Level</dt><dd>Moderate (compressor + fan)</dd></div>
            <div><dt>Air Quality</dt><dd>Moderate (filters help)</dd></div>
            <div><dt>Temperature Evenness</dt><dd>Moderate (better with zoning)</dd></div>
            <div><dt>Solar Compatible</dt><dd>Yes (runs on electricity)</dd></div>
            <div><dt>Maintenance</dt><dd>Medium (filter changes, refrigerant)</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card tier-mobile-card--popular">
          <div class="tier-mobile-card__header">
            <div class="tier-popular-tag">Premium Comfort</div>
            <h3>Hydronic Radiant Panels</h3>
            <p>Ceiling-mounted panels that radiate warmth or cooling silently from above. Powered by a heat pump and solar for near-zero running costs.</p>
            <span class="tier-badge">Best for: Premium comfort</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Running Cost</dt><dd>Low (heat pump + solar)</dd></div>
            <div><dt>Noise Level</dt><dd>Silent (no moving parts)</dd></div>
            <div><dt>Air Quality</dt><dd>Excellent (no airflow)</dd></div>
            <div><dt>Temperature Evenness</dt><dd>Excellent (even radiant distribution)</dd></div>
            <div><dt>Solar Compatible</dt><dd>Yes (heat pump + solar)</dd></div>
