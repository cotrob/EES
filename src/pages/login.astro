---
const redirectTo = Astro.url.searchParams.get('redirect') || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Login | EES</title>
  </head>
  <body>
    <div class="login-page">
      <div class="login-card">
        <div class="login-icon">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" width="36" height="36">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
        </div>
        <h1>Site Access</h1>
        <p class="login-desc">Enter the password to continue.</p>

        <form id="login-form">
          <input type="hidden" name="redirect" value={redirectTo} />
          <label for="password" class="visually-hidden">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Enter password"
            required
            autocomplete="current-password"
          />
          <p id="login-error" class="login-error" aria-live="polite"></p>
          <button type="submit">
            Continue
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </button>
        </form>
      </div>
    </div>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const errorEl = document.getElementById('login-error') as HTMLElement;
      const btn = form.querySelector('button') as HTMLButtonElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorEl.textContent = '';
        btn.disabled = true;

        const formData = new FormData(form);
        const password = formData.get('password') as string;
        const redirect = formData.get('redirect') as string;

        try {
          const res = await fetch('/api/auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password, redirect }),
          });

          if (res.ok) {
            const data = await res.json();
            window.location.href = data.redirect || '/';
          } else {
            errorEl.textContent = 'Incorrect password. Please try again.';
            const input = document.getElementById('password') as HTMLInputElement;
            input.value = '';
            input.focus();
          }
        } catch {
          errorEl.textContent = 'Something went wrong. Please try again.';
        } finally {
          btn.disabled = false;
        }
      });
    </script>

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; }

      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        color: #333;
        background: #f5f7fa;
        -webkit-font-smoothing: antialiased;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .login-card {
        width: 100%;
        max-width: 420px;
        text-align: center;
        background: #fff;
        border-radius: 1.25rem;
        padding: 3rem 2.5rem;
        border: 1px solid #e5e7eb;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
      }

      .login-icon {
        width: 4.5rem;
        height: 4.5rem;
        margin: 0 auto 1.5rem;
        border-radius: 9999px;
        background: rgba(32, 97, 183, 0.1);
        border: 1px solid rgba(32, 97, 183, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2061B7;
      }

      h1 {
        font-size: 1.5rem;
        font-weight: 700;
        color: #0E2B47;
        margin-bottom: 0.5rem;
      }

      .login-desc {
        font-size: 0.9375rem;
        color: #666;
        margin-bottom: 1.75rem;
        line-height: 1.6;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      input[type="password"] {
        width: 100%;
        padding: 0.9375rem 1.25rem;
        font-size: 1rem;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        background: #fff;
        color: #0E2B47;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        text-align: center;
      }

      input[type="password"]:focus {
        border-color: #2061B7;
        box-shadow: 0 0 0 3px rgba(32, 97, 183, 0.1);
      }

      input[type="password"]::placeholder {
        color: #aaa;
      }

      button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.375rem;
        width: 100%;
        padding: 0.875rem 2rem;
        font-size: 1rem;
        font-weight: 500;
        border-radius: 9999px;
        border: none;
        background: #2061B7;
        color: #fff;
        cursor: pointer;
        transition: background 0.2s;
      }

      button:hover { background: #184A8B; }
      button:disabled { opacity: 0.6; cursor: not-allowed; }

      .login-error:empty { display: none; }

      .login-error {
        color: #dc2626;
        font-size: 0.875rem;
        padding: 0.5rem 1rem;
        background: rgba(220, 38, 38, 0.05);
        border-radius: 0.5rem;
        border: 1px solid rgba(220, 38, 38, 0.15);
      }
    </style>
  </body>
</html>
