---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import HugeIcon from '../../components/HugeIcon.astro';
import {
  Building03Icon,
  UniversityIcon,
  Hospital01Icon,
  Store01Icon,
  LandmarkIcon,
  Home01Icon,
} from '@hugeicons/core-free-icons';
---

<BaseLayout
  title="Hydronic Ceiling Panels | EES"
  description="Suspended hydronic ceiling tiles for radiant heating and cooling. Modular, efficient, and designed for standard Australian ceiling grids."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Hydronic Ceiling Panels</h1>
      <p>Heating, cooling, and a finished ceiling in one system.</p>
    </div>
  </section>

  <!-- What Are These -->
  <section class="intro-section">
    <div class="container">
      <div class="intro-layout">
        <div class="intro-text">
          <p class="section-label">What Are Hydronic Ceiling Panels?</p>
          <h2>A Complete Replacement for Conventional Heating and Cooling</h2>
          <p>Hydronic ceiling panels heat and cool your space using water circulated through tiles in your ceiling. They replace traditional systems like split units, ducted air conditioning, radiators, and gas heaters with a single, silent, invisible system.</p>
          <p>There are no wall-mounted units, no ductwork, no vents, and no fan noise. Just a clean ceiling that keeps every room comfortable year-round.</p>
        </div>
        <div class="intro-image">
          <img src="/image/WIP/TestRoom_Final_webp/639607_7582f9e8760f4b8c8deb96294d92f1c3_mv2_crop.webp" alt="3D render looking up at a suspended ceiling with hydronic panels finished in a variety of architectural surfaces including timber, rendered coating, perforated metal, and mini-orb" />
        </div>
      </div>
    </div>
  </section>

  <!-- Product Hero -->
  <section class="product-hero">
    <div class="container">
      <div class="hero-layout">
        <div class="hero-image">
          <img src="/image/WIP/TestRoom_Final_webp/639607_dee5110879914401aa781f84eeb92cdc_mv2.webp" alt="3D render of a hydronic ceiling panel showing the three layers: insulation barrier, capillary tube mat, and architectural finish surface" />
        </div>
        <div class="hero-text">
          <p class="section-label">The Technology</p>
          <h2>Three Functions in One Tile</h2>
          <p>Our suspended hydronic ceiling tiles are modular and versatile. They are capable of both heating and cooling and are designed to accept a range of finishing surfaces. Easy to install. Simple to operate.</p>
          <div class="three-layers">
            <div class="layer">
              <span class="layer-number">1</span>
              <div>
                <strong>Insulative Barrier</strong>
                <p>Directly opposite to where the conditioning occurs, keeping energy where it's needed.</p>
              </div>
            </div>
            <div class="layer">
              <span class="layer-number">2</span>
              <div>
                <strong>Capillary Tube Mat</strong>
                <p>A highly responsive conditioning system embedded within the tile itself.</p>
              </div>
            </div>
            <div class="layer">
              <span class="layer-number">3</span>
              <div>
                <strong>Architectural Finish</strong>
                <p>The room-facing surface. Choose the material that suits your interior.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Patent & Credentials -->
  <div class="patent-group">
    <div class="diagonal-divider" style="background: #fff;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#0E2B47" />
      </svg>
    </div>

    <section class="patent-section">
      <div class="container">
        <div class="patent-layout">
          <div class="patent-text">
            <p class="section-label section-label--light">Australian Patented Technology</p>
            <h2>Australian Standard Patent 2024227462</h2>
            <p><strong>A Reciprocating Panel for Capillary Hydronic Mats</strong>, granted 24 July 2025 with a 20-year term. This panel design is the result of years of research, prototyping, and real-world testing at our Geelong facility.</p>
            <p>The patent covers the panel's unique layered construction: the combination of rigid insulation, capillary tube mat, and aluminium reflector sheet that gives the system its performance advantages.</p>
            <div class="patent-details">
              <div class="patent-detail">
                <span class="patent-detail-label">Patent No.</span>
                <span class="patent-detail-value">2024227462</span>
              </div>
              <div class="patent-detail">
                <span class="patent-detail-label">Granted</span>
                <span class="patent-detail-value">24 July 2025</span>
              </div>
              <div class="patent-detail">
                <span class="patent-detail-label">Term</span>
                <span class="patent-detail-value">20 Years</span>
              </div>
              <div class="patent-detail">
                <span class="patent-detail-label">Jurisdiction</span>
                <span class="patent-detail-value">Australia</span>
              </div>
            </div>
          </div>
          <div class="patent-badge">
            <div class="patent-badge-inner">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="patent-icon">
                <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
              </svg>
              <span class="patent-badge-title">Australian Standard Patent</span>
              <span class="patent-badge-number">2024227462</span>
              <span class="patent-badge-sub">Granted July 2025</span>
              <a href="/documents/patent-2024227462.pdf" download class="patent-download-btn">Download Patent PDF</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="diagonal-divider" style="background: #0E2B47;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#fff" />
      </svg>
    </div>
  </div>

  <!-- Panel Close-Ups -->
  <section class="section panel-closeups">
    <div class="container">
      <div class="closeup-grid">
        <div class="closeup-card">
          <img src="/image/WIP/TestRoom_Development_webp/IMG_7483.webp" alt="Blue polypropylene capillary tube mat bonded to foil-faced insulation panel, the active conditioning layer of each tile" />
          <div class="closeup-text">
            <h3>The Capillary Tube Mat</h3>
            <p>Polypropylene tubes at tight spacing bonded directly to the insulation. Water circulates through these tubes to heat or cool the panel surface uniformly with no hot or cold spots.</p>
          </div>
        </div>
        <div class="closeup-card">
          <img src="/image/WIP/TestRoom_Final_webp/IMG_0030.webp" alt="Rear view of a completed hydronic ceiling panel showing capillary tubes bonded to foil insulation with connecting hoses" />
          <div class="closeup-text">
            <h3>Panel Assembly</h3>
            <p>Each 600 × 1200mm tile is assembled in-house. Capillary mat bonded to insulation, pressure tested, then fitted with the chosen architectural finish before delivery.</p>
          </div>
        </div>
        <div class="closeup-card">
          <img src="/image/WIP/TestRoom_Final_webp/IMG_0041.webp" alt="Finished face of a hydronic ceiling panel with perforated metal surface showing clean architectural appearance that conceals the system" />
          <div class="closeup-text">
            <h3>The Finished Face</h3>
            <p>From the room below, all you see is a clean ceiling tile. The conditioning system is completely concealed and invisible to occupants.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Ceiling? -->
  <div class="why-ceiling-group">
    <div class="diagonal-divider" style="background: #fff;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#0E2B47" />
      </svg>
    </div>

    <section class="why-ceiling">
      <div class="container">
        <div class="why-layout">
          <div class="why-text">
            <p class="section-label section-label--light">Why the Ceiling?</p>
            <h2>The Most Effective Radiant Surface</h2>
            <p>The human body exchanges energy with its environment through three mechanisms: <strong>radiation</strong>, <strong>convection</strong>, and <strong>exhalation</strong>. Radiant transfer has the greatest impact on comfort.</p>
            <p>Radiant systems deliver both radiant and convective energy transfer simultaneously. They are healthier, more comfortable, and operate at roughly <strong>one-third the cost</strong> of conventional systems.</p>
            <div class="why-points">
              <div class="why-point">
                <svg viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Uninterrupted surface</strong> with no furniture or foot traffic in the way</span>
              </div>
              <div class="why-point">
                <svg viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Doesn't activate dust</strong> that accumulates on floors</span>
              </div>
              <div class="why-point">
                <svg viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>Far more <strong>hygienic</strong> than floor conditioning or forced-air systems</span>
              </div>
              <div class="why-point">
                <svg viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span><strong>Uniform MRT</strong> across the occupied zone at any distance</span>
              </div>
            </div>
          </div>
          <div class="why-image">
            <img src="/image/WIP/TestRoom_Development_webp/mounting.webp" alt="Comparison diagram of four radiant conditioning approaches: floor heating (A), ceiling heating and cooling (B and D), and wall heating (C) showing coverage, distance uniformity, and furniture obstruction" />
            <img src="/image/WIP/Hydronic_Ceiling_Panels/panel-radiant-comfort-diagram.webp" alt="Diagram showing radiant heat exchange between room surfaces and the human body, illustrating how ceiling, wall and floor panels interact with the occupant" class="why-image-secondary" />
          </div>
        </div>
      </div>
    </section>

    <div class="diagonal-divider" style="background: #0E2B47;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#fff" />
      </svg>
    </div>
  </div>

  <!-- Key Advantages -->
  <section class="section advantages-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Performance Advantages</p>
        <h2>Why This Panel <span class="h2-light">Is Different</span></h2>
        <p class="section-desc">Designed, patented, and manufactured in Geelong. Tested against the leading radiant ceiling systems on the market.</p>
      </div>

      <div class="advantages-grid">
        <div class="advantage-card advantage-card--highlight">
          <span class="advantage-stat">30–50%</span>
          <h3>Lower Cost</h3>
          <p>Priced significantly below competing radiant ceiling systems, without compromising performance or build quality.</p>
        </div>
        <div class="advantage-card advantage-card--highlight">
          <span class="advantage-stat">20–100%</span>
          <h3>More Capacity</h3>
          <p>Delivers substantially higher thermal output than competitive systems, accommodating a wider range of space and load requirements.</p>
        </div>
        <div class="advantage-card">
          <span class="advantage-stat">>95%</span>
          <h3>System Output Retained</h3>
          <p>Minimal heat transfer losses. The rigid insulation barrier keeps energy directed into the occupied space, not into the ceiling void.</p>
        </div>
        <div class="advantage-card">
          <span class="advantage-stat">50–90%</span>
          <h3>Radiative Transfer</h3>
          <p>Achieves 50–90% radiative and 10–50% convective heat transfer, the ideal balance for occupant comfort and energy efficiency.</p>
        </div>
        <div class="advantage-card">
          <h3>Dual Heating &amp; Cooling</h3>
          <p>One system provides year-round climate control. No separate heating and cooling infrastructure required, reducing complexity and cost.</p>
        </div>
        <div class="advantage-card">
          <h3>Fast Response, Dynamic Control</h3>
          <p>Adjusts quickly to changing thermal loads using an intelligent comfort model, not a conventional thermostat. Maintains consistent conditions without overshooting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ceiling Surface Options -->
  <section class="section surface-options">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Finishing Surfaces</p>
        <h2>One System, <span class="h2-light">Many Finishes</span></h2>
        <p class="section-desc">The same hydronic capillary tube system accepts a range of architectural finishes. Choose the surface that suits your space.</p>
      </div>

      <div class="surface-showcase">
        <img src="/image/WIP/TestRoom_Development_webp/ceiling-panels-labeled.webp" alt="TestCell ceiling divided into bays with five different architectural finishes: adhesive vinyl coated wallpaper, rendered coating, perforated metal panel, mini-orb, and plasterboard with vinyl finish" />
      </div>

      <div class="surface-grid">
        <div class="surface-card">
          <h3>Perforated Metal</h3>
          <p>Clean, modern appearance with excellent radiant transfer. Suitable for commercial and architectural applications.</p>
        </div>
        <div class="surface-card">
          <h3>Plasterboard with Vinyl</h3>
          <p>Standard ceiling appearance. Blends seamlessly with conventional suspended ceilings, ideal for retrofits.</p>
        </div>
        <div class="surface-card">
          <h3>Rendered Coating</h3>
          <p>Textured, solid finish. Good acoustic properties and a premium architectural look.</p>
        </div>
        <div class="surface-card">
          <h3>Mini-Orb</h3>
          <p>Corrugated metal profile. Industrial aesthetic with good structural rigidity and airflow characteristics.</p>
        </div>
        <div class="surface-card">
          <h3>Vinyl Coated Wallpaper</h3>
          <p>Adhesive-applied finish. Lightweight, cost-effective, and available in a wide range of colours and textures.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Installed Ceiling -->
  <section class="section installed-section">
    <div class="container">
      <div class="installed-layout">
        <div class="installed-image">
          <img src="/image/WIP/TestRoom_Development_webp/IMG_7977.webp" alt="Looking up at the installed hydronic ceiling panels from inside the TestCell with blue capillary tubes visible through the grid before finishing surfaces are applied" />
          <img src="/image/WIP/Hydronic_Ceiling_Panels/panel-perforated-surface-product.webp" alt="Finished hydronic ceiling panel viewed from below showing the white perforated metal surface that conceals the capillary tube system" class="installed-image-secondary" />
        </div>
        <div class="installed-text">
          <p class="section-label">Installation</p>
          <h2>Standard Grid, Simple Install</h2>
          <p>Each panel is sized at <strong>600 × 1200mm</strong> to fit standard Australian suspended ceiling grids. Panels drop in like conventional ceiling tiles. No specialist tools, no custom framing.</p>
          <p>Water connections between panels use quick-connect fittings. A single manifold feeds all panels in a zone, with individual flow meters for balancing and monitoring.</p>
          <p>The modular design means panels can be removed individually for maintenance or access to services above, without disturbing the rest of the ceiling.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Thermal Performance -->
  <section class="section thermal-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Proven Performance</p>
        <h2>Thermal Imaging <span class="h2-light">Results</span></h2>
        <p class="section-desc">Tested in our purpose-built simulation room. Thermal imaging confirms uniform surface temperature distribution in both heating and cooling modes.</p>
      </div>

      <div class="thermal-comparison">
        <div class="thermal-card">
          <div class="thermal-img-wrap">
            <img src="/image/WIP/TestRoom_Development_webp/thermal-heating-full.webp" alt="Thermal image of ceiling panels in heating mode showing uniform warm surface temperatures at 27.6°C in red and orange" />
          </div>
          <div class="thermal-info">
            <span class="thermal-mode thermal-mode--heat">Heating Mode 27.6°C</span>
            <p>Even red/orange distribution confirms uniform heat delivery across all panel surfaces. No cold spots at joints or edges.</p>
          </div>
        </div>
        <div class="thermal-card">
          <div class="thermal-img-wrap">
            <img src="/image/WIP/TestRoom_Development_webp/thermal-cooling-full.webp" alt="Thermal image of ceiling panels in cooling mode showing uniform cool surface temperatures at 14.4°C in blue and green" />
          </div>
          <div class="thermal-info">
            <span class="thermal-mode thermal-mode--cool">Cooling Mode 14.4°C</span>
            <p>Blue thermal signature shows effective, uniform cooling across all panels. No warm spots or condensation risk at these operating temperatures.</p>
          </div>
        </div>
      </div>

      <div class="thermal-data">
        <div class="thermal-data-card">
          <div class="thermal-img-wrap">
            <img src="/image/WIP/Hydronic_Ceiling_Panels/panel-test-heat-flux-graph.webp" alt="Heat flux test data showing four sensors reaching 75-100 W/m² steady state output across different panel zones" />
          </div>
          <div class="thermal-info">
            <span class="thermal-mode thermal-mode--data">Heat Flux (W/m²)</span>
            <p>Each coloured line is a sensor on a different part of the panel. They all climb quickly from zero and flatten out, meaning the panels reach full heating output within about 30 minutes and hold it steady. In practice, this means the room reaches a comfortable temperature quickly and stays there without fluctuations.</p>
            <h4 class="thermal-technical-heading">Technical Explanation</h4>
            <p class="thermal-technical">Four calibrated heat flux sensors (FLUX 1-4) positioned across different panel zones record steady-state radiative and convective output of 75-100 W/m². The dashed TC lines represent corresponding thermocouple readings tracking surface temperature at each sensor location. Time to 90% steady state is approximately 20 minutes, with less than 5% variance between zones at plateau, confirming uniform energy distribution across the capillary tube mat.</p>
          </div>
        </div>
        <div class="thermal-data-card">
          <div class="thermal-img-wrap">
            <img src="/image/WIP/Hydronic_Ceiling_Panels/panel-test-surface-temp-graph.webp" alt="Surface temperature graph showing four panel zones cooling to 20-25°C while ambient temperature rises to 32°C" />
          </div>
          <div class="thermal-info">
            <span class="thermal-mode thermal-mode--data">Surface Temperature (°C)</span>
            <p>The thick red line is the outside air temperature rising past 32°C. The other coloured lines are sensors on different panels, all dropping quickly and staying between 20-25°C. The panels keep the surface cool even as the day gets hotter.</p>
            <h4 class="thermal-technical-heading">Technical Explanation</h4>
            <p class="thermal-technical">Four thermocouples (TEMP 1-4) measure panel surface temperature during active cooling with a chilled water supply temperature of approximately 16°C. Ambient temperature (red) rises from 26.5°C to 32.5°C over the two-hour test window. Panel surfaces stabilise between 20-25°C within 15 minutes, maintaining a 6-12°C differential below ambient. The spread between sensors reflects variation in finishing surface thermal conductivity across the test panels.</p>
          </div>
        </div>
      </div>

      <div class="thermal-link">
        <p>Full testing methodology and instrumentation details are available on our <a href="/laboratory/test-room">Simulation Test Room</a> page.</p>
      </div>
    </div>
  </section>

  <!-- System Components -->
  <section class="section components-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">System Architecture</p>
        <h2>How It <span class="h2-light">All Connects</span></h2>
        <p class="section-desc">The hydronic system uses modular, low-voltage components. A heat pump circulates temperature-controlled water through the ceiling panels via a central manifold.</p>
      </div>

      <div class="system-hero">
        <img src="/image/WIP/TestRoom_Final_webp/test-hydronic-2-230616.webp" alt="3D isometric view of the complete hydronic ceiling system showing ceiling panels with hot and cold piping loops, mixing station, and equipment cabinet" />
      </div>

      <div class="components-grid">
        <div class="component-card">
          <img src="/image/WIP/TestRoom_Development_webp/diagram.webp" alt="System schematic showing heat pump, water tank, pressure tank, vacuum relief valve, circulation pump and capillary tube mat connections" />
          <div class="component-text">
            <h3>System Schematic</h3>
            <p>Heat pump drives water through the heat exchanger into the capillary tube mats via the circulation pump. Pressure tanks and vacuum relief valves ensure stable, safe operation.</p>
          </div>
        </div>
        <div class="component-card">
          <img src="/image/WIP/TestRoom_Development_webp/plumbing-full.webp" alt="Assembled hydronic plumbing manifold with 24V DC pumps, switching actuators, mixing valves and pressure tanks" />
          <div class="component-text">
            <h3>Hydraulic Manifold</h3>
            <p>PPR piping with brass fittings. Each circuit has its own flow meter and switching actuator for zone-by-zone control. All components run on 24V DC for safety.</p>
          </div>
        </div>
        <div class="component-card">
          <img src="/image/WIP/TestRoom_Development_webp/IMG_6357.webp" alt="Close-up of the hydronic manifold showing individual circuit flow meters, isolation valves and pipe connections" />
          <div class="component-text">
            <h3>Flow Control</h3>
            <p>Individual flow meters on each circuit allow precise monitoring and balancing. The system can be tuned panel-by-panel to match the thermal load of each zone.</p>
          </div>
        </div>
      </div>

      <div class="specs-bar">
        <div class="spec-item">
          <span class="spec-value">40–85W</span>
          <span class="spec-name">Circulation Pumps</span>
          <span class="spec-detail">Variable speed, 24V DC. Each serves 20–40m²</span>
        </div>
        <div class="spec-item">
          <span class="spec-value">24V DC</span>
          <span class="spec-name">Switching Actuators</span>
          <span class="spec-detail">For hot and cold tank selection</span>
        </div>
        <div class="spec-item">
          <span class="spec-value">600 × 1200mm</span>
          <span class="spec-name">Panel Size</span>
          <span class="spec-detail">Fits standard Australian suspended ceiling grids</span>
        </div>
        <div class="spec-item">
          <span class="spec-value">PPR</span>
          <span class="spec-name">Piping</span>
          <span class="spec-detail">With brass fittings. Modular and serviceable</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Heat Pump Integration -->
  <section class="section heatpump-section">
    <div class="container">
      <div class="heatpump-layout">
        <div class="heatpump-text">
          <p class="section-label">System Integration</p>
          <h2>Powered by Heat Pumps</h2>
          <p>The hydronic panels use heated and chilled water from a heat pump, an efficient, renewable-energy-driven appliance that replaces gas boilers and conventional air conditioning in one unit.</p>
          <p>Heat pumps produce <strong>3–5 times more energy than they consume</strong>, making this system one of the most efficient ways to condition a building. Combined with solar PV, the running cost approaches zero.</p>
          <p>If you're replacing a gas boiler or aging ducted system, hydronic ceiling panels paired with a heat pump are the modern alternative. Lower running costs, better comfort, and no gas connection required.</p>
        </div>
        <div class="heatpump-stats">
          <div class="heatpump-stat">
            <span class="heatpump-stat-value">3–5x</span>
            <span class="heatpump-stat-label">More efficient than gas</span>
          </div>
          <div class="heatpump-stat">
            <span class="heatpump-stat-value">~67%</span>
            <span class="heatpump-stat-label">Less on your energy bill</span>
          </div>
          <div class="heatpump-stat">
            <span class="heatpump-stat-value">0</span>
            <span class="heatpump-stat-label">Gas connection required</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Applications -->
  <section class="section applications-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Applications</p>
        <h2>Where These Panels <span class="h2-light">Are Used</span></h2>
        <p class="section-desc">Designed primarily for suspended ceiling retrofits in commercial and institutional buildings, anywhere a standard ceiling grid exists.</p>
      </div>

      <div class="applications-grid">
        <div class="application-card">
          <HugeIcon icon={Building03Icon} size={32} class="application-icon" />
          <h3>Offices &amp; Workplaces</h3>
          <p>Silent, draught-free conditioning. No wall units, no ductwork, no ceiling space lost to bulky equipment.</p>
        </div>
        <div class="application-card">
          <HugeIcon icon={UniversityIcon} size={32} class="application-icon" />
          <h3>Schools &amp; Universities</h3>
          <p>Healthier indoor air with no dust circulation or dry forced-air. Ideal for classrooms and lecture halls with suspended ceilings.</p>
        </div>
        <div class="application-card">
          <HugeIcon icon={Hospital01Icon} size={32} class="application-icon" />
          <h3>Healthcare Facilities</h3>
          <p>Hygienic radiant conditioning with no moving air. Reduces airborne particle circulation, critical for hospitals and aged care.</p>
        </div>
        <div class="application-card">
