---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
---

<BaseLayout
  title="Academic Research | EES"
  description="Peer-reviewed research papers on radiant conditioning, thermal comfort, heat pumps, and renewable energy from the EES research team."
>
  <section class="page-header">
    <div class="container">
      <h1>Academic Research</h1>
      <p>Peer-reviewed papers from our research into radiant conditioning, thermal comfort, and renewable energy systems.</p>
    </div>
  </section>

  <section class="section papers-section">
    <div class="container">
      <div class="papers-list">

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Experimental-evaluation-radiant-ceiling-panels-office-perimeter-01.png" alt="First page of Experimental Evaluation of Radiant Ceiling Panels paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Energy and Buildings, 2025</span>
            <h2>Experimental Evaluation of Radiant Ceiling Panels in Office Building Perimeter Zones</h2>
            <span class="paper-authors">Hung Q. Do, Mark B. Luther, Jane Matthews, Igor Martek</span>
            <p>Evaluates the thermal performance and comfort outcomes of radiant ceiling panels installed in perimeter zones of an office building under real operating conditions.</p>
            <div class="paper-actions">
              <a href="https://doi.org/10.1016/j.enbuild.2025.116531" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Residential-space-heating-electrification-PV-heat-pump-01.png" alt="First page of Residential Space Heating Electrification paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Energy and Buildings, 2025</span>
            <h2>Residential Space Heating Electrification Through a PV-Driven Hot Water Heat Pump</h2>
            <span class="paper-authors">Zheng Wang, Mark Luther, Peter Horan, Jane Matthews, Chunlu Liu</span>
            <p>Investigates the electrification of residential space heating using a photovoltaic-driven hot water heat pump system, analysing energy performance and carbon reduction potential.</p>
            <div class="paper-actions">
              <a href="https://doi.org/10.1016/j.enbuild.2025.115319" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/The-Third-Skin-Biomimetic-Hydronic-Conditioning-01.png" alt="First page of The Third Skin paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Biomimetics, 2025</span>
            <h2>The Third Skin: A Biomimetic Hydronic Conditioning System, a New Direction in Ecologically Sustainable Design</h2>
            <span class="paper-authors">Mark B. Luther, Richard Hyde, Arosha Gamage, Hung Q. Do</span>
            <p>Presents a biomimetic approach to building conditioning inspired by natural thermoregulation, proposing hydronic radiant systems as a sustainable alternative to conventional HVAC.</p>
            <div class="paper-actions">
              <a href="https://doi.org/10.3390/biomimetics10120843" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Radiant-Ceiling-Panels-An-Evaluation-of-Thermal-Performance-01.png" alt="First page of Radiant Ceiling Panels paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Energy and Buildings, 2025</span>
            <h2>Radiant Ceiling Panels: An Evaluation of Thermal Performance</h2>
            <span class="paper-authors">Hung Q. Do, Mark B. Luther, Jane Matthews, Igor Martek, Peter Horan</span>
            <p>Tests prefabricated, modular hydronic panel design variants and shows how small changes in construction methods can notably increase thermal capacity and reduce response time.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Radiant-Ceiling-Panels-An-Evaluation-of-Thermal-Performance.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.sciencedirect.com/science/article/pii/S0378778825006966" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Renewable-Energy-Wang-01.png" alt="First page of Renewable Energy paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Renewable Energy, 2025</span>
            <h2>Technical and Economic Analyses of Grid-Connected Residential PV Considering Batteries and Peer-to-Peer Energy Sharing</h2>
            <span class="paper-authors">Zheng Wang, Mark Luther, Peter Horan, Jane Matthews, Chunlu Liu</span>
            <p>Evaluates grid-connected residential solar PV with battery storage and peer-to-peer energy trading, analysing the economic viability and energy self-sufficiency potential.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Renewable-Energy-Wang.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.sciencedirect.com/science/article/pii/S0960148125011565" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Development-and-thermal-performance-testing-of-radiant-conditioning-ceiling-panels-01.png" alt="First page of Development and Thermal Performance Testing paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Architectural Science Review, 2024</span>
            <h2>Development and Thermal Performance Testing of Radiant Conditioning Ceiling Panels</h2>
            <span class="paper-authors">Hung Q. Do, Jane Matthews, Mark B. Luther, Igor Martek, Peter Horan</span>
            <p>Documents the advancement from heavyweight radiant floors to lightweight ceiling systems and presents comprehensive thermal performance data to inform designers and engineers.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Development-and-thermal-performance-testing-of-radiant-conditioning-ceiling-panels.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.tandfonline.com/doi/full/10.1080/00038628.2024.2381715" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/J-of-Building-Eng-Wang-01.png" alt="First page of Journal of Building Engineering paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Journal of Building Engineering, 2024</span>
            <h2>Performance Investigation of Transitioning Building Services System in Photovoltaic Homes</h2>
            <span class="paper-authors">Zheng Wang, Mark Luther, Peter Horan, Jane Matthews, Chunlu Liu</span>
            <p>Investigates how building services in residential homes can transition to photovoltaic-powered systems, analysing real-world performance data from an instrumented test house.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/J-of-Building-Eng-Wang.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.sciencedirect.com/science/article/pii/S2352710224001086" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Solar-Energy-Wang-01.png" alt="First page of Solar Energy paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Solar Energy, 2024</span>
            <h2>Technical and Economic Analyses of PV Battery Systems Considering Two Different Tariff Policies</h2>
            <span class="paper-authors">Zheng Wang, Mark Luther, Peter Horan, Jane Matthews, Chunlu Liu</span>
            <p>Compares the technical and economic performance of residential PV battery systems under two different electricity tariff structures to identify optimal sizing and payback periods.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Solar-Energy-Wang.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.sciencedirect.com/science/article/pii/S0038092X2300823X" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/On-site-solar-PV-generation-self-consumption-01.png" alt="First page of On-Site Solar PV paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Building Simulation, 2023</span>
            <h2>On-Site Solar PV Generation and Use: Self-Consumption and Self-Sufficiency</h2>
            <span class="paper-authors">Zheng Wang, Mark B. Luther, Peter Horan, Jane Matthews, Chunlu Liu</span>
            <p>Analyses patterns of on-site solar PV generation and household consumption to quantify self-consumption and self-sufficiency ratios under different system configurations.</p>
            <div class="paper-actions">
              <a href="https://doi.org/10.1007/s12273-023-1007-3" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Development-and-performance-testing-of-a-polyvalent-heat-pump-01.png" alt="First page of Polyvalent Heat Pump paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Architectural Science Review, 2023</span>
            <h2>Development and Performance Testing of a Polyvalent Heat Pump for Hot and Cold Water Production</h2>
            <span class="paper-authors">Zheng Wang, Mark B. Luther, Antonis Siamas, Jane Matthews, Chunlu Liu</span>
            <p>Investigates a solar PV-driven polyvalent heat pump that simultaneously produces hot and cold water using natural refrigerants, achieving a COP of 3.8 in simultaneous mode.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Development-and-performance-testing-of-a-polyvalent-heat-pump.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.tandfonline.com/doi/full/10.1080/00038628.2023.2273836" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Radiant-conditioning-retrofitting-for-residential-buildings-01.png" alt="First page of Radiant Conditioning Retrofitting paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Energies, 2022</span>
            <h2>Radiant Conditioning Retrofitting for Residential Buildings</h2>
            <span class="paper-authors">Hung Q. Do, Mark B. Luther, Mehdi Amirkhani, Zheng Wang, Igor Martek</span>
            <p>Examines how capillary tube mats and lightweight radiant panels can retrofit existing homes for heating and cooling, replacing conventional systems with a total thickness of just 40-50 mm.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Radiant-conditioning-retrofitting-for-residential-buildings.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.mdpi.com/1996-1073/15/2/449" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/State-of-the-art-heat-pumps-residential-01.png" alt="First page of State of the Art Heat Pumps paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Buildings, 2021</span>
            <h2>State of the Art on Heat Pumps for Residential Buildings</h2>
            <span class="paper-authors">Zheng Wang, Mark B. Luther, Mehdi Amirkhani, Chunlu Liu, Peter Horan</span>
            <p>Reviews current heat pump technologies for residential applications, covering system types, performance metrics, integration with renewable energy, and future research directions.</p>
            <div class="paper-actions">
              <a href="https://doi.org/10.3390/buildings11080350" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

        <div class="paper-card">
          <div class="paper-thumb">
            <img src="/image/research_pdfs/thumbnails/Applying-a-comfort-model-to-building-performance-analysis-01.png" alt="First page of Applying a Comfort Model paper" loading="lazy" />
          </div>
          <div class="paper-body">
            <span class="paper-journal">Architectural Science Review, 2020</span>
            <h2>Applying a Comfort Model to Building Performance Analysis</h2>
            <span class="paper-authors">Mark Luther, Olubukola Tokede, Chunlu Liu</span>
            <p>Presents a measurement and analytical process for examining and commissioning cooling systems for thermal comfort, with field studies in Australian residential and office environments.</p>
            <div class="paper-actions">
              <a href="/image/research_pdfs/Applying-a-comfort-model-to-building-performance-analysis.pdf" download class="paper-btn paper-btn--download">Download PDF</a>
              <a href="https://www.tandfonline.com/doi/full/10.1080/00038628.2020.1742645" target="_blank" rel="noopener noreferrer" class="paper-btn paper-btn--link">View Article</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>

<style>
  .papers-section {
    background: #fff;
    padding: 4rem 0;
  }

  .papers-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .paper-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem;
    background: #f8f9fa;
    border-radius: 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
    align-items: stretch;
  }

  .paper-thumb {
    flex-shrink: 0;
    width: 80px;
    border-radius: 0.4rem;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #fff;
  }

  .paper-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .paper-body {
    flex: 1;
    min-width: 0;
  }

  .paper-journal {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #2061B7;
    margin-bottom: 0.4rem;
  }

  .paper-card h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0E2B47;
    line-height: 1.35;
    margin-bottom: 0.4rem;
  }

  .paper-authors {
    display: block;
    font-size: 0.8rem;
    color: #777;
    font-style: italic;
    margin-bottom: 0.4rem;
    line-height: 1.4;
  }

  .paper-body > p {
    font-size: 0.875rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  .paper-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .paper-btn {
    display: inline-block;
    padding: 0.45rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 0.35rem;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .paper-btn--download {
    color: #fff;
    background: #0E2B47;
  }

  .paper-btn--download:hover {
    background: #163a5c;
  }

  .paper-btn--link {
    color: #2061B7;
    background: rgba(32, 97, 183, 0.08);
    border: 1px solid rgba(32, 97, 183, 0.2);
  }

  .paper-btn--link:hover {
    background: #2061B7;
    color: #fff;
  }

  @media (max-width: 600px) {
    .paper-card {
      flex-direction: column;
      gap: 1rem;
      padding: 1.25rem;
    }

    .paper-thumb {
      width: 60px;
    }

    .paper-actions {
      flex-direction: column;
    }

    .paper-btn {
      text-align: center;
    }
  }
</style>
