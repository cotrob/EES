<script>
  // Click-to-stick: clicking a card keeps overlay visible until another card is clicked,
  // clicking elsewhere on the page, or after 3.5s timeout
  (() => {
    let activeItem: HTMLElement | null = null;
    let timeout: ReturnType<typeof setTimeout> | null = null;

    function clearActive() {
      if (activeItem) {
        activeItem.classList.remove('is-active');
        activeItem = null;
      }
      if (timeout) {
        clearTimeout(timeout);
        timeout = null;
      }
    }

    document.querySelectorAll('.bento-item').forEach((item) => {
      item.addEventListener('click', (e) => {
        e.stopPropagation();
        const el = item as HTMLElement;
        if (el === activeItem) {
          clearActive();
          return;
        }
        clearActive();
        el.classList.add('is-active');
        activeItem = el;
        timeout = setTimeout(clearActive, 3500);
      });
    });

    document.addEventListener('click', clearActive);
  })();

  const moreToggle = document.getElementById('more-examples-toggle');
  const bentoExtra = document.getElementById('bento-extra');
  if (moreToggle && bentoExtra) {
    moreToggle.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = bentoExtra.classList.toggle('is-visible');
      moreToggle.classList.toggle('is-open', isOpen);
      const label = moreToggle.childNodes[0] as Text;
      label.textContent = isOpen ? 'Show Less ' : 'Show More ';
    });
  }
</script>
