---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import BentoMini from '../../../components/sections/BentoMini.astro';
import ProcessTimeline from '../../../components/sections/ProcessTimeline.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import IconFeatureGrid from '../../../components/sections/IconFeatureGrid.astro';
import FaqGroup from '../../../components/sections/FaqGroup.astro';
import ServiceHero from '../../../components/sections/ServiceHero.astro';
import HugeIcon from '../../../components/HugeIcon.astro';
import Sun01Icon from '@hugeicons/core-free-icons/Sun01Icon';
import ZapIcon from '@hugeicons/core-free-icons/ZapIcon';
import Home01Icon from '@hugeicons/core-free-icons/Home01Icon';
import BatteryFullIcon from '@hugeicons/core-free-icons/BatteryFullIcon';
import ArrowRight01Icon from '@hugeicons/core-free-icons/ArrowRight01Icon';
import ArrowDownRight01Icon from '@hugeicons/core-free-icons/ArrowDownRight01Icon';
import CallIcon from '@hugeicons/core-free-icons/CallIcon';
import Search01Icon from '@hugeicons/core-free-icons/Search01Icon';
import CompassIcon from '@hugeicons/core-free-icons/CompassIcon';
import ClipboardIcon from '@hugeicons/core-free-icons/ClipboardIcon';
import CheckmarkBadge01Icon from '@hugeicons/core-free-icons/CheckmarkBadge01Icon';
import SmartPhone01Icon from '@hugeicons/core-free-icons/SmartPhone01Icon';
import Certificate01Icon from '@hugeicons/core-free-icons/Certificate01Icon';
---

<BaseLayout
  title="Residential Solar Panels Geelong & Torquay | Installation | EES"
  description="Expert residential solar panel installation in Geelong, Torquay and the Surf Coast. CEC accredited, designed for your home, backed by a 10-year workmanship warranty."
>
  <ServiceHero
    title="Residential Solar Systems"
    illustration="/image/illustrations/Residential  Solar Systems.png"
    illustrationAlt="Residential solar panel installation illustration"
  />


  <!-- Intro: Our approach -->
  <section class="approach-section">
    <div class="container">
      <div class="approach-layout">
        <div class="approach-heading">
          <p class="section-label">Our Approach</p>
          <h2>We Start With<br />Your Life, Not<br />Your Roof</h2>
          <div class="approach-arrow">
            <HugeIcon icon={ArrowDownRight01Icon} />
          </div>
        </div>
        <div class="approach-text">
          <p>
            Before we look at your roof or talk about panels, we want to <strong>understand how you live</strong>. How much power are you using during the day? Are you home or at work? Are you planning to get an electric vehicle, an induction cooktop, or a heat pump in the next few years? Are you retiring soon and going to be home more?
          </p>
          <p>
            All of this matters because a solar system should be <strong>designed around your actual consumption</strong> and where it's heading, not a generic template. We never oversize a system to sell you more panels, and we never design for winter production because that doesn't reflect how your system will perform most of the year.
          </p>
          <div class="approach-image">
            <img src="/image/illustrations/service_residential_solarasystem_section_lifefirstV1.png" alt="EES residential solar installation on a home in Geelong" loading="lazy" />
          </div>
          <p>
            The goal is simple: <strong>cover your own usage first</strong>. Not to send power back to the grid for a measly one cent per kilowatt hour. To power your home.
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .approach-section {
      padding: 8rem 0 4rem;
      background: #fff;
    }

    .approach-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: start;
      max-width: 1000px;
      margin: 0 auto;
    }

    .approach-heading {
      position: relative;
      padding-right: 80px;
      text-align: right;
    }

    .approach-heading h2 {
      margin-bottom: 0;
    }

    .approach-arrow {
      position: absolute;
      top: 0;
      right: 0;
      width: 50px;
      height: 50px;
      background: #C2D456;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0E2B47;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .approach-arrow.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .approach-arrow :global(svg) {
      width: 33px;
      height: 33px;
      stroke-width: 3;
      opacity: 0;
      transform: translate(-8px, -8px);
      transition: opacity 0.35s ease 0.3s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
    }

    .approach-arrow.animate-in :global(svg) {
      opacity: 1;
      transform: translate(0, 0);
    }

    .approach-text p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .approach-text p:last-child {
      margin-bottom: 0;
    }

    .approach-image {
      margin: 1.5rem 0;
    }

    .approach-image img {
      width: 77%;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .approach-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .approach-heading {
        padding-right: 0;
        text-align: center;
      }

      .approach-heading h2 {
        display: inline;
      }

      .approach-arrow {
        position: relative;
        top: auto;
        right: auto;
        display: inline-flex;
        vertical-align: top;
        margin-left: 0.5rem;
      }

      .approach-image {
        margin-top: 1.5rem;
      }

      .approach-image img {
        width: 90%;
        display: block;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    const arrow = document.querySelector('.approach-arrow');
    if (arrow) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { arrow.classList.add('animate-in'); obs.disconnect(); } });
      }, { threshold: 0.5 });
      obs.observe(arrow);
    }
  </script>


  <!-- How solar works: simple explanation -->
  <section class="solar-basics-section">
    <div class="container">
      <p class="section-label">How Solar Works</p>
      <h2>Sunlight In, Savings Out</h2>

      <svg width="0" height="0" style="position:absolute;">
        <defs>
          <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C0D446" />
            <stop offset="100%" stop-color="#2061B7" />
          </linearGradient>
        </defs>
      </svg>

      <div class="basics-flow">
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={Sun01Icon} gradient="icon-gradient" />
          </div>
          <h3>Sunlight hits panels</h3>
          <p>Solar panels on your roof convert sunlight into DC electricity.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={ZapIcon} gradient="icon-gradient" />
          </div>
          <h3>Inverter converts it</h3>
          <p>The inverter turns DC into AC power that your home can use.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={Home01Icon} gradient="icon-gradient" />
          </div>
          <h3>Home uses it first</h3>
          <p>Everything running in your home gets powered by solar first.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon basics-icon--battery">
            <HugeIcon icon={BatteryFullIcon} gradient="icon-gradient" />
          </div>
          <h3>Battery stores the rest</h3>
          <p>Anything left over charges your battery for tonight.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .solar-basics-section {
      padding: 5rem 0;
      background: #f8f9fa;
    }

    .solar-basics-section .section-label,
    .solar-basics-section h2 {
      text-align: center;
    }

    .solar-basics-section h2 {
      margin-bottom: 3rem;
    }

    .basics-flow {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0.75rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .basics-step {
      text-align: center;
      flex: 1;
      max-width: 200px;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .basics-arrow {
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    @keyframes arrow-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1.3); }
    }

    /* Everything flips in together */
    .basics-flow.in-view .basics-step:nth-child(1) { transition-delay: 0s; transform: rotateY(0); opacity: 1; }
    .basics-flow.in-view > :nth-child(2) { transition-delay: 0.15s; transform: rotateY(0); opacity: 1; }
    .basics-flow.in-view .basics-step:nth-child(3) { transition-delay: 0.3s; transform: rotateY(0); opacity: 1; }
    .basics-flow.in-view > :nth-child(4) { transition-delay: 0.45s; transform: rotateY(0); opacity: 1; }
    .basics-flow.in-view .basics-step:nth-child(5) { transition-delay: 0.6s; transform: rotateY(0); opacity: 1; }
    .basics-flow.in-view > :nth-child(6) { transition-delay: 0.75s; transform: rotateY(0); opacity: 1; }
    .basics-flow.in-view .basics-step:nth-child(7) { transition-delay: 0.9s; transform: rotateY(0); opacity: 1; }

    /* Arrows pulse 1.5x after all flips finish */
    .basics-flow.in-view > :nth-child(2) { animation: arrow-pulse 0.35s ease 1.5s forwards; }
    .basics-flow.in-view > :nth-child(4) { animation: arrow-pulse 0.35s ease 1.65s forwards; }
    .basics-flow.in-view > :nth-child(6) { animation: arrow-pulse 0.35s ease 1.8s forwards; }

    .basics-icon {
      width: 48px;
      height: 48px;
      margin: 0 auto 1rem;
    }

    .basics-icon :global(svg) {
      width: 100%;
      height: 100%;
    }

    .basics-icon--battery :global(path:nth-child(n+3)) {
      stroke-width: 3.5;
    }

    .basics-step h3 {
      font-size: 0.95rem;
      color: #0E2B47;
      margin-bottom: 0.4rem;
    }

    .basics-step p {
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .basics-arrow {
      width: 28px;
      flex-shrink: 0;
      color: #2061B7;
      margin-top: 0.5rem;
    }

    .basics-arrow svg {
      width: 100%;
      height: auto;
    }

    @media (max-width: 768px) {
      .basics-flow {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .basics-step {
        max-width: 300px;
      }

      .basics-arrow {
        transform: rotateY(180deg) rotate(90deg);
        width: 24px;
        margin: 0;
      }

      @keyframes arrow-pulse-mobile {
        0% { transform: rotate(90deg) scale(1); }
        50% { transform: rotate(90deg) scale(1.5); }
        100% { transform: rotate(90deg) scale(1.3); }
      }

      .basics-flow.in-view > .basics-arrow { transform: rotateY(0) rotate(90deg); opacity: 1; }
      .basics-flow.in-view > :nth-child(2) { animation: arrow-pulse-mobile 0.35s ease 1.5s forwards; }
      .basics-flow.in-view > :nth-child(4) { animation: arrow-pulse-mobile 0.35s ease 1.65s forwards; }
      .basics-flow.in-view > :nth-child(6) { animation: arrow-pulse-mobile 0.35s ease 1.8s forwards; }
    }
  </style>

  <script>
    const flow = document.querySelector('.basics-flow');
    if (flow) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { flow.classList.add('in-view'); observer.disconnect(); } });
      }, { threshold: 0.3 });
      observer.observe(flow);
    }
  </script>


  <!-- Guarantees -->
  <section class="guarantees-section">
    <div class="guarantees-section__slant"></div>
    <div class="guarantees-section__texture"></div>
    <div class="container">
      <p class="section-label" style="text-align:center;">With Every Solar System</p>
      <h2 style="text-align:center; margin-bottom: 2.5rem;">Our Guarantees</h2>

      <div class="guarantees-grid">
        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">70-90%</span>
            <span class="guarantee-tile__label">Average<br />bill reduction</span>
          </div>
        </div>

        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">1-2 day</span>
            <span class="guarantee-tile__label">Typical<br />install time</span>
          </div>
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">10 year</span>
            <span class="guarantee-tile__label">Workmanship<br />warranty</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">25 year</span>
            <span class="guarantee-tile__label">Panel<br />warranty</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .guarantees-section {
      position: relative;
      padding: 5rem 0 6rem;
      background: #f4f5f7;
      overflow: hidden;
    }

    .guarantees-section__slant {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: #eceef1;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
      z-index: 0;
    }

    .guarantees-section__texture {
      position: absolute;
      bottom: -500px;
      left: -100px;
      width: 1000px;
      height: 1000px;
      background: url('/image/textures/WhatWeDo_Texture.svg') no-repeat center / contain;
      transform: rotate(30deg);
      z-index: 0;
      pointer-events: none;
      opacity: 1;
    }

    .guarantees-section .container {
      position: relative;
      z-index: 1;
    }

    .guarantees-grid {
      display: flex;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .guarantee-tile {
      position: relative;
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 528 / 521;
      margin-right: -20px;
    }

    .guarantee-tile:last-child {
      margin-right: 0;
    }

    .guarantee-tile__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
    }

    .guarantee-tile__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 1.5rem;
    }

    .guarantee-tile__value {
      display: block;
      font-size: 2.25rem;
      font-weight: 800;
      color: #0E2B47;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .guarantee-tile__label {
      display: block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #0E2B47;
      line-height: 1.4;
    }

    .guarantee-tile__badge {
      position: absolute;
      bottom: -30px;
      right: -30px;
      width: 72px;
      height: 72px;
      z-index: 2;
    }

    @media (max-width: 768px) {
      .guarantees-grid {
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .guarantee-tile {
        width: calc(50% - 0.75rem);
        flex-shrink: 0;
        margin-right: 0;
      }

      .guarantee-tile__value {
        font-size: 1.75rem;
      }

      .guarantee-tile__label {
        font-size: 0.85rem;
      }

      .guarantee-tile__badge {
        width: 56px;
        height: 56px;
        bottom: -12px;
        right: -12px;
      }

      .guarantees-section__texture {
        width: 600px;
        height: 600px;
        bottom: -300px;
        left: -80px;
      }
    }
  </style>


  <!-- Gallery preview -->
  <section class="gallery-preview-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="gallery-decoration" aria-hidden="true" />
    <div class="container">
      <div class="gallery-preview-grid">
        <div class="gallery-preview-item">
          <img src="/image/photos_clients/12_v1.webp" alt="Norlane residential solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">12.33kW</span>
            <span class="gallery-preview-name">Norlane</span>
          </div>
        </div>
        <div class="gallery-preview-item">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_7.webp" alt="Ocean Grove residential solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">13.2kW</span>
            <span class="gallery-preview-name">Ocean Grove</span>
          </div>
        </div>
        <div class="gallery-preview-item gallery-preview-wide">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_9.webp" alt="Leopold residential solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">6.6kW</span>
            <span class="gallery-preview-name">Leopold</span>
          </div>
        </div>
        <div class="gallery-preview-item gallery-preview-wide">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_17_TopCut_.webp" alt="Torquay residential solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">15.5kW</span>
            <span class="gallery-preview-name">Torquay</span>
          </div>
        </div>
        <div class="gallery-preview-item">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_15_TopCut_.webp" alt="Belmont residential solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">9.9kW</span>
            <span class="gallery-preview-name">Belmont</span>
          </div>
        </div>
        <div class="gallery-preview-item">
          <img src="/image/photos_clients/16_v1.webp" alt="Inverleigh residential solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">8.5kW</span>
            <span class="gallery-preview-name">Inverleigh</span>
          </div>
        </div>
      </div>
      <div class="gallery-preview-cta">
        <a href="/examples/residential">View Full Gallery</a>
      </div>
    </div>
  </section>

  <style>
    .gallery-preview-section {
      padding: 4rem 0;
      background: #fff;
      position: relative;
      overflow: hidden;
    }
    .gallery-decoration {
      position: absolute;
      right: -10%;
      top: 50%;
      transform: translateY(-50%) rotate(100deg);
      opacity: 0.4;
      pointer-events: none;
      height: 100%;
      width: auto;
    }

    .gallery-preview-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto;
      gap: 0.6rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .gallery-preview-item {
      position: relative;
      border-radius: 0.6rem;
      overflow: hidden;
    }

    .gallery-preview-item:nth-child(1) { grid-column: 1; grid-row: 1; }
    .gallery-preview-item:nth-child(2) { grid-column: 2; grid-row: 1; }
    .gallery-preview-item:nth-child(3) { grid-column: 3 / 5; grid-row: 1; }
    .gallery-preview-item:nth-child(4) { grid-column: 1 / 3; grid-row: 2; }
    .gallery-preview-item:nth-child(5) { grid-column: 3; grid-row: 2; }
    .gallery-preview-item:nth-child(6) { grid-column: 4; grid-row: 2; }

    .gallery-preview-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      aspect-ratio: 1 / 1;
    }

    .gallery-preview-wide img {
      aspect-ratio: auto;
      height: 100%;
    }

    .gallery-preview-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0.75rem;
    }

    .gallery-preview-kw {
      display: inline-block;
      width: fit-content;
      font-size: 0.6rem;
      font-weight: 700;
      color: #fff;
      background: rgba(0,0,0,0.45);
      backdrop-filter: blur(6px);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      margin-bottom: 0.2rem;
    }

    .gallery-preview-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }

    .gallery-preview-cta {
      text-align: center;
      margin-top: 1.5rem;
    }

    .gallery-preview-cta a {
      color: #2061B7;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
    }

    .gallery-preview-cta a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .gallery-preview-grid {
        grid-template-columns: 1fr 1fr;
      }

      .gallery-preview-item:nth-child(1) { grid-column: 1; grid-row: 1; }
      .gallery-preview-item:nth-child(2) { grid-column: 2; grid-row: 1; }
