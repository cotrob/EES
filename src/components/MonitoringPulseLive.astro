---
// Original "LIVE" pulse bar animation for the monitoring section
// Saved as a reusable component so we can swap it back in if needed
---

<div class="monitoring-live">
  <div class="monitoring-live__dot"></div>
  <span class="monitoring-live__label">Live</span>
  <div class="monitoring-live__pulse-wrap">
    <svg class="monitoring-live__pulse" viewBox="0 0 200 40" preserveAspectRatio="none">
      <polyline class="monitoring-live__line" points="0,20 20,20 28,20 32,8 36,32 40,14 44,26 48,20 56,20 76,20 84,20 88,8 92,32 96,14 100,26 104,20 112,20 132,20 140,20 144,8 148,32 152,14 156,26 160,20 168,20 200,20" fill="none" stroke="rgba(194,212,86,0.6)" stroke-width="1.5" />
    </svg>
  </div>
  <span class="monitoring-live__status">All systems nominal</span>
</div>

<style>
  .monitoring-live {
    position: relative;
    z-index: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #1a3a5c;
    border-radius: 0 0 12px 12px;
    padding: 1rem 1.5rem 0.85rem;
    margin-top: -8px;
  }

  .monitoring-live__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #C2D456;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(194, 212, 86, 0.5); }
    50% { opacity: 0.6; box-shadow: 0 0 0 6px rgba(194, 212, 86, 0); }
  }

  .monitoring-live__label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #C2D456;
    flex-shrink: 0;
  }

  .monitoring-live__pulse-wrap {
    flex: 1;
    height: 24px;
    overflow: hidden;
  }

  .monitoring-live__pulse {
    width: 100%;
    height: 100%;
  }

  .monitoring-live__line {
    animation: sweep-pulse 3s linear infinite;
  }

  @keyframes sweep-pulse {
    0% { stroke-dasharray: 400; stroke-dashoffset: 400; }
    100% { stroke-dasharray: 400; stroke-dashoffset: 0; }
  }

  .monitoring-live__status {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
    white-space: nowrap;
  }
</style>
