---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import RelatedNav from '../../components/sections/RelatedNav.astro';
---

<BaseLayout
  title="Research Resources | EES"
  description="Access our published research, testing videos, and technical documentation from our laboratory and field installations."
>
  <section class="page-header">
    <div class="container">
      <h1>Research Resources</h1>
      <p>Papers, testing videos, and technical documentation.</p>
    </div>
  </section>

  <RelatedNav
    heading="Browse Our Resources"
    links={[
      { href: '/laboratory/written-papers', title: 'Academic Research', description: 'Peer-reviewed publications on thermal comfort, radiant ceilings, heat pumps, and renewable energy' },
      { href: '/laboratory/footage', title: 'Testing Videos', description: 'Video from our test facility and real-world installations' },
      { href: '/laboratory/products', title: 'Products', description: 'Technical details on products developed and tested in our facility' },
    ]}
  />

  <ScrollIndicator />
</BaseLayout>
