---
interface ImageItem {
  src: string;
  alt: string;
  kw?: string;
  location?: string;
}

interface Props {
  images: ImageItem[];
}

const { images } = Astro.props;
---

<div class="bento-mini">
  {images.map((img, i) => (
    <div class={`bento-mini__item bento-mini__item--${i + 1}`}>
      <img src={img.src} alt={img.alt} loading="lazy" />
      {(img.kw || img.location) && (
        <div class="bento-mini__overlay">
          {img.kw && <span class="bento-mini__kw">{img.kw}</span>}
          {img.location && <span class="bento-mini__location">{img.location}</span>}
        </div>
      )}
    </div>
  ))}
</div>

<style>
  .bento-mini {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
    gap: 0.5rem;
    height: 100%;
    min-height: 380px;
  }

  .bento-mini__item {
    position: relative;
    border-radius: 0.6rem;
    overflow: hidden;
  }

  .bento-mini__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bento-mini__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 50%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0.6rem 0.75rem;
  }

  .bento-mini__kw {
    display: inline-block;
    width: fit-content;
    font-size: 0.55rem;
    font-weight: 700;
    color: #fff;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    margin-bottom: 0.2rem;
    letter-spacing: 0.02em;
  }

  .bento-mini__location {
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.5);
  }

  /* Layout:
     Row 1: img1 (tall, spans row 1-2) | img2
     Row 2: img1 (cont.)               | img3
     Row 3: img4                        | img5
  */
  .bento-mini__item--1 {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .bento-mini__item--2 {
    grid-column: 2;
    grid-row: 1;
  }

  .bento-mini__item--3 {
    grid-column: 2;
    grid-row: 2;
  }

  .bento-mini__item--4 {
    grid-column: 1;
    grid-row: 3;
  }

  .bento-mini__item--5 {
    grid-column: 2;
    grid-row: 3;
  }

  @media (max-width: 800px) {
    .bento-mini {
      min-height: auto;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 0.4rem;
    }

    /* Simplify to 2x2 on mobile, hide 3rd and 5th */
    .bento-mini__item--1 {
      grid-row: 1;
      grid-column: 1;
    }

    .bento-mini__item--2 {
      grid-row: 1;
      grid-column: 2;
    }

    .bento-mini__item--3 {
      display: none;
    }

    .bento-mini__item--4 {
      grid-row: 2;
      grid-column: 1;
    }

    .bento-mini__item--5 {
      grid-row: 2;
      grid-column: 2;
    }

    .bento-mini__item img {
      aspect-ratio: 4 / 3;
    }
  }
</style>
