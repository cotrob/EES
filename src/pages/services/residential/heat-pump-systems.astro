---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import ProcessTimeline from '../../../components/sections/ProcessTimeline.astro';
import FaqGroup from '../../../components/sections/FaqGroup.astro';
import ServiceHero from '../../../components/sections/ServiceHero.astro';
import HugeIcon from '../../../components/HugeIcon.astro';
import Clock01Icon from '@hugeicons/core-free-icons/Clock01Icon';
import Sun01Icon from '@hugeicons/core-free-icons/Sun01Icon';
import UserGroupIcon from '@hugeicons/core-free-icons/UserGroupIcon';
import FireIcon from '@hugeicons/core-free-icons/FireIcon';
import HeaterIcon from '@hugeicons/core-free-icons/HeaterIcon';
import ZapIcon from '@hugeicons/core-free-icons/ZapIcon';
import ArrowRight01Icon from '@hugeicons/core-free-icons/ArrowRight01Icon';
import ArrowDownRight01Icon from '@hugeicons/core-free-icons/ArrowDownRight01Icon';
import NaturalFoodIcon from '@hugeicons/core-free-icons/NaturalFoodIcon';
import DropletIcon from '@hugeicons/core-free-icons/DropletIcon';
---

<BaseLayout
  title="Heat Pump Hot Water Systems Geelong | Installation & Prices | EES"
  description="Heat pump hot water installation in Geelong, Torquay and the Surf Coast. Replace your old gas or electric hot water with an efficient heat pump. CEC accredited, honest advice on whether it's worth switching."
>
  <ServiceHero
    title="Heat Pump Hot Water Systems"
    illustration="/image/illustrations/resindeetial _heatPunmps_ (1).png"
    illustrationAlt="Heat pump hot water system illustration"
  />


  <!-- Intro: Why heat pump hot water -->
  <section class="approach-section">
    <div class="container">
      <div class="approach-layout">
        <div class="approach-heading">
          <p class="section-label">Why Heat Pump Hot Water</p>
          <h2>Already Have Solar?<br />This Is the<br />Next Step.</h2>
          <div class="approach-arrow">
            <HugeIcon icon={ArrowDownRight01Icon} />
          </div>
        </div>
        <div class="approach-text">
          <p>
            If you've got solar panels on your roof and you're generating free electricity during the day, why are you still paying for gas to heat your water?
          </p>
          <p>
            A heat pump hot water system runs on electricity, not gas. Pair it with your solar and your hot water is essentially free. It's the single easiest way to start removing gas from your home and putting more of your solar generation to work.
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .approach-section {
      padding: 8rem 0 4rem;
      background: #fff;
    }

    .approach-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: start;
      max-width: 1000px;
      margin: 0 auto;
    }

    .approach-heading {
      position: relative;
      padding-right: 80px;
      text-align: right;
    }

    .approach-heading h2 {
      margin-bottom: 0;
    }

    .approach-arrow {
      position: absolute;
      top: 0;
      right: 0;
      width: 50px;
      height: 50px;
      background: #C2D456;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0E2B47;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .approach-arrow.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .approach-arrow :global(svg) {
      width: 33px;
      height: 33px;
      stroke-width: 3;
      opacity: 0;
      transform: translate(-8px, -8px);
      transition: opacity 0.35s ease 0.3s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
    }

    .approach-arrow.animate-in :global(svg) {
      opacity: 1;
      transform: translate(0, 0);
    }

    .approach-text p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .approach-text p:last-child {
      margin-bottom: 0;
    }

    .approach-image {
      margin: 1.5rem 0;
    }

    .approach-image img {
      width: 77%;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .approach-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .approach-heading {
        padding-right: 0;
        text-align: center;
      }

      .approach-heading h2 {
        display: inline;
      }

      .approach-arrow {
        position: relative;
        top: auto;
        right: auto;
        display: inline-flex;
        vertical-align: top;
        margin-left: 0.5rem;
      }

      .approach-image {
        margin-top: 1.5rem;
      }

      .approach-image img {
        width: 90%;
        display: block;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    const arrow = document.querySelector('.approach-arrow');
    if (arrow) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { arrow.classList.add('animate-in'); obs.disconnect(); } });
      }, { threshold: 0.5 });
      obs.observe(arrow);
    }
  </script>


  <!-- How a heat pump works: simple visual explanation -->
  <section class="heatpump-basics-section">
    <div class="container">
      <p class="section-label">How It Works</p>
      <h2>Heat Pump Hot Water in 30 Seconds</h2>

      <p class="heatpump-basics-intro">
        A heat pump doesn't generate heat by burning gas or running a heating element. It moves heat from the air into your water, using the same technology as a reverse cycle air conditioner.
      </p>

      <svg width="0" height="0" style="position:absolute;">
        <defs>
          <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C0D446" />
            <stop offset="100%" stop-color="#2061B7" />
          </linearGradient>
        </defs>
      </svg>

      <div class="heatpump-basics-flow">
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={NaturalFoodIcon} gradient="icon-gradient" />
          </div>
          <h3>Absorbs heat from the air</h3>
          <p>Even on cool days, there's warmth in the air. The heat pump's fan draws air across an evaporator that captures that thermal energy.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={ZapIcon} gradient="icon-gradient" />
          </div>
          <h3>Compresses and concentrates it</h3>
          <p>A compressor pressurises the refrigerant, raising the temperature high enough to heat water to 60°C and above.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={DropletIcon} gradient="icon-gradient" />
          </div>
          <h3>Heats your water</h3>
          <p>The hot refrigerant passes through a heat exchanger wrapped around your storage tank, transferring all that captured energy into your water.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .heatpump-basics-section {
      padding: 5rem 0;
      background: #f8f9fa;
    }

    .heatpump-basics-section .section-label,
    .heatpump-basics-section h2 {
      text-align: center;
    }

    .heatpump-basics-section h2 {
      margin-bottom: 1rem;
    }

    .heatpump-basics-intro {
      max-width: 720px;
      margin: 0 auto 3rem;
      text-align: center;
      color: #555;
      font-size: 1.05rem;
      line-height: 1.7;
    }

    .heatpump-basics-flow {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0.75rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .basics-step {
      text-align: center;
      flex: 1;
      max-width: 200px;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .basics-arrow {
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    @keyframes arrow-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1.3); }
    }

    /* Everything flips in together */
    .heatpump-basics-flow.in-view .basics-step:nth-child(1) { transition-delay: 0s; transform: rotateY(0); opacity: 1; }
    .heatpump-basics-flow.in-view > :nth-child(2) { transition-delay: 0.15s; transform: rotateY(0); opacity: 1; }
    .heatpump-basics-flow.in-view .basics-step:nth-child(3) { transition-delay: 0.3s; transform: rotateY(0); opacity: 1; }
    .heatpump-basics-flow.in-view > :nth-child(4) { transition-delay: 0.45s; transform: rotateY(0); opacity: 1; }
    .heatpump-basics-flow.in-view .basics-step:nth-child(5) { transition-delay: 0.6s; transform: rotateY(0); opacity: 1; }

    /* Arrows pulse after all flips finish */
    .heatpump-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse 0.35s ease 1.5s forwards; }
    .heatpump-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse 0.35s ease 1.65s forwards; }

    .basics-icon {
      width: 48px;
      height: 48px;
      margin: 0 auto 1rem;
    }

    .basics-icon :global(svg) {
      width: 100%;
      height: 100%;
    }

    .basics-step h3 {
      font-size: 0.95rem;
      color: #0E2B47;
      margin-bottom: 0.4rem;
    }

    .basics-step p {
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .basics-arrow {
      width: 28px;
      flex-shrink: 0;
      color: #2061B7;
      margin-top: 0.5rem;
    }

    .basics-arrow svg {
      width: 100%;
      height: auto;
    }

    @media (max-width: 768px) {
      .heatpump-basics-flow {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .basics-step {
        max-width: 300px;
      }

      .basics-arrow {
        transform: rotateY(180deg) rotate(90deg);
        width: 24px;
        margin: 0;
      }

      @keyframes arrow-pulse-mobile {
        0% { transform: rotate(90deg) scale(1); }
        50% { transform: rotate(90deg) scale(1.5); }
        100% { transform: rotate(90deg) scale(1.3); }
      }

      .heatpump-basics-flow.in-view > .basics-arrow { transform: rotateY(0) rotate(90deg); opacity: 1; }
      .heatpump-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse-mobile 0.35s ease 1.5s forwards; }
      .heatpump-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse-mobile 0.35s ease 1.65s forwards; }
    }
  </style>

  <script>
    const flow = document.querySelector('.heatpump-basics-flow');
    if (flow) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { flow.classList.add('in-view'); observer.disconnect(); } });
      }, { threshold: 0.3 });
      observer.observe(flow);
    }
  </script>


  <!-- Guarantees -->
  <section class="guarantees-section">
    <div class="guarantees-section__slant"></div>
    <div class="guarantees-section__texture"></div>
    <div class="container">
      <p class="section-label" style="text-align:center;">With Every Heat Pump Install</p>
      <h2 style="text-align:center; margin-bottom: 2.5rem;">Our Guarantees</h2>

      <div class="guarantees-grid">
        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">~60%</span>
            <span class="guarantee-tile__label">Average hot water<br />bill reduction</span>
          </div>
        </div>

        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">1 day</span>
            <span class="guarantee-tile__label">Typical<br />install time</span>
          </div>
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">10 year</span>
            <span class="guarantee-tile__label">Workmanship<br />warranty</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">15 year</span>
            <span class="guarantee-tile__label">Heat pump<br />warranty</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .guarantees-section {
      position: relative;
      padding: 5rem 0 6rem;
      background: #f4f5f7;
      overflow: hidden;
    }

    .guarantees-section__slant {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: #eceef1;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
      z-index: 0;
    }

    .guarantees-section__texture {
      position: absolute;
      bottom: -500px;
      left: -100px;
      width: 1000px;
      height: 1000px;
      background: url('/image/textures/WhatWeDo_Texture.svg') no-repeat center / contain;
      transform: rotate(30deg);
      z-index: 0;
      pointer-events: none;
      opacity: 1;
    }

    .guarantees-section .container {
      position: relative;
      z-index: 1;
    }

    .guarantees-grid {
      display: flex;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .guarantee-tile {
      position: relative;
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 528 / 521;
      margin-right: -20px;
    }

    .guarantee-tile:last-child {
      margin-right: 0;
    }

    .guarantee-tile__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
    }

    .guarantee-tile__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 1.5rem;
    }

    .guarantee-tile__value {
      display: block;
      font-size: 2.25rem;
      font-weight: 800;
      color: #0E2B47;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .guarantee-tile__label {
      display: block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #0E2B47;
      line-height: 1.4;
    }

    .guarantee-tile__badge {
      position: absolute;
      bottom: -34px;
      left: 50%;
      transform: translateX(-50%);
      width: 86px;
      height: 86px;
      z-index: 2;
    }

    @media (max-width: 768px) {
      .guarantees-grid {
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .guarantee-tile {
        width: calc(50% - 0.75rem);
        flex-shrink: 0;
        margin-right: 0;
      }

      .guarantee-tile__value {
        font-size: 1.75rem;
      }

      .guarantee-tile__label {
        font-size: 0.85rem;
      }

      .guarantee-tile__badge {
        width: 67px;
        height: 67px;
        bottom: -22px;
        left: 50%;
        transform: translateX(-50%);
      }

      .guarantees-section__texture {
        width: 600px;
        height: 600px;
        bottom: -300px;
        left: -80px;
      }
    }
  </style>


  <!-- Hot water system comparison table -->
  <section class="hw-tiers-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="tiers-decoration" aria-hidden="true" />
    <div class="container">
      <div class="spec-cards-header">
        <p class="section-label">What You Might Currently Have</p>
        <h2>Four Common Hot Water System Types</h2>
      </div>

      <div class="tier-comparison-table">
        <table>
          <thead>
            <!-- Card row -->
            <tr class="tier-card-row">
              <th></th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Instantaneous Gas</h3>
                <p class="tier-desc">Heats water on demand with no storage tank. Efficient for gas but still relies on gas supply and connection fees.</p>
                <span class="tier-badge">Best for: Small households</span>
              </th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Gas Storage</h3>
                <p class="tier-desc">A gas burner heats a tank of water and keeps it hot. Common in older homes, but the pilot light runs constantly and gas prices keep climbing.</p>
                <span class="tier-badge">Best for: Older homes</span>
              </th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Solar Boosted</h3>
                <p class="tier-desc">Roof mounted solar collectors heat water with a gas or electric booster. Works well but panels degrade and replacements are expensive.</p>
                <span class="tier-badge">Best for: Existing solar HW</span>
              </th>
              <th class="tier-card-cell tier-card-cell--popular">
                <div class="tier-card-top-bar"></div>
                <div class="tier-popular-tag">Best Upgrade</div>
                <h3>Fully Electric</h3>
                <p class="tier-desc">A heating element inside the tank. Simple and cheap to install but the most expensive to run. This is where a heat pump makes the biggest difference.</p>
                <span class="tier-badge">Best for: Upgrade candidate</span>
              </th>
            </tr>
            <!-- Column label row -->
            <tr class="tier-label-row">
              <th>Feature</th>
              <th>Instantaneous Gas</th>
              <th>Gas Storage</th>
              <th>Solar Boosted</th>
              <th>Fully Electric</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Running Cost</td>
              <td>High (gas rates + connection)</td>
              <td>High (gas + standing pilot)</td>
              <td>Low–Medium</td>
              <td>Highest (element heating)</td>
            </tr>
            <tr>
              <td>Efficiency</td>
              <td>Good for gas</td>
              <td>Poor (standby heat loss)</td>
              <td>Good (free solar boost)</td>
              <td>Poor</td>
            </tr>
            <tr>
              <td>Solar Compatible</td>
              <td>No</td>
              <td>No</td>
              <td>Partial (rooftop thermal only)</td>
              <td>Yes (via heat pump upgrade)</td>
            </tr>
            <tr>
              <td>Gas Connection Fee</td>
              <td>~$1.40/day ($500+/year)</td>
              <td>~$1.40/day ($500+/year)</td>
              <td>Varies</td>
              <td>None</td>
            </tr>
            <tr>
              <td>Best Upgrade Path</td>
              <td>Heat pump + solar PV</td>
              <td>Heat pump + solar PV</td>
              <td>Heat pump + solar PV</td>
              <td>Direct heat pump swap</td>
            </tr>
            <tr>
              <td>Typical Lifespan</td>
              <td>15–20 years</td>
              <td>10–15 years</td>
              <td>15–20 years (panels degrade)</td>
              <td>10–12 years</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile stacked cards (hidden on desktop) -->
      <div class="tier-mobile-cards">
        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Instantaneous Gas</h3>
            <p>Heats water on demand with no storage tank. Efficient for gas but still relies on gas supply and connection fees.</p>
            <span class="tier-badge">Best for: Small households</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Running Cost</dt><dd>High (gas rates + connection)</dd></div>
            <div><dt>Efficiency</dt><dd>Good for gas</dd></div>
            <div><dt>Solar Compatible</dt><dd>No</dd></div>
            <div><dt>Gas Connection Fee</dt><dd>~$1.40/day ($500+/year)</dd></div>
            <div><dt>Best Upgrade Path</dt><dd>Heat pump + solar PV</dd></div>
            <div><dt>Typical Lifespan</dt><dd>15–20 years</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Gas Storage</h3>
            <p>A gas burner heats a tank of water and keeps it hot. Common in older homes, but the pilot light runs constantly and gas prices keep climbing.</p>
            <span class="tier-badge">Best for: Older homes</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Running Cost</dt><dd>High (gas + standing pilot)</dd></div>
            <div><dt>Efficiency</dt><dd>Poor (standby heat loss)</dd></div>
            <div><dt>Solar Compatible</dt><dd>No</dd></div>
            <div><dt>Gas Connection Fee</dt><dd>~$1.40/day ($500+/year)</dd></div>
            <div><dt>Best Upgrade Path</dt><dd>Heat pump + solar PV</dd></div>
            <div><dt>Typical Lifespan</dt><dd>10–15 years</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Solar Boosted</h3>
            <p>Roof mounted solar collectors heat water with a gas or electric booster. Works well but panels degrade and replacements are expensive.</p>
            <span class="tier-badge">Best for: Existing solar HW</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Running Cost</dt><dd>Low–Medium</dd></div>
            <div><dt>Efficiency</dt><dd>Good (free solar boost)</dd></div>
            <div><dt>Solar Compatible</dt><dd>Partial (rooftop thermal only)</dd></div>
            <div><dt>Gas Connection Fee</dt><dd>Varies</dd></div>
            <div><dt>Best Upgrade Path</dt><dd>Heat pump + solar PV</dd></div>
            <div><dt>Typical Lifespan</dt><dd>15–20 years (panels degrade)</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card tier-mobile-card--popular">
          <div class="tier-mobile-card__header">
            <div class="tier-popular-tag">Best Upgrade</div>
            <h3>Fully Electric</h3>
            <p>A heating element inside the tank. Simple and cheap to install but the most expensive to run. This is where a heat pump makes the biggest difference.</p>
            <span class="tier-badge">Best for: Upgrade candidate</span>
          </div>
          <dl class="tier-mobile-card__specs">
