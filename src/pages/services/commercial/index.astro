---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import IconFeatureGrid from '../../../components/sections/IconFeatureGrid.astro';
import ProcessTimeline from '../../../components/sections/ProcessTimeline.astro';
import StatBar from '../../../components/sections/StatBar.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
---

<BaseLayout
  title="Commercial Solar & Battery Systems Geelong | Business Solutions | EES"
  description="Commercial solar panel systems and battery storage for businesses in Geelong and regional Victoria. Reduce operating costs with CEC-accredited installation."
>
  <section class="page-header">
    <div class="container">
      <h1>Commercial Energy Systems</h1>
      <p>Solar and battery storage — scaled for business.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_16_TopCut_.webp" alt="Commercial solar installation on business premises" bg="white">
    <p class="section-label">Commercial Solutions</p>
    <h2>Solar and Battery Systems for Commercial Buildings</h2>
    <p>
      Commercial buildings have different energy demands to homes — higher consumption, three-phase power, demand charges, and operating schedules that don't align with solar generation. A residential-grade solar system won't cut it.
    </p>
    <p>
      EES designs and installs commercial solar and battery systems that address these challenges directly. We work with structural and electrical engineers to ensure every system meets ESV, Clean Energy Council, and network provider requirements. The result is reduced operating costs, lower peak demand charges, and a building that costs less to run, year after year.
    </p>
  </SplitFeature>

  <IconFeatureGrid
    label="What We Install"
    heading="Commercial Solar & Battery"
    bg="light"
    columns={2}
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg>',
        title: 'Commercial Solar Systems',
        description: 'Rooftop and ground-mount solar for offices, retail, warehouses, medical centres, aged care, and industrial buildings. Systems from 30 kW to 100+ kW.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="7" width="12" height="10" rx="1"/><line x1="10" y1="7" x2="10" y2="4"/><line x1="14" y1="7" x2="14" y2="4"/><path d="M10 17v3"/><path d="M14 17v3"/></svg>',
        title: 'Commercial Battery Storage',
        description: 'Behind-the-meter battery storage for peak demand reduction, demand charge management, energy arbitrage, and backup power for critical loads.'
      },
    ]}
  />

  <IconFeatureGrid
    label="Our Clients"
    heading="Industries We Work With"
    bg="white"
    columns={3}
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="9" y1="6" x2="15" y2="6"/><line x1="9" y1="10" x2="15" y2="10"/><line x1="9" y1="14" x2="13" y2="14"/></svg>',
        title: 'Offices & Commercial',
        description: 'Reduce operating costs and meet sustainability targets.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><line x1="9" y1="21" x2="9" y2="15"/><line x1="15" y1="21" x2="15" y2="15"/></svg>',
        title: 'Retail & Hospitality',
        description: 'Lower energy bills with solar self-consumption.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>',
        title: 'Medical & Healthcare',
        description: 'Reliable power with battery backup for critical loads.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>',
        title: 'Warehouses & Industrial',
        description: 'Large-scale solar and battery for demand charge reduction.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><rect x="5" y="3" width="14" height="18" rx="1"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="11" y2="15"/></svg>',
        title: 'Multi-Residential',
        description: 'Centralised solar and battery for apartments and townhouses.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>',
        title: 'Any Business',
        description: 'If you pay a power bill, we can likely help reduce it.'
      },
    ]}
  />

  <StatBar
    dark
    stats={[
      { value: '30-100+ kW', label: 'System sizes' },
      { value: '10yr', label: 'Workmanship warranty' },
      { value: 'Div 40', label: 'Tax depreciation eligible' },
      { value: '0', label: 'Subcontractors' },
    ]}
  />

  <IconFeatureGrid
    label="Financial Impact"
    heading="Why Commercial Solar Pays Off"
    bg="light"
    columns={2}
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
        title: 'Reduced Electricity Bills',
        description: 'Solar self-consumption offsets grid purchases at retail rates.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
        title: 'Peak Demand Reduction',
        description: 'Batteries shave demand charges, often the largest bill component.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>',
        title: 'STCs, LGCs & Rebates',
        description: 'Small-scale or Large-scale Technology Certificates depending on system size. We handle the entire process for you.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>',
        title: 'Tax Depreciation',
        description: 'Commercial solar and battery assets depreciate under Division 40.'
      },
    ]}
  />

  <ProcessTimeline
    label="Our Process"
    heading="How We Work With Businesses"
    steps={[
      { title: 'Site Assessment', description: 'We review your building, energy bills, load profile, and operating schedule. For larger systems, structural engineers assess wind and weight loading for your roof.' },
      { title: 'System Design', description: 'Engineered for your specific load profile, building layout, and export requirements. Electrical engineers prepare protection schematics and grid protection boards where required.' },
      { title: 'Approvals & Proposal', description: 'We handle grid connection applications, DNSP coordination, LGC paperwork, and permits. You receive a detailed proposal with system specs, projected savings, and ROI timeline.' },
      { title: 'Installation', description: 'Scheduled entirely around your operations. If a switchboard shutdown needs to happen at 2am to avoid disrupting your business, that\'s what we do.' },
      { title: 'Commissioning & Monitoring', description: 'Full system testing, monitoring setup, and handover. Every system is monitored from day one so we can track performance and respond to any issues.' },
    ]}
  />

  <RelatedNav
    links={[
      { href: '/services/residential', title: 'Residential Systems', description: 'Home solar, battery, and energy solutions' },
      { href: '/services/consultation', title: 'Free Solar Quote', description: 'Get a commercial energy assessment' },
      { href: '/examples/commercial', title: 'Our Work', description: 'See our commercial installations' },
    ]}
  />

  <ScrollIndicator />
</BaseLayout>
