const currentPath = Astro.url.pathname;
---

<header class="header-v2" id="main-header">
  <nav class="nav-v2">
    <a href="/" class="logo-v2">
      <img src="/image/logo/logo_special_navVersion_White.svg" alt="EES Environmental Energy Services" class="logo-img-v2" />
    </a>
    <ul class="nav-links-v2">
      {navItems.map((item: any) => (
        item.divider ? (
          <li class="nav-divider-v2" aria-hidden="true"></li>
        ) : (
        <li class:list={['nav-item-v2', { 'has-mega-v2': item.megaMenu }]}>
          {item.href ? (
            <a
              href={item.href}
              class:list={['nav-link-v2', { active: currentPath === item.href }]}
            >
              {item.label}
            </a>
          ) : (
            <>
              <button class="nav-link-v2 nav-toggle-v2" type="button">
                {item.label}
                <svg class="chevron-v2" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </button>
              <div class="mega-menu-v2">
                <div class="mega-menu-inner-v2">
                  {item.megaMenu?.map((card: any) => (
                    <div class:list={['mega-card-v2', { 'mega-card-no-bg': card.noCard, 'mega-card-disabled': card.disabled }]}>
                      <div class="mega-card-header-v2">
                        <h3>
                          {card.href && !card.disabled ? (
                            <a href={card.href} class="mega-title-link-v2">
                              {card.icon && <svg class:list={['mega-title-icon-v2', { 'mobile-only-icon': card.mobileIconOnly }]} width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={card.icon}/></svg>}
                              {card.title}
                              <svg class="mega-title-chevron-v2" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            </a>
                          ) : (
                            <span class="mega-title-link-v2 mega-title-disabled">
                              {card.icon && <svg class:list={['mega-title-icon-v2', { 'mobile-only-icon': card.mobileIconOnly }]} width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={card.icon}/></svg>}
                              {card.title}
                            </span>
                          )}
                        </h3>
                        {card.examplesHref && (
                          <a href={card.examplesHref} class="mega-examples-btn-v2">
                            See Examples
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                          </a>
                        )}
                      </div>
                      <ul class="mega-card-links-v2">
                        {card.services.map((svc: any) => (
                          <li>
                            {svc.disabled ? (
                              <span class="mega-link-disabled">
                                {svc.label}
                              </span>
                            ) : (
                              <a href={svc.href}>
                                {svc.label}
                                <svg class="mega-link-chevron-v2" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                              </a>
                            )}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            </>
          )}
        </li>
        )
      ))}
    </ul>
    <a href="#solar-qualifier" class="nav-cta-v2"><svg class="cta-arrow-v2" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>Get Your Free Quote</a>
    <button class="menu-toggle-v2" id="menu-toggle" type="button">Menu</button>
  </nav>
</header>

<script>
  const header = document.getElementById('main-header');
  const menuToggle = document.getElementById('menu-toggle');

  function handleScroll() {
    const hero = document.querySelector('.hero') as HTMLElement | null;
    const threshold = hero ? hero.offsetHeight - 100 : 50;
    if (window.scrollY > threshold) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }

  menuToggle?.addEventListener('click', () => {
    header?.classList.toggle('menu-open');
    const isOpen = header?.classList.contains('menu-open');
    menuToggle.textContent = isOpen ? 'Close' : 'Menu';
  });

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Mega menu interactions
  const megaItems = document.querySelectorAll('.nav-item-v2.has-mega-v2');
  const megaTimers = new Map<Element, ReturnType<typeof setTimeout>>();
  const isMobile = () => window.innerWidth <= 900;

  // Mobile: click toggles on nav-toggle buttons
  document.querySelectorAll('.nav-toggle-v2').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      if (!isMobile()) return;
      e.preventDefault();
      const item = btn.closest('.nav-item-v2.has-mega-v2');
      if (!item) return;
      const wasOpen = item.classList.contains('mega-open');
      megaItems.forEach((other) => other.classList.remove('mega-open'));
      if (!wasOpen) item.classList.add('mega-open');
    });
  });

  // Desktop: open on hover, close after delay on leave
  megaItems.forEach((item) => {
    item.addEventListener('mouseenter', () => {
      if (isMobile()) return;
      const timer = megaTimers.get(item);
      if (timer) { clearTimeout(timer); megaTimers.delete(item); }
      megaItems.forEach((other) => {
        if (other !== item) {
          other.classList.remove('mega-open');
          const t = megaTimers.get(other);
          if (t) { clearTimeout(t); megaTimers.delete(other); }
        }
      });
      item.classList.add('mega-open');
    });

    item.addEventListener('mouseleave', () => {
      if (isMobile()) return;
      const timer = setTimeout(() => {
        item.classList.remove('mega-open');
        megaTimers.delete(item);
      }, 2100);
      megaTimers.set(item, timer);
    });
  });

  // Close mega menu when hovering over non-mega nav items (Home, About, etc.)
  document.querySelectorAll('.nav-item-v2:not(.has-mega-v2)').forEach((item) => {
    item.addEventListener('mouseenter', () => {
      if (isMobile()) return;
      megaItems.forEach((mega) => {
        mega.classList.remove('mega-open');
        const t = megaTimers.get(mega);
        if (t) { clearTimeout(t); megaTimers.delete(mega); }
      });
    });
  });

  // Close mega menu when hovering over the CTA button or logo
  document.querySelectorAll('.nav-cta-v2, .logo-v2').forEach((el) => {
    el.addEventListener('mouseenter', () => {
      if (isMobile()) return;
      megaItems.forEach((mega) => {
        mega.classList.remove('mega-open');
        const t = megaTimers.get(mega);
        if (t) { clearTimeout(t); megaTimers.delete(mega); }
      });
    });
  });

  // Close mega menu when clicking anywhere outside
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    megaItems.forEach((item) => {
      if (!item.contains(target)) {
        item.classList.remove('mega-open');
        const timer = megaTimers.get(item);
        if (timer) { clearTimeout(timer); megaTimers.delete(item); }
      }
    });
  });
</script>

<style>
  .header-v2 {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 0.875rem 2rem;
  }

  .header-v2::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
    z-index: -1;
    transition: background 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
  }

  .header-v2.scrolled::before {
    background: rgba(14, 43, 71, 0.85);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .nav-v2 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
  }

  .logo-v2 {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .logo-img-v2 {
    height: 1.75rem;
    width: auto;
  }

  .nav-links-v2 {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item-v2 {
    position: relative;
  }

  .nav-item-v2.has-mega-v2 {
    position: static;
  }

  .nav-divider-v2 {
    width: 1px;
    height: 1.25rem;
    background: rgba(255, 255, 255, 0.3);
    align-self: center;
    margin: 0 0.25rem;
    list-style: none;
  }

  .nav-link-v2 {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 1rem;
    text-decoration: none;
    color: #fff;
    font-weight: 500;
    border-radius: 8px;
    transition: background 0.2s, color 0.2s;
    background: none;
    border: none;
    font-size: 0.9375rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-link-v2:hover,
  .nav-link-v2.active {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .nav-toggle-v2 .chevron-v2 {
    transition: transform 0.2s;
  }

  .nav-item-v2.has-mega-v2.mega-open .chevron-v2 {
    transform: rotate(180deg);
  }

  .nav-cta-v2 {
    padding: 0.625rem 1.5rem;
    background: #2061B7;
    color: #fff;
    text-decoration: none;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    font-weight: 500;
    font-size: 0.9375rem;
    transition: background 0.2s, transform 0.2s;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .cta-arrow-v2 {
    flex-shrink: 0;
    animation: arrowBounceV2 2.5s ease-in-out infinite;
  }

  .nav-cta-v2:hover {
    background: #184A8B;
    color: #fff;
  }

  .nav-cta-v2:hover .cta-arrow-v2 {
    animation: none;
  }

  @keyframes arrowBounceV2 {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }

  /* Mega Menu */
  .mega-menu-v2 {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    padding-top: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
    pointer-events: none;
  }

  .nav-item-v2.has-mega-v2.mega-open .mega-menu-v2 {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .mega-menu-inner-v2 {
    display: grid;
    grid-auto-columns: 1fr;
    grid-auto-flow: column;
    gap: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(80px) saturate(180%);
    -webkit-backdrop-filter: blur(80px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 1rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, backdrop-filter 0.3s ease;
  }

  .header-v2.scrolled .mega-menu-inner-v2 {
    background: rgba(14, 43, 71, 0.85);
    backdrop-filter: blur(80px) saturate(180%);
    -webkit-backdrop-filter: blur(80px) saturate(180%);
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .mega-card-v2 {
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    padding: 1.25rem;
    min-width: 260px;
    background: linear-gradient(135deg, rgba(22, 53, 84, 0.95) 0%, rgba(14, 43, 71, 0.9) 100%);
    backdrop-filter: blur(12px) saturate(150%);
    -webkit-backdrop-filter: blur(12px) saturate(150%);
    border: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 0 20px rgba(255, 255, 255, 0.03),
      0 4px 16px rgba(0, 0, 0, 0.15);
    transition: background 0.3s, box-shadow 0.3s;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .mega-card-v2::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, #22C55E, #2061B7);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .mega-card-v2:hover {
    background: linear-gradient(135deg, rgba(27, 63, 99, 0.98) 0%, rgba(20, 55, 88, 0.95) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      inset 0 0 24px rgba(255, 255, 255, 0.05),
      0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .mega-card-no-bg {
    background: none;
    border: none;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .mega-card-no-bg::before {
    display: none;
  }

  .mega-card-no-bg:hover {
    background: none;
    border: none;
    box-shadow: none;
  }

  .mega-title-disabled {
    cursor: default;
    opacity: 0.7;
    pointer-events: none;
  }

  .mega-title-disabled:hover {
    opacity: 0.7;
    text-decoration: none;
  }

  .mega-card-header-v2 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    gap: 0.75rem;
  }

  .mega-card-header-v2 h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
    letter-spacing: 0.01em;
  }

  .mega-title-link-v2 {
    display: inline-flex;
    align-items: center;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .mega-title-link-v2:hover {
    opacity: 0.8;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .mega-title-icon-v2 {
    display: inline-block;
    vertical-align: middle;
    margin-right: 0.375rem;
    opacity: 0.7;
    flex-shrink: 0;
  }

  .mega-title-link-v2:hover .mega-title-icon-v2 {
    opacity: 1;
  }

  .mobile-only-icon {
    display: none;
  }

  .mega-title-chevron-v2 {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.25rem;
    opacity: 0.6;
    transition: opacity 0.15s, transform 0.15s;
  }

  .mega-title-link-v2:hover .mega-title-chevron-v2 {
    opacity: 1;
    transform: translateX(2px);
  }

  .mega-card-links-v2 {
    list-style: none;
    padding: 0;
    margin: 0;
    padding-left: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-left: 1px solid rgba(255, 255, 255, 0.15);
  }

  .mega-card-links-v2 a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3rem 0;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s;
  }

  .mega-card-links-v2 a:hover {
    color: #fff;
  }

  .mega-link-chevron-v2 {
    opacity: 0.4;
    transition: opacity 0.15s, transform 0.15s;
    flex-shrink: 0;
  }

  .mega-card-links-v2 a:hover .mega-link-chevron-v2 {
    opacity: 1;
    transform: translateX(2px);
  }

  /* See Examples button */
  .mega-examples-btn-v2 {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 5px;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
