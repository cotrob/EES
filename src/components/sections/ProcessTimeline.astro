---
interface Step {
  title: string;
  description: string;
  icon?: [string, Record<string, string | number>][];
}

interface Props {
  label?: string;
  heading?: string;
  steps: Step[];
  bg?: 'white' | 'light' | 'cream';
  iconSize?: number;
  iconColor?: string;
}

import HugeIcon from '../HugeIcon.astro';

const { label, heading, steps, bg = 'cream', iconSize = 22, iconColor = '#3B6B2B' } = Astro.props;

const bgMap = {
  white: '#fff',
  light: '#f8f9fa',
  cream: 'rgba(240, 238, 217, 0.25)',
};
---

<section class="process-timeline" style={`background: ${bgMap[bg]};`}>
  <div class="container">
    {(label || heading) && (
      <div class="process-timeline-header">
        {label && <p class="section-label">{label}</p>}
        {heading && <h2>{heading}</h2>}
      </div>
    )}
    <div class="steps-timeline">
      {steps.map((step, i) => (
        <div class="step">
          <div class="step-marker">
            <span class="step-number">{i + 1}</span>
            {i < steps.length - 1 && <div class="step-line"></div>}
          </div>
          <div class="step-content">
            <div class="step-icon-row">
              {step.icon && (
                <div class="step-icon">
                  <HugeIcon icon={step.icon} size={iconSize} color={iconColor} />
                </div>
              )}
              <h3>{step.title}</h3>
            </div>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initProcessTimeline() {
    const steps = document.querySelectorAll('.process-timeline .step');
    if (!steps.length) return;

    let revealed = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !revealed) {
            revealed = true;
            observer.disconnect();
            steps.forEach((step, i) => {
              setTimeout(() => step.classList.add('is-visible'), i * 300);
            });
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
    );

    steps.forEach((step) => observer.observe(step));
  }

  initProcessTimeline();
  document.addEventListener('astro:page-load', initProcessTimeline);
</script>
