---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
---

<BaseLayout
  title="Research Facility | EES"
  description="Our purpose-built research and testing facility in Geelong, Victoria. Home to the EES simulation test room, open-air test rigs, and panel manufacturing."
>
  <section class="facility-hero">
    <img src="/image/WIP/TestRoom_webp/testroom-aerial-facility.webp" alt="Aerial view of the EES research facility in Geelong" />
    <div class="facility-hero__overlay">
      <div class="container">
        <h1>Research Facility</h1>
        <p>Our Geelong workshop and testing laboratory.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container prose">
      <p>Facility page coming soon. In the meantime, visit our <a href="/laboratory/test-room">Simulation Test Room</a> page to see the TestCell and our testing capabilities.</p>
    </div>
  </section>

  <style>
    .facility-hero {
      position: relative;
      width: 100%;
      max-height: 500px;
      overflow: hidden;
    }
    .facility-hero img {
      width: 100%;
      height: 500px;
      object-fit: cover;
      display: block;
    }
    .facility-hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(14, 43, 71, 0.85) 0%, rgba(14, 43, 71, 0.3) 100%);
      display: flex;
      align-items: flex-end;
      padding-bottom: 3rem;
    }
    .facility-hero__overlay h1 {
      color: #fff;
      font-size: 2.8rem;
      margin: 0 0 0.5rem;
    }
    .facility-hero__overlay p {
      color: rgba(255, 255, 255, 0.85);
      font-size: 1.2rem;
      margin: 0;
    }
  </style>
  <ScrollIndicator />
</BaseLayout>
