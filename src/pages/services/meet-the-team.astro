---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import SplitFeature from '../../components/sections/SplitFeature.astro';
import IconFeatureGrid from '../../components/sections/IconFeatureGrid.astro';
import RelatedNav from '../../components/sections/RelatedNav.astro';
---

<BaseLayout
  title="Meet the Team | EES Solar & Energy Services Geelong"
  description="Meet the EES team — CEC-accredited electricians, energy system designers, and local support staff servicing Geelong, Surf Coast, and regional Victoria."
>
  <section class="page-header">
    <div class="container">
      <h1>Meet the Team</h1>
      <p>Local energy experts you'll actually meet — before, during, and after installation.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_15_TopCut_.webp" alt="EES team and facility" bg="white">
    <p class="section-label">Your Local Team</p>
    <h2>Same People, Start to Finish</h2>
    <p>
      When you work with EES, you're not dealing with a call centre or a sales team that disappears after the contract is signed. You're working with the same local team from first consultation through to installation and ongoing support.
    </p>
    <p>
      We're based at 13 Nobility Street, Moolap — and we service Greater Geelong, Torquay, the Surf Coast, Bellarine Peninsula, Golden Plains, and wider regional Victoria.
    </p>
  </SplitFeature>

  <IconFeatureGrid
    label="What We Do"
    heading="Our Team Handles Everything"
    bg="light"
    columns={3}
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>',
        title: 'System Design',
        description: 'We assess your property, review your energy usage, and design integrated systems tailored to your home.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
        title: 'Installation',
        description: 'Our CEC-accredited electricians install every system. No subcontractors, no third-party handoffs.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
        title: 'Commissioning',
        description: 'We commission and test every installation, walk you through monitoring, and make sure everything works.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
        title: 'Ongoing Support',
        description: 'If something needs attention after installation, you call us directly. We\'re local and here for the long term.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
        title: 'Research & Development',
        description: 'Our research team designs, builds, and tests products at our Geelong facility before they go into homes.'
      },
    ]}
  />

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_19_TopCut_.webp" alt="EES headquarters" reverse bg="cream">
    <p class="section-label">Why It Matters</p>
    <h2>No Subcontractors, No Runaround</h2>
    <p>
      Most solar companies use subcontractors — your system is designed by one company, sold by another, and installed by a third. If something goes wrong, nobody takes ownership.
    </p>
    <p>
      At EES, the person who designs your system works with the person who installs it. Our <strong>10-year workmanship warranty</strong> means we stand behind every installation, and because we're local, we're down the road if you need us.
    </p>
    <p>
      <a href="/about">See the full team on our About page &rarr;</a>
    </p>
  </SplitFeature>

  <RelatedNav
    links={[
      { href: '/about', title: 'About EES', description: 'Team profiles and company info' },
      { href: '/services/consultation', title: 'Free Consultation', description: 'Book a no-obligation assessment' },
      { href: '/contact', title: 'Contact Us', description: 'Get in touch with the team' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to work with a local team?</p>
      <a href="/services/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>
