---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import ServiceHero from '../../../components/sections/ServiceHero.astro';
import HugeIcon from '../../../components/HugeIcon.astro';
import Sun01Icon from '@hugeicons/core-free-icons/Sun01Icon';
import Home01Icon from '@hugeicons/core-free-icons/Home01Icon';
import BatteryFullIcon from '@hugeicons/core-free-icons/BatteryFullIcon';
import ElectricTower01Icon from '@hugeicons/core-free-icons/ElectricTower01Icon';
import MoneyReceiveSquareIcon from '@hugeicons/core-free-icons/MoneyReceiveSquareIcon';
import ArrowRight01Icon from '@hugeicons/core-free-icons/ArrowRight01Icon';
import ArrowDownRight01Icon from '@hugeicons/core-free-icons/ArrowDownRight01Icon';
---

<BaseLayout
  title="Virtual Power Plants (VPPs) Geelong | Earn From Your Battery | EES"
  description="Earn money from your home battery with a Virtual Power Plant. EES sets you up with the best VPP strategy for your home, not locked to any single retailer. Geelong, Surf Coast, Bellarine."
>
  <ServiceHero
    title="Virtual Power Plants (VPPs)"
    illustration="/image/illustrations/Residential  Solar Systems.png"
    illustrationAlt="Virtual power plant energy trading illustration"
  />


  <!-- Approach: What is a VPP -->
  <section class="approach-section">
    <div class="container">
      <div class="approach-layout">
        <div class="approach-heading">
          <p class="section-label">What Is a VPP</p>
          <h2>Your Battery Can<br />Sell Power Back<br />at $17 a Kilowatt<br />Hour</h2>
          <div class="approach-arrow">
            <HugeIcon icon={ArrowDownRight01Icon} />
          </div>
        </div>
        <div class="approach-text">
          <p>
            A Virtual Power Plant connects your home battery to the wholesale energy market. When demand on the grid spikes and electricity prices go up, your battery automatically discharges stored energy back to the grid at those high prices. You get paid the wholesale rate, not the flat one cent feed in tariff.
          </p>
          <p>
            Here's a real example. Loy Yang coal plant in central Victoria goes down for planned maintenance. They call it in 24 hours in advance. There's going to be a shortage of electricity, so the price in the national energy market jumps to $17.50 per kilowatt hour, the maximum it can go. Your battery automatically discharges at that rate. If you've got a 16 kWh battery, that's around $272 in a two hour window.
          </p>
          <div class="approach-image">
            <img src="/image/photography/01_Hero_Images_OG/Frontage_18_TopCut_.webp" alt="Home battery system with VPP capability" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .approach-section {
      padding: 8rem 0 4rem;
      background: #fff;
    }

    .approach-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: start;
      max-width: 1000px;
      margin: 0 auto;
    }

    .approach-heading {
      position: relative;
      padding-right: 80px;
      text-align: right;
    }

    .approach-heading h2 {
      margin-bottom: 0;
    }

    .approach-arrow {
      position: absolute;
      top: 0;
      right: 0;
      width: 50px;
      height: 50px;
      background: #C2D456;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0E2B47;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .approach-arrow.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .approach-arrow :global(svg) {
      width: 33px;
      height: 33px;
      stroke-width: 3;
      opacity: 0;
      transform: translate(-8px, -8px);
      transition: opacity 0.35s ease 0.3s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
    }

    .approach-arrow.animate-in :global(svg) {
      opacity: 1;
      transform: translate(0, 0);
    }

    .approach-text p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.7;
      margin-bottom: 1rem;
    }

    .approach-text p:last-child {
      margin-bottom: 0;
    }

    .approach-image {
      margin: 1.5rem 0;
    }

    .approach-image img {
      width: 77%;
      height: auto;
      display: block;
      margin: 0 auto;
    }

    @media (max-width: 768px) {
      .approach-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .approach-heading {
        padding-right: 0;
        text-align: center;
      }

      .approach-heading h2 {
        display: inline;
      }

      .approach-arrow {
        position: relative;
        top: auto;
        right: auto;
        display: inline-flex;
        vertical-align: top;
        margin-left: 0.5rem;
      }

      .approach-image {
        margin-top: 1.5rem;
      }

      .approach-image img {
        width: 90%;
        display: block;
        margin: 0 auto;
      }
    }
  </style>

  <script>
    const arrow = document.querySelector('.approach-arrow');
    if (arrow) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { arrow.classList.add('animate-in'); obs.disconnect(); } });
      }, { threshold: 0.5 });
      obs.observe(arrow);
    }
  </script>


  <!-- How it works -->
  <section class="vpp-basics-section">
    <div class="container">
      <p class="section-label">How It Works</p>
      <h2>From Solar to Earnings</h2>

      <svg width="0" height="0" style="position:absolute;">
        <defs>
          <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C0D446" />
            <stop offset="100%" stop-color="#2061B7" />
          </linearGradient>
        </defs>
      </svg>

      <div class="vpp-basics-flow">
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={Sun01Icon} gradient="icon-gradient" />
          </div>
          <h3>Solar charges your battery</h3>
          <p>During the day, your solar panels generate electricity and charge your home battery as normal.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={Home01Icon} gradient="icon-gradient" />
          </div>
          <h3>You use what you need</h3>
          <p>Your home draws from the battery first, reducing what you buy from the grid.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon basics-icon--battery">
            <HugeIcon icon={BatteryFullIcon} gradient="icon-gradient" />
          </div>
          <h3>VPP trades automatically</h3>
          <p>When wholesale prices spike, your battery automatically exports stored energy at the market rate. You don't need to watch the market.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={ElectricTower01Icon} gradient="icon-gradient" />
          </div>
          <h3>Grid pays wholesale rate</h3>
          <p>You get paid the actual wholesale price for each kWh exported. On a good spike, that can be $17.50 per kilowatt hour.</p>
        </div>
        <div class="basics-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="basics-step">
          <div class="basics-icon">
            <HugeIcon icon={MoneyReceiveSquareIcon} gradient="icon-gradient" />
          </div>
          <h3>Battery recharges tomorrow</h3>
          <p>Your solar panels refill the battery the next day and the cycle continues.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .vpp-basics-section {
      padding: 5rem 0;
      background: #f8f9fa;
    }

    .vpp-basics-section .section-label,
    .vpp-basics-section h2 {
      text-align: center;
    }

    .vpp-basics-section h2 {
      margin-bottom: 3rem;
    }

    .vpp-basics-flow {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0.75rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .basics-step {
      text-align: center;
      flex: 1;
      max-width: 200px;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .basics-arrow {
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    @keyframes arrow-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1.3); }
    }

    /* Everything flips in together */
    .vpp-basics-flow.in-view .basics-step:nth-child(1) { transition-delay: 0s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view > :nth-child(2) { transition-delay: 0.15s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view .basics-step:nth-child(3) { transition-delay: 0.3s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view > :nth-child(4) { transition-delay: 0.45s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view .basics-step:nth-child(5) { transition-delay: 0.6s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view > :nth-child(6) { transition-delay: 0.75s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view .basics-step:nth-child(7) { transition-delay: 0.9s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view > :nth-child(8) { transition-delay: 1.05s; transform: rotateY(0); opacity: 1; }
    .vpp-basics-flow.in-view .basics-step:nth-child(9) { transition-delay: 1.2s; transform: rotateY(0); opacity: 1; }

    /* Arrows pulse after all flips finish */
    .vpp-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse 0.35s ease 1.8s forwards; }
    .vpp-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse 0.35s ease 1.95s forwards; }
    .vpp-basics-flow.in-view > :nth-child(6) { animation: arrow-pulse 0.35s ease 2.1s forwards; }
    .vpp-basics-flow.in-view > :nth-child(8) { animation: arrow-pulse 0.35s ease 2.25s forwards; }

    .basics-icon {
      width: 48px;
      height: 48px;
      margin: 0 auto 1rem;
    }

    .basics-icon :global(svg) {
      width: 100%;
      height: 100%;
    }

    .basics-icon--battery :global(path:nth-child(n+3)) {
      stroke-width: 3.5;
    }

    .basics-step h3 {
      font-size: 0.95rem;
      color: #0E2B47;
      margin-bottom: 0.4rem;
    }

    .basics-step p {
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .basics-arrow {
      width: 28px;
      flex-shrink: 0;
      color: #2061B7;
      margin-top: 0.5rem;
    }

    .basics-arrow svg {
      width: 100%;
      height: auto;
    }

    @media (max-width: 768px) {
      .vpp-basics-flow {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .basics-step {
        max-width: 300px;
      }

      .basics-arrow {
        transform: rotateY(180deg) rotate(90deg);
        width: 24px;
        margin: 0;
      }

      @keyframes arrow-pulse-mobile {
        0% { transform: rotate(90deg) scale(1); }
        50% { transform: rotate(90deg) scale(1.5); }
        100% { transform: rotate(90deg) scale(1.3); }
      }

      .vpp-basics-flow.in-view > .basics-arrow { transform: rotateY(0) rotate(90deg); opacity: 1; }
      .vpp-basics-flow.in-view > :nth-child(2) { animation: arrow-pulse-mobile 0.35s ease 1.8s forwards; }
      .vpp-basics-flow.in-view > :nth-child(4) { animation: arrow-pulse-mobile 0.35s ease 1.95s forwards; }
      .vpp-basics-flow.in-view > :nth-child(6) { animation: arrow-pulse-mobile 0.35s ease 2.1s forwards; }
      .vpp-basics-flow.in-view > :nth-child(8) { animation: arrow-pulse-mobile 0.35s ease 2.25s forwards; }
    }
  </style>

  <script>
    const flow = document.querySelector('.vpp-basics-flow');
    if (flow) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { flow.classList.add('in-view'); observer.disconnect(); } });
      }, { threshold: 0.3 });
      observer.observe(flow);
    }
  </script>


  <!-- Guarantees -->
  <section class="guarantees-section">
    <div class="guarantees-section__slant"></div>
    <div class="guarantees-section__texture"></div>
    <div class="container">
      <p class="section-label" style="text-align:center;">With Every VPP Setup</p>
      <h2 style="text-align:center; margin-bottom: 2.5rem;">What You Get</h2>

      <div class="guarantees-grid">
        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">$17.50</span>
            <span class="guarantee-tile__label">Max wholesale<br />price per kWh</span>
          </div>
        </div>

        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">15kW</span>
            <span class="guarantee-tile__label">Three-phase<br />export capacity</span>
          </div>
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">48hr</span>
            <span class="guarantee-tile__label">Fault<br />response time</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">$0</span>
            <span class="guarantee-tile__label">VPP setup<br />fee</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .guarantees-section {
      position: relative;
      padding: 5rem 0 6rem;
      background: #f4f5f7;
      overflow: hidden;
    }

    .guarantees-section__slant {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: #eceef1;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
      z-index: 0;
    }

    .guarantees-section__texture {
      position: absolute;
      bottom: -500px;
      left: -100px;
      width: 1000px;
      height: 1000px;
      background: url('/image/textures/WhatWeDo_Texture.svg') no-repeat center / contain;
      transform: rotate(30deg);
      z-index: 0;
      pointer-events: none;
      opacity: 1;
    }

    .guarantees-section .container {
      position: relative;
      z-index: 1;
    }

    .guarantees-grid {
      display: flex;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .guarantee-tile {
      position: relative;
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 528 / 521;
      margin-right: -20px;
    }

    .guarantee-tile:last-child {
      margin-right: 0;
    }

    .guarantee-tile__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
    }

    .guarantee-tile__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 1.5rem;
    }

    .guarantee-tile__value {
      display: block;
      font-size: 2.25rem;
      font-weight: 800;
      color: #0E2B47;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .guarantee-tile__label {
      display: block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #0E2B47;
      line-height: 1.4;
    }

    .guarantee-tile__badge {
      position: absolute;
      bottom: -28px;
      left: 50%;
      transform: translateX(-50%);
      width: 72px;
      height: 72px;
      z-index: 2;
    }

    @media (max-width: 768px) {
      .guarantees-grid {
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .guarantee-tile {
        width: calc(50% - 0.75rem);
        flex-shrink: 0;
        margin-right: 0;
      }

      .guarantee-tile__value {
        font-size: 1.75rem;
      }

      .guarantee-tile__label {
        font-size: 0.85rem;
      }

      .guarantee-tile__badge {
        width: 56px;
        height: 56px;
        bottom: -18px;
        left: 50%;
        transform: translateX(-50%);
      }

      .guarantees-section__texture {
        width: 600px;
        height: 600px;
        bottom: -300px;
        left: -80px;
      }
    }
  </style>


  <!-- Earning potential comparison table -->
  <section class="vpp-tiers-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="tiers-decoration" aria-hidden="true" />
    <div class="container">
      <div class="spec-cards-header">
        <p class="section-label">Earning Potential</p>
        <h2>What Your Setup Can Earn</h2>
      </div>

      <div class="tier-comparison-table">
        <table>
          <thead>
            <!-- Card row -->
            <tr class="tier-card-row">
              <th></th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Single Phase</h3>
                <p class="tier-desc">Standard residential connection with 5kW export limit. Suitable for VPP participation but with capped earning potential during price spikes.</p>
                <span class="tier-badge">Best for: Standard homes</span>
              </th>
              <th class="tier-card-cell tier-card-cell--popular">
                <div class="tier-card-top-bar"></div>
                <div class="tier-popular-tag">Recommended</div>
                <h3>Three Phase</h3>
                <p class="tier-desc">Three-phase connection with 15kW export capacity — three times the earning potential of single phase during price spikes.</p>
                <span class="tier-badge">Best for: Maximum earnings</span>
              </th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>Three Phase + Large Battery</h3>
                <p class="tier-desc">Three-phase power paired with a large capacity battery (16kWh+). The ultimate VPP setup for maximising both storage and export.</p>
                <span class="tier-badge">Best for: Serious traders</span>
              </th>
            </tr>
            <!-- Column label row -->
            <tr class="tier-label-row">
              <th>Feature</th>
              <th>Single Phase</th>
              <th>Three Phase</th>
              <th>Three Phase + Large Battery</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Export Capacity</td>
              <td>5kW</td>
              <td>15kW</td>
              <td>15kW</td>
            </tr>
            <tr>
              <td>Spike Earnings (2hr window)</td>
              <td>$40–$85</td>
              <td>$120–$272</td>
              <td>$200–$272+</td>
            </tr>
            <tr>
              <td>Typical Monthly Earnings</td>
              <td>Moderate</td>
              <td>$170+/month</td>
              <td>$170+/month</td>
            </tr>
            <tr>
              <td>Winter Strategy</td>
              <td>Force charge from grid (off-peak)</td>
              <td>Force charge (e.g. Glowbird 11am–2pm free)</td>
              <td>Force charge + large reserve</td>
            </tr>
            <tr>
              <td>Best VPP Provider</td>
              <td>Amber or Glowbird (depends on usage)</td>
              <td>Amber, Glowbird, or Tango</td>
              <td>Amber wholesale trading</td>
            </tr>
            <tr>
              <td>Battery Recharge</td>
              <td>Next day solar</td>
              <td>Next day solar</td>
              <td>Next day solar + grid top-up</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile stacked cards (hidden on desktop) -->
      <div class="tier-mobile-cards">
        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Single Phase</h3>
            <p>Standard residential connection with 5kW export limit. Suitable for VPP participation but with capped earning potential during price spikes.</p>
            <span class="tier-badge">Best for: Standard homes</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Export Capacity</dt><dd>5kW</dd></div>
            <div><dt>Spike Earnings (2hr window)</dt><dd>$40–$85</dd></div>
            <div><dt>Typical Monthly Earnings</dt><dd>Moderate</dd></div>
            <div><dt>Winter Strategy</dt><dd>Force charge from grid (off-peak)</dd></div>
            <div><dt>Best VPP Provider</dt><dd>Amber or Glowbird (depends on usage)</dd></div>
            <div><dt>Battery Recharge</dt><dd>Next day solar</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card tier-mobile-card--popular">
          <div class="tier-mobile-card__header">
            <div class="tier-popular-tag">Recommended</div>
            <h3>Three Phase</h3>
            <p>Three-phase connection with 15kW export capacity — three times the earning potential of single phase during price spikes.</p>
            <span class="tier-badge">Best for: Maximum earnings</span>
          </div>
          <dl class="tier-mobile-card__specs">
            <div><dt>Export Capacity</dt><dd>15kW</dd></div>
            <div><dt>Spike Earnings (2hr window)</dt><dd>$120–$272</dd></div>
            <div><dt>Typical Monthly Earnings</dt><dd>$170+/month</dd></div>
            <div><dt>Winter Strategy</dt><dd>Force charge (e.g. Glowbird 11am–2pm free)</dd></div>
            <div><dt>Best VPP Provider</dt><dd>Amber, Glowbird, or Tango</dd></div>
            <div><dt>Battery Recharge</dt><dd>Next day solar</dd></div>
          </dl>
        </div>

        <div class="tier-mobile-card">
          <div class="tier-mobile-card__header">
            <h3>Three Phase + Large Battery</h3>
