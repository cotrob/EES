---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import SplitFeature from '../../components/sections/SplitFeature.astro';
import ProcessTimeline from '../../components/sections/ProcessTimeline.astro';
import IconFeatureGrid from '../../components/sections/IconFeatureGrid.astro';
import RelatedNav from '../../components/sections/RelatedNav.astro';
import { hugeIconToSvg } from '../../lib/hugeicon-svg';
import Layout01Icon from '@hugeicons/core-free-icons/Layout01Icon';
import ChartBarIncreasingIcon from '@hugeicons/core-free-icons/ChartBarIncreasingIcon';
import Dollar01Icon from '@hugeicons/core-free-icons/Dollar01Icon';
import File01Icon from '@hugeicons/core-free-icons/File01Icon';
import CreditCardIcon from '@hugeicons/core-free-icons/CreditCardIcon';
import UserAdd01Icon from '@hugeicons/core-free-icons/UserAdd01Icon';
---

<BaseLayout
  title="Free Solar & Energy Consultation Geelong | Book Online | EES"
  description="Free no-obligation energy consultation in Geelong. We assess your property and recommend the best solar, battery or heat pump solution."
>
  <section class="page-header">
    <div class="container">
      <h1>Free Energy Consultation</h1>
      <p>No-obligation assessment of your property and energy needs.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_18_TopCut_.webp" alt="EES team conducting a property energy assessment" bg="white">
    <p class="section-label">What to Expect</p>
    <h2>A Proper Engineering Assessment</h2>
    <p>
      We visit your property and carry out a detailed assessment. This isn't a sales pitch — it's an engineering assessment to determine what system will actually work best for your situation.
    </p>
    <p>
      Every consultation is conducted by a qualified member of our team — not a subcontractor or third-party sales agent.
    </p>
  </SplitFeature>

  <ProcessTimeline
    label="During Your Visit"
    heading="What Happens During a Consultation"
    steps={[
      { title: 'Assess Your Roof', description: 'Orientation, pitch, shading, and available space for solar panels.' },
      { title: 'Review Your Energy Bills', description: 'Understand how much you use, when you use it, and what you\'re paying.' },
      { title: 'Discuss Your Goals', description: 'Whether that\'s reducing bills, going off-grid, replacing gas, adding a battery, or all of the above.' },
      { title: 'Evaluate Your Electrical Setup', description: 'Switchboard capacity, existing wiring, and what\'s needed for installation.' },
      { title: 'Recommend a System', description: 'Based on your property and energy profile, not a generic package.' },
    ]}
  />

  <IconFeatureGrid
    label="Your Proposal"
    heading="What You'll Receive"
    bg="light"
    columns={3}
    features={[
      {
        icon: hugeIconToSvg(Layout01Icon),
        title: 'System Design',
        description: 'Detailed design and component specifications tailored to your property.'
      },
      {
        icon: hugeIconToSvg(ChartBarIncreasingIcon),
        title: 'Savings Estimate',
        description: 'Expected energy generation and realistic, conservative savings projections.'
      },
      {
        icon: hugeIconToSvg(Dollar01Icon),
        title: 'Applicable Rebates',
        description: 'STC discount, Victorian Government rebates, and any other incentives you qualify for.'
      },
      {
        icon: hugeIconToSvg(File01Icon),
        title: 'Itemised Pricing',
        description: 'Full cost breakdown with no hidden charges or surprise fees.'
      },
      {
        icon: hugeIconToSvg(CreditCardIcon),
        title: 'Financing Options',
        description: 'Interest-free plans, green loans, and buy-now-pay-later if needed.'
      },
      {
        icon: hugeIconToSvg(UserAdd01Icon),
        title: 'No Obligation',
        description: 'There\'s no pressure. If you decide not to proceed, you keep the assessment.'
      },
    ]}
  />

  <SplitFeature image="/image/icon/Crednetials_3.webp" alt="Geelong bollards icon - trusted local team" reverse bg="cream" flat>
    <p class="section-label">Service Area</p>
    <h2>Local Geelong Team</h2>
    <p>
      We service Greater Geelong, Torquay, the Surf Coast, Bellarine Peninsula, Golden Plains, and wider regional Victoria. Based in Moolap, we're a local team with local knowledge.
    </p>
    <p>
      EES is a CEC-accredited installer and Solar Victoria approved retailer. Every consultation is conducted by a qualified member of our team.
    </p>
    <p><strong>Phone:</strong> <a href="tel:0427664827">0427 664 827</a></p>
    <p><strong>Email:</strong> <a href="mailto:support@eeservices.io">support@eeservices.io</a></p>
  </SplitFeature>

  <RelatedNav
    links={[
      { href: '/services/residential', title: 'Residential Systems', description: 'Solar, battery, heat pump solutions' },
      { href: '/services/commercial', title: 'Commercial Systems', description: 'Solar and battery for business' },
      { href: '/services/financing', title: 'Financing & Rebates', description: 'Payment plans and government incentives' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to find out what's possible for your property?</p>
      <a href="#solar-qualifier" class="btn btn-primary">Start Your Energy Assessment</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>
