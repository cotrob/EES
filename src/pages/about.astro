---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
---

<BaseLayout
  title="About EES | CEC Accredited Solar & Energy Installer Geelong"
  description="EES is a CEC accredited solar company in Geelong. We design, install, and support solar, battery, heat pump, and hydronic heating systems from our research facility in Moolap."
>
  <!-- ── Top texture banner ── -->
  <div class="about-texture">
    <img src="/image/textures/aboutus_top%20texture.svg" alt="" aria-hidden="true" />
  </div>

  <!-- ── Row 1: Hero + Photos ── -->
  <section class="about-row">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <p class="section-label">About EES</p>
          <h1><strong>About us, our people</strong><br/>and our commitment to<br/>healthy and affordable living</h1>
        </div>
        <p class="about-intro">Where it all started in Moolap, Geelong and why we're focused on the south coast of Victoria</p>
        <div class="about-photo about-photo--main">
          <img src="/image/photos_EESshed/Group%20131%20(1).png" alt="EES team members outside the Moolap facility" />
        </div>
        <div class="about-photo about-photo--secondary">
          <img src="/image/photos_EESshed/Group%20132.png" alt="EES headquarters exterior in Moolap, Geelong" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Row 2: Our Story ── -->
  <section class="story-row">
    <div class="container">
      <div class="story-flex">
        <div class="story-left">
          <h2 class="story-script">Our Story &#8601;</h2>
        </div>
        <div class="story-right">
          <p>
            What if a home could heat, cool, and power itself using a single integrated system? That question led to the founding of Environmental Energy Services in Moolap, Geelong. What began as a research project has grown into a full service energy company with its own laboratory, its own products, and a team of qualified electricians and researchers working under one roof.
          </p>
          <p>
            We're not a marketing company that outsources installations. We hold our own REC Electrical Licence. Our team designs, installs, and supports every system we put in. Your warranty sits with a real brick and mortar business here in Geelong, not a call centre somewhere else.
          </p>
          <p>
            We're not a marketing company that outsources installations. We hold our own REC Electrical Licence. Our team <strong>designs, installs, and supports every system we put in. Your warranty</strong> sits with a real brick and mortar business here in Geelong, not a call centre somewhere else.
          </p>
          <div class="about-photo about-photo--bottom">
            <img src="/image/photos_EESshed/Aboutus_exterior.webp" alt="EES facility and team in Moolap, Geelong" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Team ── -->
  <section class="team-section">
    <div class="container">
      <h2 class="team-heading">The Team</h2>
      <div class="team-grid">
        <div class="team-member">
          <img src="/image/photos_team/DrMarkLuther_clean_transparent.png" alt="Mark B. Luther" loading="lazy" />
          <h3>Mark B. Luther</h3>
          <p class="team-role">Director (Arch.D. - Architect)</p>
          <p>Honorary Professor of Deakin University after 27 years of service. Specialises in Architecture Science and Environmental Technology. Inventor of the Environmental Service Pod and the Autonomatic Hydronic Ceiling Panel.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/LincolnLuther_clean_transparent.png" alt="Lincoln B. Luther" loading="lazy" />
          <h3>Lincoln B. Luther</h3>
          <p class="team-role">Manager of Sales</p>
          <p>Over 4 years industry experience in renewables with a background in Economics, Banking and Finance. Specialises in solar, battery and renewable building services.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/Matthew Ellison_02_clean_transparent.png" alt="Matthew Ellison" loading="lazy" />
          <h3>Matthew Ellison</h3>
          <p class="team-role">Manager of Installations</p>
          <p>Senior electrician experienced in Solar PV and Battery installations in commercial and residential projects. Also involved with electrical research and design on the Environmental Service Pod.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/HungQDo_clean_transparent.png" alt="Hung Q. Do" loading="lazy" />
          <h3>Hung Q. Do</h3>
          <p class="team-role">Research Development</p>
          <p>PhD candidate specialising in hydronic ceiling innovative systems. His research focuses on effective conditioning through hydronic control in commercial buildings.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/placeholder.svg" alt="Pat Sandall" loading="lazy" />
          <h3>Pat Sandall</h3>
          <p class="team-role">Head Electrician, A Grade</p>
          <p>A Grade electrician leading EES field installations across solar, battery, and integrated energy systems for residential and commercial projects.</p>
        </div>
        <div class="team-member">
          <img src="/image/photos_team/placeholder.svg" alt="Caleb Nowson" loading="lazy" />
          <h3>Caleb Nowson</h3>
          <p class="team-role">Business Development Manager</p>
          <p>Manages business development and client relationships, connecting homeowners and businesses with the right energy solutions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Accreditations ── -->
  <section class="accreditations-section">
    <div class="container">
      <p class="section-label" style="text-align: center;">Accreditations</p>
      <h2 class="accreditations-heading">Our Credentials</h2>
      <div class="accreditations-logos">
        <div class="accreditation-logo"><img src="/image/_logos_partners/clean-energy-council-member.webp" alt="Clean Energy Council Member" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/cec-approved-seller.webp" alt="CEC Approved Seller" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/solar-accreditation-australia.webp" alt="Solar Accreditation Australia" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/smart-energy-council.webp" alt="Smart Energy Council" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/tesla-energy-certified.webp" alt="Tesla Energy Certified Installer" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/energy-safe-victoria.webp" alt="Energy Safe Victoria" /></div>
        <div class="accreditation-logo"><img src="/image/_logos_partners/solar-victoria.webp" alt="Solar Victoria" /></div>
        <div class="accreditation-logo accreditation-logo--large"><img src="/image/_logos_partners/enphase.webp" alt="Enphase Silver Installer" /></div>
        <div class="accreditation-logo accreditation-logo--large"><img src="/image/_logos_partners/newenergytech_approvaed seller.webp" alt="New Energy Tech Approved Seller" /></div>
        <div class="accreditation-logo accreditation-logo--medium"><img src="/image/_logos_partners/sigenergy-certified-installer.webp" alt="Sigenergy Certified Installer" /></div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section">
    <div class="container">
      <p>We'd love to show you how we could help with your home or business. Let's have a conversation.</p>
      <a href="/services/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>

<style>
  /* ── Force solid dark nav on white page ── */
  :global(.header-v2::before) {
    background: rgba(14, 43, 71, 0.95) !important;
    border-color: rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  /* ── Top texture banner ── */
  .about-texture {
    width: 100%;
    overflow: hidden;
    line-height: 0;
    background: #fff;
  }

  .about-texture img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* ── Row 1: Hero + Photos (2fr / 1fr) ── */
  .about-row {
    padding: 3rem 0 0;
    background: #fff;
    background-image: url('/image/icon/Brand_wave_dots_darkblue.svg');
    background-repeat: no-repeat;
    background-position: top right;
    background-size: 50% auto;
    opacity: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto 1fr;
    grid-template-areas:
      "heading intro"
      "photo-main photo-secondary";
    gap: 1.5rem 2rem;
  }

  .hero-text {
    grid-area: heading;
    align-self: end;
    padding-bottom: 0.5rem;
  }

  .hero-text .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0E2B47;
    margin-bottom: 0.5rem;
  }

  .hero-text h1 {
    font-size: 2.5rem;
    font-weight: 400;
    color: #0E2B47;
    line-height: 1.2;
    margin: 0;
  }

  .hero-text h1 strong {
    font-weight: 800;
  }

  .about-intro {
    grid-area: intro;
    font-size: 0.95rem;
    color: #555;
    line-height: 1.6;
    max-width: 320px;
    padding-top: 0.25rem;
    align-self: start;
    margin: 0;
  }

  /* ── Photos ── */
  .about-photo {
    border-radius: 12px;
    overflow: hidden;
  }

  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-photo--main {
    grid-area: photo-main;
    min-height: 320px;
  }

  .about-photo--main img {
    aspect-ratio: 4 / 3;
  }

  .about-photo--secondary {
    grid-area: photo-secondary;
    align-self: end;
  }

  .about-photo--secondary img {
    aspect-ratio: 4 / 3;
  }

  .about-photo--bottom {
    margin-top: 2rem;
    max-width: 480px;
  }

  .about-photo--bottom img {
    aspect-ratio: 4 / 3;
  }

  /* ── Row 2: Our Story (flexbox split) ── */
  .story-row {
    padding: 4rem 0;
    background: #fff;
  }

  .story-flex {
    display: flex;
    gap: 3rem;
  }

  .story-left {
    flex: 0 0 40%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 0;
  }

  .story-right {
    flex: 1;
  }

  .story-script {
    font-family: 'Playwrite RO', cursive;
    font-size: 2.5rem;
    font-weight: 400;
    color: #0E2B47;
    line-height: 1.3;
  }

  .story-right p {
    color: #444;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .story-right p strong {
    font-weight: 700;
    color: #0E2B47;
  }

  /* ── Team ── */
  .team-section {
    padding: 5rem 0 4rem;
    background: #f8f9fa;
  }

  .team-heading {
    font-size: 2rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 2rem;
  }

  .team-member {
    text-align: center;
  }

  .team-member img {
    width: 140px;
    height: 140px;
    object-fit: cover;
    object-position: top center;
    border-radius: 50%;
    background: #fff;
    border: 3px solid transparent;
    background-image: linear-gradient(#fff, #fff), linear-gradient(135deg, #C0D446 0%, #e5e7eb 30%, #e5e7eb 100%);
    background-origin: border-box;
    background-clip: padding-box, border-box;
    margin: 0 auto 1rem;
    display: block;
  }

  .team-member h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-size: 0.8rem;
    color: #2061B7;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .team-member > p:last-child {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.6;
  }

  /* ── Accreditations ── */
  .accreditations-section {
    padding: 4rem 0;
    background: #fff;
  }

  .accreditations-heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    color: #0E2B47;
    margin-bottom: 2rem;
  }

  .accreditations-logos {
    display: grid;
    grid-template-columns: repeat(4, auto);
    align-items: center;
    justify-content: center;
    gap: 2.5rem 3rem;
    margin: 0 auto;
  }

  .accreditation-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .accreditation-logo img {
    height: 52px;
    width: auto;
    max-width: none;
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .accreditation-logo--large img {
    height: 85px;
  }

  .accreditation-logo--medium img {
    height: 65px;
  }

  .accreditation-logo img:hover {
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "heading"
        "intro"
        "photo-main"
        "photo-secondary";
      gap: 1.25rem;
    }

    .about-row {
      padding: 2rem 0 0;
      background-size: 80% auto;
    }

    .hero-text h1 {
      font-size: 1.75rem;
    }

    .about-intro {
      max-width: none;
    }

    .about-photo--main {
      min-height: 240px;
    }

    .story-flex {
      flex-direction: column;
      gap: 1.5rem;
    }

    .story-left {
      flex: none;
      justify-content: flex-start;
      padding: 0;
    }

    .story-script {
      font-size: 2rem;
    }

    .story-row {
      padding: 3rem 0;
    }

    .about-photo--bottom {
      max-width: none;
    }

    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .accreditations-logos {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      max-width: 500px;
    }
  }

  @media (max-width: 500px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
