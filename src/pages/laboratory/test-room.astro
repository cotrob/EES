---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import HugeIcon from '../../components/HugeIcon.astro';
import {
  ThermometerIcon,
  EnergyIcon,
  GridIcon,
  CpuSettingsIcon,
  PipelineIcon,
  TestTubeIcon,
} from '@hugeicons/core-free-icons';
---

<BaseLayout
  title="Simulation Test Room | EES"
  description="Our purpose-built TestCell for real-world hydronic ceiling panel testing. Full-scale simulation room with ASHRAE-55 and ISO 7730 instrumentation, built and operated in-house at our Geelong facility."
>
  <!-- Page Header with Hero Image -->
  <section class="page-header page-header--hero">
    <img src="/image/WIP/TestRoom_Development_webp/308748357_831370331371037_4396639554076040798_n.webp" alt="EES simulation test room facility with hydronic system equipment and test cell structure" loading="eager" class="page-header__bg" />
    <div class="page-header__overlay">
      <div class="container">
        <h1>Simulation Test Room</h1>
        <p>Purpose-built to prove our hydronic ceiling systems under real-world conditions.</p>
      </div>
    </div>
  </section>

  <!-- Drone Footage Section -->
  <section class="section drone-section">
    <div class="container">
      <div class="drone-layout">
        <div class="drone-video-wrapper">
          <video autoplay muted loop playsinline preload="auto" poster="/image/WIP/TestRoom_Development_webp/testroom-aerial-facility.webp">
            <source src="/image/video/Timeline 1.webm" type="video/webm" />
            Your browser does not support the video tag.
          </video>
          <div class="drone-placeholder-badge">
            <span>Drone footage in production</span>
          </div>
        </div>
        <div class="drone-text">
          <p class="section-label">Facility Overview</p>
          <h2>Built From the Ground Up</h2>
          <p>The facility houses our simulation test room, open-air test rigs, panel manufacturing area, hydraulic assembly station, and instrumentation lab. All under one roof.</p>
          <p>We built this facility because the products we develop don't exist anywhere else. There's no off-the-shelf test lab for hydronic ceiling panels. If we wanted real performance data under real conditions, we had to build the testing infrastructure ourselves.</p>
          <p>Drone footage of the full facility is currently being captured and will replace this video.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Workshop -->
  <section class="section workshop-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">The Workshop</p>
        <h2>Where Research <span class="h2-light">Meets Manufacturing</span></h2>
        <p class="section-desc">The facility operates as both a research laboratory and a production workshop. Products are designed, prototyped, tested, refined, and manufactured in the same space.</p>
      </div>

      <div class="workshop-grid">
        <div class="workshop-card workshop-card--wide">
          <div class="workshop-card-text">
            <h3>Main Workshop Floor</h3>
            <p>The central workspace houses the Environmental Service Pod, panel assembly stations, and the open-air test rig. Equipment is arranged for rapid iteration between design changes and test runs.</p>
          </div>
          <img src="/image/WIP/TestRoom_Development_webp/308748357_831370331371037_4396639554076040798_n.webp" alt="Wide view of the EES workshop showing the Environmental Service Pod equipment rack, open-air test rig frame, and thermal imaging station" />
        </div>
        <div class="workshop-card">
          <div class="workshop-card-text">
            <h3>Environmental Service Pod</h3>
            <p>The full-scale ESP prototype sits on the workshop floor. Water storage, battery modules, heat exchanger, and a canopy-mounted ceiling panel rig for open-air thermal testing.</p>
          </div>
          <img src="/image/WIP/TestRoom_Development_webp/IMG-0997.webp" alt="Environmental Service Pod equipment rack with hot and cold water storage tanks, battery modules, and canopy-mounted ceiling panel frame inside the warehouse" />
        </div>
        <div class="workshop-card">
          <div class="workshop-card-text">
            <h3>Open-Air Test Rig</h3>
            <p>A steel-framed overhead rig holds ceiling panels at working height for thermal testing, flow balancing, and instrumentation calibration before panels move to the enclosed TestCell.</p>
          </div>
          <img src="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-piping-test-equipment.webp" alt="Wider view of the workshop showing the overhead test rig with connected ceiling panels and the ESP equipment rack beneath" />
        </div>
      </div>
    </div>
  </section>

  <!-- The TestCell Build Story -->
  <div class="testcell-group">
    <div class="diagonal-divider" style="background: #fff;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#0E2B47" />
      </svg>
    </div>

    <section class="testcell-section">
      <div class="container">
        <div class="testcell-intro">
          <div class="testcell-intro-text">
            <p class="section-label section-label--light">The Simulation Test Room</p>
            <h2>A Real Room Built for Real Testing</h2>
            <p>The TestCell is a full-scale, instrumented room constructed inside the workshop. It's not a sealed laboratory chamber. It's built to behave like a real occupied space, with solar gain through glass, ventilation, and thermal mass. That's the point: we test under the same conditions our products will face in the field.</p>
            <p>Every element was designed and constructed in-house: steel framing, insulation, glazing, ceiling grid, plumbing, and instrumentation. The room is aligned to ASHRAE-55 and ISO 7730 testing standards.</p>
          </div>
          <div class="testcell-specs">
            <div class="testcell-spec">
              <span class="testcell-spec-value">3.6 x 4.8m</span>
              <span class="testcell-spec-label">Floor Area</span>
            </div>
            <div class="testcell-spec">
              <span class="testcell-spec-value">3.0m</span>
              <span class="testcell-spec-label">Ceiling Height</span>
            </div>
            <div class="testcell-spec">
              <span class="testcell-spec-value">7.5m²</span>
              <span class="testcell-spec-label">North-Facing Glass</span>
            </div>
            <div class="testcell-spec">
              <span class="testcell-spec-value">R2.0</span>
              <span class="testcell-spec-label">Wall Insulation</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="diagonal-divider" style="background: #0E2B47;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#fff" />
      </svg>
    </div>
  </div>

  <!-- TestCell Build Timeline -->
  <section class="section build-story">
    <div class="container">
      <div class="section-header">
        <p class="section-label">The Build</p>
        <h2>How We Built <span class="h2-light">the TestCell</span></h2>
        <p class="section-desc">From steel studs to a fully instrumented simulation room. Every element was designed and constructed in-house.</p>
      </div>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">1</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images">
              <img src="/image/WIP/TestRoom_Development_webp/db40c3a0-63a3-484b-ae40-10b1c7887877.webp" alt="Steel stud framing of the TestCell structure inside the EES workshop showing wall and ceiling framework" loading="lazy" />
            </div>
            <h3>Steel Frame Construction</h3>
            <p>The room was framed from steel studs to Australian Standard specifications. A permanent structure with proper wall and ceiling framing, not a temporary enclosure or a tent.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">2</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images timeline-images--double">
              <img src="/image/WIP/TestRoom_Final_webp/testroom-external-facility.webp" alt="Elevated view of the TestCell wrapped in blue building membrane inside the workshop, with scissor lift and construction materials visible" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/testroom-interior-truss-structure.webp" alt="Looking up inside the workshop at the steel truss roof structure and corrugated wall cladding above the TestCell" loading="lazy" />
            </div>
            <h3>Envelope and Membrane</h3>
            <p>Building wrap membrane applied over the full structure. The room sits inside the larger workshop but is thermally isolated from it, behaving as an independent building envelope for testing purposes.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">3</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images timeline-images--double">
              <img src="/image/WIP/TestRoom_Development_webp/testroom-double-glazed-window.webp" alt="Commercial-grade double-glazed window unit installed in the north wall of the TestCell, showing insulation batts and steel framing" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/testroom-window-insulation-detail.webp" alt="Close-up of window frame insulation detail showing fibreglass batts packed around the glazing unit and steel stud framing" loading="lazy" />
            </div>
            <h3>Glazing and Insulation</h3>
            <p>A 7.5m² commercial-grade double-glazed window was installed on the north face to simulate worst-case solar gain. R2.0 batt insulation throughout all walls. The window is the most thermally challenging element in any real building, so we built around one.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">4</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images timeline-images--double">
              <img src="/image/WIP/TestRoom_Development_webp/269722110_2110682989094831_8008561485059951530_n.webp" alt="Worker installing underfloor hydronic heating mats inside the TestCell, blue capillary tubes visible across the floor" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/230776749_2606143206347473_1221053032294569180_n.webp" alt="Underfloor capillary tube mats being laid across the TestCell floor with cardboard protection and worker in high-vis" loading="lazy" />
            </div>
            <h3>Underfloor Conditioning</h3>
            <p>Hydronic capillary tube mats were installed beneath the floor surface. This allows the TestCell to test both ceiling panel and underfloor radiant systems independently, or simultaneously, under identical conditions.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">5</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images timeline-images--double">
              <img src="/image/WIP/TestRoom_Development_webp/IMG_7797.webp" alt="Hydronic ceiling panels installed in the TestCell suspended ceiling grid with blue capillary tubes visible from below before finishing surfaces are applied" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/IMG_7910.webp" alt="Finished ceiling inside the TestCell showing multiple architectural surface finishes including perforated metal, plasterboard, and rendered coating" loading="lazy" />
            </div>
            <h3>Ceiling Panel Installation</h3>
            <p>Hydronic ceiling panels were installed into the standard 600 x 1200mm suspended ceiling grid. The ceiling is divided into bays, each fitted with a different architectural finish, allowing direct comparison of surface performance under identical conditions.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">6</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images timeline-images--triple">
              <img src="/image/WIP/TestRoom_Development_webp/plumbing-full.webp" alt="Assembled hydronic plumbing manifold with 24V DC pumps, switching actuators, mixing valves, and pressure tanks" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/IMG_6357.webp" alt="Hydronic manifold close-up showing individual circuit flow meters, isolation valves, and PPR pipe connections" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/1.webp" alt="Multiple ceiling panels plumbed together on a workbench for system-level flow testing before installation" loading="lazy" />
            </div>
            <h3>Plumbing and Hydraulics</h3>
            <p>PPR piping with brass fittings connects each panel to the central manifold. Flow meters on every circuit allow individual panel monitoring and balancing. The entire hydraulic system runs on 24V DC for safety.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="timeline-number">7</span>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-images timeline-images--double">
              <img src="/image/WIP/TestRoom_Development_webp/IMG_0025.webp" alt="Exterior of the completed TestCell showing blue building membrane, black hydraulic piping, green water tank, and the entrance doorway into the lit interior" loading="lazy" />
              <img src="/image/WIP/TestRoom_Development_webp/IMG_0027.webp" alt="Looking through the open doorway into the completed TestCell showing finished walls, timber floor, comfort cart, thermal camera on tripod, and instrumentation cabling overhead" loading="lazy" />
            </div>
            <h3>Completed and Commissioned</h3>
            <p>The finished TestCell: a fully enclosed, instrumented room with timber flooring, finished walls, suspended ceiling, and full environmental monitoring. Hydraulic equipment and water storage sit immediately outside the room for short pipe runs and minimal thermal losses.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inside the TestCell -->
  <section class="section interior-section">
    <div class="container">
      <div class="interior-layout">
        <div class="interior-image">
          <img src="/image/WIP/TestRoom_Development_webp/IMG_7928.webp" alt="Researcher seated inside the TestCell monitoring live data on laptop and desktop screens, with hydronic ceiling panels active overhead and the north-facing window providing natural daylight" />
        </div>
        <div class="interior-text">
          <p class="section-label">Inside the TestCell</p>
          <h2>A Space Designed to Be Occupied</h2>
          <p>The TestCell isn't just measured from outside. It's occupied during testing. Researchers sit inside the room while systems run, monitoring live data streams on screens positioned at the desk.</p>
          <p>This matters because the room was built to replicate real conditions. Sunlight enters through the north-facing glass. Air moves naturally. The floor, walls and ceiling interact thermally, exactly as they would in a real building. The data captured here reflects how people will actually experience the system.</p>
        </div>
      </div>

      <div class="interior-detail-grid">
        <div class="interior-detail">
          <img src="/image/WIP/TestRoom_Development_webp/IMG_7975.webp" alt="Interior of the TestCell looking toward the north-facing window with roller blinds drawn, desk and chair in position, and ASHRAE comfort cart visible at right" />
          <span>North-facing window with roller blinds for solar gain control</span>
        </div>
        <div class="interior-detail">
          <img src="/image/WIP/TestRoom_Development_webp/ceiling-panels-labeled.webp" alt="TestCell ceiling divided into bays with five different architectural finishes: adhesive vinyl, rendered coating, perforated metal, mini-orb, and plasterboard" />
          <span>Ceiling divided into bays with different architectural finishes</span>
        </div>
        <div class="interior-detail">
          <img src="/image/WIP/TestRoom_Final_webp/testroom-aerial-solar-panels.webp" alt="Aerial view of the facility roof showing the solar panel array that powers the TestCell and workshop operations" />
          <span>Rooftop solar array powers the facility and test systems</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Instrumentation -->
  <div class="instrumentation-group">
    <div class="diagonal-divider" style="background: #fff;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#0E2B47" />
      </svg>
    </div>

    <section class="instrumentation-section">
      <div class="container">
        <div class="section-header section-header--light">
          <p class="section-label section-label--light">Instrumentation</p>
          <h2>What We Measure</h2>
          <p class="section-desc section-desc--light">Professional-grade environmental monitoring aligned to international thermal comfort and building performance standards.</p>
        </div>

        <div class="instrument-grid">
          <div class="instrument-card">
            <img src="/image/WIP/TestRoom_Final_webp/IMG_7953.webp" alt="Avio thermal imaging camera mounted on a Manfrotto tripod, positioned to capture ceiling panel surface temperature distribution" />
            <div class="instrument-info">
              <h3>Thermal Imaging Camera</h3>
              <p>Avio infrared camera captures real-time surface temperature maps of the ceiling, walls, and floor. Used to verify uniform heat distribution and identify thermal bridging.</p>
            </div>
          </div>
          <div class="instrument-card">
            <img src="/image/WIP/TestRoom_Development_webp/278089988_1024252955112112_2213671243500220494_n.webp" alt="ASHRAE-55 thermal comfort cart with vertical sensor array measuring air temperature at multiple heights from floor to ceiling" />
            <div class="instrument-info">
              <h3>ASHRAE-55 Comfort Cart</h3>
              <p>Measures operative temperature and air temperature stratification at multiple heights. The standard method for evaluating whether a space meets human thermal comfort requirements.</p>
            </div>
          </div>
          <div class="instrument-card">
            <img src="/image/WIP/TestRoom_Development_webp/sensor-.webp" alt="Environmental sensor array with probes for air temperature, humidity, and velocity measurement positioned inside the TestCell" />
            <div class="instrument-info">
              <h3>Environmental Sensors</h3>
              <p>Air temperature, humidity, and velocity probes distributed throughout the room. Continuous logging captures how conditions change over time and respond to system inputs.</p>
            </div>
          </div>
          <div class="instrument-card">
            <img src="/image/WIP/TestRoom_Development_webp/IMG_7223.webp" alt="Heat flux sensors, thermocouples, and data logger on a workbench showing the calibration and wiring process for surface energy measurement" />
            <div class="instrument-info">
              <h3>Heat Flux Sensors</h3>
              <p>Calibrated sensors bonded to panel surfaces quantify radiative and conductive energy transfer in W/m². This is how we measure actual thermal output, not just temperature.</p>
            </div>
          </div>
        </div>

        <div class="standards-bar">
          <div class="standard-item">
            <span class="standard-name">ASHRAE Standard 55</span>
            <span class="standard-desc">Thermal Environmental Conditions for Human Occupancy</span>
          </div>
          <div class="standard-item">
            <span class="standard-name">ISO 7730</span>
            <span class="standard-desc">Ergonomics of the Thermal Environment</span>
          </div>
        </div>
      </div>
    </section>

    <div class="diagonal-divider" style="background: #0E2B47;">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="0,0 0,120 1440,120" fill="#f8f9fa" />
      </svg>
    </div>
  </div>

  <!-- Thermal Results Preview -->
  <section class="section thermal-preview">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Measured Results</p>
        <h2>Thermal Imaging <span class="h2-light">From the TestCell</span></h2>
        <p class="section-desc">Infrared imaging confirms uniform surface temperature distribution across ceiling panels in both heating and cooling modes.</p>
      </div>

      <div class="thermal-grid">
        <div class="thermal-card">
          <div class="thermal-img-wrap">
            <img src="/image/WIP/TestRoom_Development_webp/thermal-heating-full.webp" alt="Thermal image of ceiling panels in heating mode showing uniform warm surface temperatures at 27.6 degrees in red and orange tones" />
          </div>
          <div class="thermal-info">
            <span class="thermal-mode thermal-mode--heat">Heating Mode 27.6°C</span>
            <p>Even red/orange distribution confirms uniform heat delivery with no cold spots at joints or edges.</p>
          </div>
        </div>
        <div class="thermal-card">
          <div class="thermal-img-wrap">
            <img src="/image/WIP/TestRoom_Development_webp/thermal-cooling-full.webp" alt="Thermal image of ceiling panels in cooling mode showing uniform cool surface temperatures at 14.4 degrees in blue and green tones" />
          </div>
          <div class="thermal-info">
            <span class="thermal-mode thermal-mode--cool">Cooling Mode 14.4°C</span>
            <p>Blue thermal signature shows effective cooling across all panel surfaces with no warm spots or condensation risk.</p>
          </div>
        </div>
      </div>

      <div class="thermal-monitor-layout">
        <div class="thermal-monitor-image">
          <img src="/image/WIP/Hydronic_Ceiling_Panels/panel-thermal-imaging-monitor.webp" alt="Monitor displaying live Avio thermal camera feed showing green and blue heat map of ceiling panel surface temperatures during a cooling test" />
        </div>
        <div class="thermal-monitor-image">
          <img src="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-thermal-comparison-abc.webp" alt="Three-panel thermal comparison labeled A, B, and C from the Avio camera showing different ceiling panel configurations under heating test conditions" />
        </div>
      </div>

      <div class="thermal-link">
        <p>Detailed performance data, heat flux graphs, and surface temperature results are documented on our <a href="/laboratory/hydronic-ceiling-panels">Hydronic Ceiling Panels</a> page.</p>
      </div>
    </div>
  </section>

  <!-- Open-Air Test Rig -->
  <section class="section testrig-section">
    <div class="container">
      <div class="testrig-layout">
        <div class="testrig-text">
          <p class="section-label">Open-Air Testing</p>
          <h2>The Overhead Test Rig</h2>
          <p>Before panels enter the TestCell, they go through the open-air test rig, a steel-framed platform suspended at ceiling height in the main workshop.</p>
          <p>This rig is used for pressure testing, flow balancing, leak detection, and preliminary thermal output measurement. Panels are connected to the full hydraulic system and run under load before any instrumented room testing begins.</p>
          <p>It's also where we test new panel configurations, finishing surfaces, and connection methods at full scale without disrupting a controlled test cycle in the TestCell.</p>
        </div>
        <div class="testrig-images">
          <img src="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-test-rig-warehouse.webp" alt="Overhead test rig in the EES workshop showing ceiling panels mounted on a steel frame at height with blue capillary tube connections and the warehouse roof structure above" />
          <img src="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-overhead-thermal-camera-setup.webp" alt="Thermal imaging camera on tripod pointed upward at ceiling panels mounted in the test rig, capturing surface temperature data during an active heating test" class="testrig-image-secondary" />
        </div>
      </div>
    </div>
  </section>

  <!-- What We Test -->
  <section class="section capabilities-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Capabilities</p>
        <h2>What We Test <span class="h2-light">Here</span></h2>
        <p class="section-desc">The facility supports the full development cycle, from early prototyping through to validated performance data ready for publication.</p>
      </div>

      <div class="capabilities-grid">
        <div class="capability-card">
          <HugeIcon icon={ThermometerIcon} size={32} class="capability-icon" />
          <h3>Thermal Comfort Evaluation</h3>
          <p>Full ASHRAE-55 comfort assessment in heating and cooling modes. Operative temperature, air stratification, and radiant asymmetry measured continuously throughout each test cycle.</p>
        </div>
        <div class="capability-card">
          <HugeIcon icon={EnergyIcon} size={32} class="capability-icon" />
          <h3>Energy Performance</h3>
          <p>Heat flux measurement, system COP tracking, and energy consumption logging under controlled and real-world conditions. Data is used to benchmark our products against published performance standards.</p>
        </div>
        <div class="capability-card">
          <HugeIcon icon={GridIcon} size={32} class="capability-icon" />
          <h3>Panel Surface Comparison</h3>
          <p>Side-by-side comparison of different architectural finishes under identical conditions. The TestCell ceiling is divided into bays, each with a different surface, allowing direct thermal output comparison.</p>
        </div>
        <div class="capability-card">
          <HugeIcon icon={CpuSettingsIcon} size={32} class="capability-icon" />
          <h3>Control System Development</h3>
          <p>Real-time tuning of control algorithms using live sensor data. The facility allows rapid iteration between software changes and measured comfort outcomes.</p>
        </div>
        <div class="capability-card">
          <HugeIcon icon={PipelineIcon} size={32} class="capability-icon" />
          <h3>Hydraulic System Validation</h3>
          <p>Flow balancing, pressure testing, and leak detection across complete plumbing assemblies. Every manifold, actuator, and circuit is validated before it leaves the workshop.</p>
        </div>
        <div class="capability-card">
          <HugeIcon icon={TestTubeIcon} size={32} class="capability-icon" />
          <h3>Third-Party Testing</h3>
          <p>The facility is available for independent testing of external products and systems. If you need thermal performance data in a controlled, instrumented environment, we can accommodate your requirements.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Want to see the facility?</h2>
        <p>We welcome visits from architects, engineers, researchers, and building professionals. We also offer third-party testing services for products that require thermal performance validation.</p>
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>

<style>
  /* Page Header Hero */
  .page-header--hero {
