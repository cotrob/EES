---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Commercial Solar Installation Gallery | EES Geelong"
  description="Browse our commercial solar installation gallery. See real business and industrial solar systems installed across Geelong and regional Victoria by EES."
>
  <section class="gallery-hero">
    <div class="container">
      <p class="gallery-label">Gallery</p>
      <h1>Commercial <span class="h1-light">Installations</span></h1>
      <p class="gallery-desc">A selection of our commercial and industrial solar installations across Victoria.</p>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">

      <!-- Bento Grid 1 -->
      <div class="bento-grid">
