---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  dark?: boolean;
}

const { stats, dark = false } = Astro.props;
---

<section class={`stat-bar ${dark ? 'stat-bar--dark' : ''}`}>
  <div class="container">
    <div class="stat-row">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
