<style>
  .gallery-hero {
    background: #0E2B47;
    padding: 8rem 0 4rem;
    text-align: center;
  }

  .gallery-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #5ba3e6;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .gallery-hero h1 {
    font-size: 3rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .h1-light {
    font-weight: 300;
    opacity: 0.8;
  }

  .gallery-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .gallery-section {
    background: #f8f9fa;
    padding: 4rem 0 3rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Bento Grid ── */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: auto auto;
    gap: 0.75rem;
    max-width: 1100px;
    margin: 0 auto 0.75rem;
  }

  .bento-item {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .bento-item:nth-child(1) { grid-column: 1; grid-row: 1; }
  .bento-item:nth-child(2) { grid-column: 2; grid-row: 1; }
  .bento-item:nth-child(3) { grid-column: 3 / 5; grid-row: 1; }
  .bento-item:nth-child(4) { grid-column: 1; grid-row: 2; }
  .bento-item:nth-child(5) { grid-column: 2 / 4; grid-row: 2; }
  .bento-item:nth-child(6) { grid-column: 4; grid-row: 2; }

  .bento-grid-alt .bento-item:nth-child(1) { grid-column: 1; grid-row: 1; }
  .bento-grid-alt .bento-item:nth-child(2) { grid-column: 2 / 4; grid-row: 1; }
  .bento-grid-alt .bento-item:nth-child(3) { grid-column: 4; grid-row: 1; }
  .bento-grid-alt .bento-item:nth-child(4) { grid-column: 1 / 3; grid-row: 2; }
  .bento-grid-alt .bento-item:nth-child(5) { grid-column: 3; grid-row: 2; }
  .bento-grid-alt .bento-item:nth-child(6) { grid-column: 4; grid-row: 2; }

  .bento-grid-alt2 .bento-item:nth-child(1) { grid-column: 1; grid-row: 1; }
  .bento-grid-alt2 .bento-item:nth-child(2) { grid-column: 2 / 4; grid-row: 1; }
  .bento-grid-alt2 .bento-item:nth-child(3) { grid-column: 4; grid-row: 1; }
  .bento-grid-alt2 .bento-item:nth-child(4) { grid-column: 1; grid-row: 2; }
  .bento-grid-alt2 .bento-item:nth-child(5) { grid-column: 2 / 4; grid-row: 2; }
  .bento-grid-alt2 .bento-item:nth-child(6) { grid-column: 4; grid-row: 2; }

  .bento-grid-extra .bento-item:nth-child(1) { grid-column: 1; grid-row: 1; }
  .bento-grid-extra .bento-item:nth-child(2) { grid-column: 2; grid-row: 1; }
  .bento-grid-extra .bento-item:nth-child(3) { grid-column: 3 / 5; grid-row: 1; }
  .bento-grid-extra .bento-item:nth-child(4) { grid-column: 1 / 3; grid-row: 2; }
  .bento-grid-extra .bento-item:nth-child(5) { grid-column: 3; grid-row: 2; }
  .bento-grid-extra .bento-item:nth-child(6) { grid-column: 4; grid-row: 2; }

  .bento-item img,
  .bento-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 1 / 1;
  }

  .bento-wide-top img,
  .bento-wide-top video,
  .bento-wide-bottom img,
  .bento-wide-bottom video {
    aspect-ratio: auto;
    height: 100%;
  }

  .bento-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      transparent 65%
    );
    display: flex;
    flex-direction: column;
    padding: 1rem 1.15rem;
    pointer-events: none;
    transition: background 0.4s ease;
  }

  .bento-content {
    display: flex;
    flex-direction: column;
    margin-top: auto;
    transition: margin-top 0.4s ease;
  }

  .bento-item:hover .bento-overlay,
  .bento-item.is-active .bento-overlay {
    background: rgba(0, 15, 30, 0.82);
    pointer-events: auto;
  }

  .bento-item:hover .bento-content,
  .bento-item.is-active .bento-content {
    margin-top: 0;
  }

  .bento-details {
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 0.35s ease 0.1s, max-height 0.35s ease 0.1s;
  }

  .bento-item:hover .bento-details,
  .bento-item.is-active .bento-details {
    opacity: 1;
    max-height: 250px;
  }

  .bento-details ul {
    list-style: none;
    padding: 0;
    margin: 0.6rem 0 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .bento-details ul li {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
    padding-left: 0.85rem;
    position: relative;
    line-height: 1.4;
  }

  .bento-details ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4em;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
  }

  .bento-details p {
    font-size: 0.9rem;
