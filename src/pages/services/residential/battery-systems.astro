---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import IconFeatureGrid from '../../../components/sections/IconFeatureGrid.astro';
import ProcessTimeline from '../../../components/sections/ProcessTimeline.astro';
import FaqGroup from '../../../components/sections/FaqGroup.astro';
import ServiceHero from '../../../components/sections/ServiceHero.astro';
import { hugeIconToSvg } from '../../../lib/hugeicon-svg';
import HugeIcon from '../../../components/HugeIcon.astro';
import CallIcon from '@hugeicons/core-free-icons/CallIcon';
import Search01Icon from '@hugeicons/core-free-icons/Search01Icon';
import CompassIcon from '@hugeicons/core-free-icons/CompassIcon';
import ClipboardIcon from '@hugeicons/core-free-icons/ClipboardIcon';
import CheckmarkBadge01Icon from '@hugeicons/core-free-icons/CheckmarkBadge01Icon';
import SmartPhone01Icon from '@hugeicons/core-free-icons/SmartPhone01Icon';
import Certificate01Icon from '@hugeicons/core-free-icons/Certificate01Icon';
import Sun01Icon from '@hugeicons/core-free-icons/Sun01Icon';
import Home01Icon from '@hugeicons/core-free-icons/Home01Icon';
import BatteryFullIcon from '@hugeicons/core-free-icons/BatteryFullIcon';
import BatteryCharging01Icon from '@hugeicons/core-free-icons/BatteryCharging01Icon';
import ElectricTower01Icon from '@hugeicons/core-free-icons/ElectricTower01Icon';
import ArrowRight01Icon from '@hugeicons/core-free-icons/ArrowRight01Icon';
import Layers01Icon from '@hugeicons/core-free-icons/Layers01Icon';
import ZapIcon from '@hugeicons/core-free-icons/ZapIcon';
import ShieldEnergyIcon from '@hugeicons/core-free-icons/ShieldEnergyIcon';
import ArrowDownRight01Icon from '@hugeicons/core-free-icons/ArrowDownRight01Icon';
---

<BaseLayout
  title="Solar Battery Storage Geelong | Prices, Rebates & Installation | EES"
  description="Home battery storage systems in Geelong. Solar battery prices, Victorian rebates, and expert installation by CEC-accredited team. Back-to-base monitoring on every system."
>
  <ServiceHero
    title="Residential Battery Systems"
    illustration="/image/illustrations/Residential  Battery Systems.png"
    illustrationAlt="Home battery storage system illustration"
  />


  <!-- Intro: Why add a battery -->
  <section class="approach-section">
    <div class="container">
      <div class="approach-layout">
        <div class="approach-heading">
          <p class="section-label">Why Add a Battery</p>
          <h2>Stop Giving Your<br />Solar Away<br />for 1 Cent</h2>
          <div class="approach-arrow">
            <HugeIcon icon={ArrowDownRight01Icon} />
          </div>
        </div>
        <div class="approach-text">
          <p>
            Without a battery, your solar panels export excess electricity to the grid during the day. The feed in tariff you get paid for that? It's barely one cent per kilowatt hour. Then at night, when you're cooking dinner, charging the car, or running the heater, you buy power back from the grid at 30 cents or more.
          </p>
          <p>
            A battery changes that equation completely. Instead of sending your solar to the grid for next to nothing, you store it. Then at night, your home draws from the battery first. Your electric vehicle charges from the battery. Your induction cooktop runs from the battery. Your heater runs from the battery.
          </p>
          <p>
            The result is simple: <strong>you use more of your own solar</strong>, buy less from the grid, and get a much better return on every panel on your roof.
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .approach-section {
      padding: 8rem 0 4rem;
      background: #fff;
    }

    .approach-layout {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3.5rem;
      align-items: start;
      max-width: 1000px;
      margin: 0 auto;
    }

    .approach-heading {
      position: relative;
      padding-right: 80px;
      text-align: right;
    }

    .approach-heading h2 {
      margin-bottom: 0;
    }

    .approach-arrow {
      position: absolute;
      top: 0;
      right: 0;
      width: 50px;
      height: 50px;
      background: #C2D456;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #0E2B47;
      opacity: 0;
      transform: scale(0.5);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .approach-arrow.animate-in {
      opacity: 1;
      transform: scale(1);
    }

    .approach-arrow :global(svg) {
      width: 33px;
      height: 33px;
      stroke-width: 3;
      opacity: 0;
      transform: translate(-8px, -8px);
      transition: opacity 0.35s ease 0.3s, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;
    }

    .approach-arrow.animate-in :global(svg) {
      opacity: 1;
      transform: translate(0, 0);
    }

    .approach-text p {
      font-size: 0.95rem;
      color: #555;
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    @media (max-width: 768px) {
      .approach-layout {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }

      .approach-heading {
        padding-right: 0;
        text-align: center;
      }

      .approach-heading h2 {
        display: inline;
      }

      .approach-arrow {
        position: relative;
        top: auto;
        right: auto;
        display: inline-flex;
        vertical-align: top;
        margin-left: 0.5rem;
      }
    }
  </style>

  <script>
    const arrow = document.querySelector('.approach-arrow');
    if (arrow) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { arrow.classList.add('animate-in'); obs.disconnect(); } });
      }, { threshold: 0.5 });
      obs.observe(arrow);
    }
  </script>


  <!-- How it works: energy flow -->
  <section class="energy-flow-section">
    <div class="container">
      <p class="section-label">How It Works</p>
      <h2>Where Your Energy Goes</h2>

      <svg width="0" height="0" style="position:absolute;">
        <defs>
          <linearGradient id="icon-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#C0D446" />
            <stop offset="100%" stop-color="#2061B7" />
          </linearGradient>
        </defs>
      </svg>

      <div class="flow-steps">
        <div class="flow-step">
          <div class="flow-icon">
            <HugeIcon icon={Sun01Icon} gradient="icon-gradient" />
          </div>
          <h3>Solar generates</h3>
          <p>Panels produce electricity during the day.</p>
        </div>
        <div class="flow-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="flow-step">
          <div class="flow-icon">
            <HugeIcon icon={Home01Icon} gradient="icon-gradient" />
          </div>
          <h3>Home uses first</h3>
          <p>Everything running in your home gets powered first.</p>
        </div>
        <div class="flow-arrow">
          <HugeIcon icon={ArrowRight01Icon} />
        </div>
        <div class="flow-step">
          <div class="flow-icon">
            <HugeIcon icon={BatteryFullIcon} gradient="icon-gradient" />
          </div>
          <h3>Battery stores the rest</h3>
          <p>Excess solar charges the battery for tonight.</p>
        </div>
        <div class="flow-arrow flow-arrow--dotted">
          <svg width="28" height="24" viewBox="0 0 28 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 12h18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="4 4"/>
            <path d="M18 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
        <div class="flow-step">
          <div class="flow-icon">
            <HugeIcon icon={ElectricTower01Icon} gradient="icon-gradient" />
          </div>
          <h3>Grid gets the leftovers</h3>
          <p>Only once the battery is full does anything go to the grid.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .energy-flow-section {
      padding: 5rem 0;
      background: #f8f9fa;
    }

    .energy-flow-section .section-label,
    .energy-flow-section h2 {
      text-align: center;
    }

    .energy-flow-section h2 {
      margin-bottom: 3rem;
    }

    .flow-steps {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0.75rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .flow-step {
      text-align: center;
      flex: 1;
      max-width: 200px;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .flow-step--faded .flow-icon {
      opacity: 0.45;
    }

    .flow-step--faded h3,
    .flow-step--faded p {
      opacity: 0.45;
    }

    .flow-icon {
      width: 48px;
      height: 48px;
      margin: 0 auto 1rem;
    }

    .flow-icon :global(svg) {
      width: 100%;
      height: 100%;
    }

    .flow-step h3 {
      font-size: 0.95rem;
      color: #0E2B47;
      margin-bottom: 0.4rem;
    }

    .flow-step p {
      font-size: 0.85rem;
      color: #555;
      line-height: 1.5;
    }

    .flow-arrow {
      width: 28px;
      flex-shrink: 0;
      color: #2061B7;
      margin-top: 0.5rem;
      transform: rotateY(180deg);
      opacity: 0;
      transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .flow-arrow--dotted {
      color: #9bb0c7;
    }

    .flow-arrow svg {
      width: 100%;
      height: auto;
    }

    @keyframes arrow-pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.5); }
      100% { transform: scale(1.3); }
    }

    /* Staggered flip-in */
    :global(.flow-steps.in-view) .flow-step:nth-child(1) { transition-delay: 0s; transform: rotateY(0); opacity: 1; }
    :global(.flow-steps.in-view) > :nth-child(2) { transition-delay: 0.15s; transform: rotateY(0); opacity: 1; }
    :global(.flow-steps.in-view) .flow-step:nth-child(3) { transition-delay: 0.3s; transform: rotateY(0); opacity: 1; }
    :global(.flow-steps.in-view) > :nth-child(4) { transition-delay: 0.45s; transform: rotateY(0); opacity: 1; }
    :global(.flow-steps.in-view) .flow-step:nth-child(5) { transition-delay: 0.6s; transform: rotateY(0); opacity: 1; }
    :global(.flow-steps.in-view) > :nth-child(6) { transition-delay: 0.75s; transform: rotateY(0); opacity: 1; }
    :global(.flow-steps.in-view) .flow-step:nth-child(7) { transition-delay: 0.9s; transform: rotateY(0); opacity: 1; }

    /* Arrows pulse after all flips finish */
    :global(.flow-steps.in-view) > :nth-child(2) { animation: arrow-pulse 0.35s ease 1.5s forwards; }
    :global(.flow-steps.in-view) > :nth-child(4) { animation: arrow-pulse 0.35s ease 1.65s forwards; }
    :global(.flow-steps.in-view) > :nth-child(6) { animation: arrow-pulse 0.35s ease 1.8s forwards; }

    @media (max-width: 768px) {
      .flow-steps {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .flow-step {
        max-width: 300px;
      }

      .flow-arrow {
        transform: rotateY(180deg) rotate(90deg);
        width: 24px;
        margin: 0;
      }

      @keyframes arrow-pulse-mobile {
        0% { transform: rotate(90deg) scale(1); }
        50% { transform: rotate(90deg) scale(1.5); }
        100% { transform: rotate(90deg) scale(1.3); }
      }

      :global(.flow-steps.in-view) > .flow-arrow { transform: rotateY(0) rotate(90deg); opacity: 1; }
      :global(.flow-steps.in-view) > :nth-child(2) { animation: arrow-pulse-mobile 0.35s ease 1.5s forwards; }
      :global(.flow-steps.in-view) > :nth-child(4) { animation: arrow-pulse-mobile 0.35s ease 1.65s forwards; }
      :global(.flow-steps.in-view) > :nth-child(6) { animation: arrow-pulse-mobile 0.35s ease 1.8s forwards; }
    }
  </style>

  <script>
    const flow = document.querySelector('.flow-steps');
    if (flow) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { flow.classList.add('in-view'); observer.disconnect(); } });
      }, { threshold: 0.3 });
      observer.observe(flow);
    }
  </script>


  <!-- Guarantees -->
  <section class="guarantees-section">
    <div class="guarantees-section__slant"></div>
    <div class="guarantees-section__texture"></div>
    <div class="container">
      <p class="section-label" style="text-align:center;">With Every Battery System</p>
      <h2 style="text-align:center; margin-bottom: 2.5rem;">Our Guarantees</h2>

      <div class="guarantees-grid">
        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">80%+</span>
            <span class="guarantee-tile__label">Grid<br />independence</span>
          </div>
        </div>

        <div class="guarantee-tile">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">24/7</span>
            <span class="guarantee-tile__label">Back-to-base<br />monitoring</span>
          </div>
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">10 year</span>
            <span class="guarantee-tile__label">Workmanship<br />warranty</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>

        <div class="guarantee-tile guarantee-tile--badged">
          <img src="/image/elements/residenteials_Section_Gaurantee_Tile.svg" alt="" class="guarantee-tile__bg" />
          <div class="guarantee-tile__content">
            <span class="guarantee-tile__value">10yr+</span>
            <span class="guarantee-tile__label">Battery<br />lifespan</span>
          </div>
          <img src="/image/icon/residenteials_Section_Gaurantee_Badge.svg" alt="" class="guarantee-tile__badge" />
        </div>
      </div>
    </div>
  </section>

  <style>
    .guarantees-section {
      position: relative;
      padding: 5rem 0 6rem;
      background: #f4f5f7;
      overflow: hidden;
    }

    .guarantees-section__slant {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 100%;
      background: #eceef1;
      clip-path: polygon(0 8%, 100% 0, 100% 92%, 0 100%);
      z-index: 0;
    }

    .guarantees-section__texture {
      position: absolute;
      bottom: -500px;
      left: -100px;
      width: 1000px;
      height: 1000px;
      background: url('/image/textures/WhatWeDo_Texture.svg') no-repeat center / contain;
      transform: rotate(30deg);
      z-index: 0;
      pointer-events: none;
      opacity: 1;
    }

    .guarantees-section .container {
      position: relative;
      z-index: 1;
    }

    .guarantees-grid {
      display: flex;
      justify-content: center;
      max-width: 900px;
      margin: 0 auto;
    }

    .guarantee-tile {
      position: relative;
      width: 220px;
      flex-shrink: 0;
      aspect-ratio: 528 / 521;
      margin-right: -20px;
    }

    .guarantee-tile:last-child {
      margin-right: 0;
    }

    .guarantee-tile__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.06));
    }

    .guarantee-tile__content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 1.5rem;
    }

    .guarantee-tile__value {
      display: block;
      font-size: 2.25rem;
      font-weight: 800;
      color: #0E2B47;
      line-height: 1.1;
      margin-bottom: 0.5rem;
    }

    .guarantee-tile__label {
      display: block;
      font-size: 0.95rem;
      font-weight: 500;
      color: #0E2B47;
      line-height: 1.4;
    }

    .guarantee-tile__badge {
      position: absolute;
      bottom: -30px;
      right: -30px;
      width: 72px;
      height: 72px;
      z-index: 2;
    }

    @media (max-width: 768px) {
      .guarantees-grid {
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      .guarantee-tile {
        width: calc(50% - 0.75rem);
        flex-shrink: 0;
        margin-right: 0;
      }

      .guarantee-tile__value {
        font-size: 1.75rem;
      }

      .guarantee-tile__label {
        font-size: 0.85rem;
      }

      .guarantee-tile__badge {
        width: 56px;
        height: 56px;
        bottom: -12px;
        right: -12px;
      }

      .guarantees-section__texture {
        width: 600px;
        height: 600px;
        bottom: -300px;
        left: -80px;
      }
    }
  </style>


  <!-- Gallery preview -->
  <section class="gallery-preview-section">
    <img src="/image/icon/Brand_wave_dots_BlueByGoogleMaps.svg" alt="" class="gallery-decoration" aria-hidden="true" />
    <div class="container">
      <div class="gallery-preview-grid">
        <div class="gallery-preview-item">
          <img src="/image/photos_clients/12_v1.webp" alt="Norlane battery and solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">12.33kW + Battery</span>
            <span class="gallery-preview-name">Norlane</span>
          </div>
        </div>
        <div class="gallery-preview-item">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_7.webp" alt="Ocean Grove battery and solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">13.2kW + Battery</span>
            <span class="gallery-preview-name">Ocean Grove</span>
          </div>
        </div>
        <div class="gallery-preview-item gallery-preview-wide">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_9.webp" alt="Leopold battery and solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">6.6kW + 10kWh</span>
            <span class="gallery-preview-name">Leopold</span>
          </div>
        </div>
        <div class="gallery-preview-item gallery-preview-wide">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_17_TopCut_.webp" alt="Torquay battery and solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">15.5kW + 15kWh</span>
            <span class="gallery-preview-name">Torquay</span>
          </div>
        </div>
        <div class="gallery-preview-item">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_15_TopCut_.webp" alt="Belmont battery and solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">9.9kW + Battery</span>
            <span class="gallery-preview-name">Belmont</span>
          </div>
        </div>
        <div class="gallery-preview-item">
          <img src="/image/photos_clients/16_v1.webp" alt="Inverleigh battery and solar installation" loading="lazy" />
          <div class="gallery-preview-overlay">
            <span class="gallery-preview-kw">8.5kW + 10kWh</span>
            <span class="gallery-preview-name">Inverleigh</span>
          </div>
        </div>
      </div>
      <div class="gallery-preview-cta">
        <a href="/examples/residential">View Full Gallery</a>
      </div>
    </div>
  </section>

  <style>
    .gallery-preview-section {
      padding: 4rem 0;
      background: #fff;
      position: relative;
      overflow: hidden;
    }

    .gallery-decoration {
      position: absolute;
      right: -10%;
      top: 50%;
      transform: translateY(-50%) rotate(100deg);
      opacity: 0.4;
      pointer-events: none;
      height: 100%;
      width: auto;
    }

    .gallery-preview-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto;
      gap: 0.6rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .gallery-preview-item {
      position: relative;
      border-radius: 0.6rem;
      overflow: hidden;
    }

    .gallery-preview-item:nth-child(1) { grid-column: 1; grid-row: 1; }
    .gallery-preview-item:nth-child(2) { grid-column: 2; grid-row: 1; }
    .gallery-preview-item:nth-child(3) { grid-column: 3 / 5; grid-row: 1; }
    .gallery-preview-item:nth-child(4) { grid-column: 1 / 3; grid-row: 2; }
    .gallery-preview-item:nth-child(5) { grid-column: 3; grid-row: 2; }
    .gallery-preview-item:nth-child(6) { grid-column: 4; grid-row: 2; }

    .gallery-preview-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      aspect-ratio: 1 / 1;
    }

    .gallery-preview-wide img {
      aspect-ratio: auto;
      height: 100%;
    }

    .gallery-preview-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 50%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0.75rem;
    }

    .gallery-preview-kw {
      display: inline-block;
      width: fit-content;
      font-size: 0.6rem;
      font-weight: 700;
      color: #fff;
      background: rgba(0,0,0,0.45);
      backdrop-filter: blur(6px);
      padding: 0.1rem 0.4rem;
      border-radius: 3px;
      margin-bottom: 0.2rem;
    }

    .gallery-preview-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #fff;
      text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    }

    .gallery-preview-cta {
      text-align: center;
      margin-top: 1.5rem;
    }

    .gallery-preview-cta a {
      color: #2061B7;
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
    }

    .gallery-preview-cta a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .gallery-preview-grid {
        grid-template-columns: 1fr 1fr;
      }

