---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import ProcessTimeline from '../../../components/sections/ProcessTimeline.astro';
import StatBar from '../../../components/sections/StatBar.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import IconFeatureGrid from '../../../components/sections/IconFeatureGrid.astro';
---

<BaseLayout
  title="Residential Solar Panels Geelong & Torquay | Installation | EES"
  description="Expert residential solar panel installation in Geelong, Torquay and the Surf Coast. CEC accredited, designed for your home, backed by a 10-year workmanship warranty."
>
  <section class="page-header">
    <div class="container">
      <h1>Residential Solar Systems</h1>
      <p>Solar panel installation designed around your home and energy profile.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_14_TopCut_.webp" alt="EES residential solar installation on a home in Geelong" bg="white">
    <p class="section-label">Our Approach</p>
    <h2>Solar Designed for Your Home</h2>
    <p>
      Every home is different — roof orientation, shading, energy usage, and future plans all affect what solar system will perform best. We design each system around your specific property, not a generic template.
    </p>
    <p>
      Our process starts with a detailed assessment of your roof, energy bills, and goals. From there, we design a system that maximises self-consumption and delivers the best return on your investment.
    </p>
  </SplitFeature>

  <IconFeatureGrid
    label="What We Install"
    heading="Quality Components, Long-Term Reliability"
    bg="light"
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="12" y1="3" x2="12" y2="21"/></svg>',
        title: 'Tier 1 Solar Panels',
        description: 'Independently tested and rated for Australian conditions with 25-year warranties.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
        title: 'Quality Inverters',
        description: 'The component that converts DC power from your panels to AC power for your home.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>',
        title: 'Optimised Design',
        description: 'Panel placement and string configuration designed for your specific roof.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg>',
        title: 'Full Monitoring',
        description: 'See your generation and consumption in real time from your phone.'
      },
    ]}
  />

  <!-- Solar System Size Selector -->
  <section class="solar-tiers-section">
    <div class="container">
      <div class="spec-cards-header">
        <p class="section-label">System Sizes</p>
        <h2>The Right Size for Your Home</h2>
      </div>

      <div class="tier-comparison-table">
        <table>
          <thead>
            <!-- Card row -->
            <tr class="tier-card-row">
              <th></th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>6.6 kW</h3>
                <p class="tier-desc">Suits smaller households with moderate energy use. A cost-effective entry point with strong returns.</p>
                <span class="tier-badge">Best for: 1–2 person households</span>
              </th>
              <th class="tier-card-cell tier-card-cell--popular">
                <div class="tier-card-top-bar"></div>
                <div class="tier-popular-tag">Most Common</div>
                <h3>10 kW</h3>
                <p class="tier-desc">The most common size for a family home. Maximises the federal STC rebate and covers most daytime usage.</p>
                <span class="tier-badge">Best for: Family homes</span>
              </th>
              <th class="tier-card-cell">
                <div class="tier-card-top-bar"></div>
                <h3>13–15 kW</h3>
                <p class="tier-desc">For larger homes, homes with pools, or households planning to add a battery, heat pump, or EV charger.</p>
                <span class="tier-badge">Best for: Large homes & future-proofing</span>
              </th>
            </tr>
            <!-- Column label row -->
            <tr class="tier-label-row">
              <th>Feature</th>
              <th>6.6 kW</th>
              <th>10 kW</th>
              <th>13–15 kW</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Number of Panels</td>
              <td>15–18 panels</td>
              <td>22–26 panels</td>
              <td>28–38 panels</td>
            </tr>
            <tr>
              <td>Daily Generation</td>
              <td>~24–28 kWh/day</td>
              <td>~38–42 kWh/day</td>
              <td>~50–62 kWh/day</td>
            </tr>
            <tr>
              <td>Roof Space Needed</td>
              <td>~28–35 m²</td>
              <td>~40–52 m²</td>
              <td>~52–72 m²</td>
            </tr>
            <tr>
              <td>Typical Bill Reduction</td>
              <td>70–85%</td>
              <td>80–90%</td>
              <td>85–95%+</td>
            </tr>
            <tr>
              <td>Inverter</td>
              <td>Single-phase 5 kW</td>
              <td>Single/three-phase 5–10 kW</td>
              <td>Three-phase 10–15 kW</td>
            </tr>
            <tr>
              <td>STC Rebate</td>
              <td>~$2,800–$3,200</td>
              <td>~$3,800–$4,400</td>
              <td>~$5,000–$6,200</td>
            </tr>
            <tr>
              <td>Battery Ready</td>
              <td>Yes — can add later</td>
              <td>Yes — ideal pairing</td>
              <td>Yes — recommended</td>
            </tr>
            <tr>
              <td>Payback Period</td>
              <td>3–5 years</td>
              <td>3–4 years</td>
              <td>3–5 years</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="tier-detail-cta">
        <a href="/services/consultation" class="btn btn-primary">Get Your Free Quote</a>
      </div>
    </div>
  </section>

  <style>
    .solar-tiers-section {
      padding: 4rem 0;
      background: #f8f9fa;
    }

    .spec-cards-header {
      max-width: 1000px;
      margin: 0 auto 2rem;
      /* Offset to center over the 3 data columns, not the feature label column */
      padding-left: 22%;
      text-align: center;
    }

    /* Comparison table */
    .tier-comparison-table {
      max-width: 1000px;
      margin: 0 auto;
      background: transparent;
      overflow: visible;
    }

    .tier-comparison-table table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
    }

    /* Card header row */
    .tier-card-row th {
      vertical-align: top;
      padding: 0;
      border-bottom: none;
      background: #f8f9fa;
    }

    .tier-card-row th:first-child {
      background: #f8f9fa;
    }

    .tier-card-cell {
      text-align: left;
      font-weight: normal;
      position: relative;
      background: #fff;
      border: 2px solid #e5e7eb;
      border-bottom: none;
      border-radius: 0.75rem 0.75rem 0 0;
      overflow: hidden;
    }

    .tier-card-cell h3 {
      font-size: 1.5rem;
      font-weight: 800;
      color: #0E2B47;
      margin: 0 0 0.5rem;
      padding: 0 1.25rem;
    }

    .tier-card-cell .tier-desc {
      font-size: 0.88rem;
      color: #555;
      line-height: 1.55;
      margin: 0 0 0.75rem;
      padding: 0 1.25rem;
    }

    .tier-card-cell .tier-badge {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 600;
      color: #2061B7;
      background: rgba(32, 97, 183, 0.08);
      padding: 0.25rem 0.65rem;
      border-radius: 2rem;
      margin: 0 0 1.25rem 1.25rem;
    }

    .tier-card-top-bar {
      height: 4px;
      background: #2061B7;
      margin-bottom: 1.25rem;
    }

    .tier-popular-tag {
      background: #2061B7;
      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-align: center;
      padding: 0.3rem 0;
      margin-top: -1.25rem;
      margin-bottom: 1rem;
    }

    .tier-card-cell--popular {
      background: rgba(32, 97, 183, 0.03);
      border-color: #2061B7;
    }

    /* Column label row */
    .tier-label-row th {
      text-align: left;
      padding: 0.7rem 1.25rem;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #888;
      border-bottom: 2px solid #e5e7eb;
      border-top: 1px solid #e5e7eb;
      background: #fff;
    }

    .tier-label-row th:first-child {
      border-left: 1px solid #e5e7eb;
      border-top-left-radius: 0.75rem;
    }

    .tier-label-row th:last-child {
      border-right: 1px solid #e5e7eb;
    }

    .tier-label-row th:nth-child(3) {
      background: rgba(32, 97, 183, 0.06);
      border-left: 2px solid #2061B7;
      border-right: 2px solid #2061B7;
    }

    /* Body rows */
    .tier-comparison-table tbody td {
      padding: 0.65rem 1.25rem;
      font-size: 0.88rem;
      color: #444;
      border-bottom: 1px solid #f0f0f0;
      vertical-align: top;
      background: #fff;
    }

    .tier-comparison-table tbody td:first-child {
      font-weight: 600;
      color: #0E2B47;
      border-left: 1px solid #e5e7eb;
    }

    .tier-comparison-table tbody td:last-child {
      border-right: 1px solid #e5e7eb;
    }

    .tier-comparison-table tbody td:nth-child(3) {
      background: rgba(32, 97, 183, 0.03);
      border-left: 2px solid #2061B7;
      border-right: 2px solid #2061B7;
    }

    .tier-comparison-table tbody tr:nth-child(even) td {
      background: #fafbfc;
    }

    .tier-comparison-table tbody tr:nth-child(even) td:nth-child(3) {
      background: rgba(32, 97, 183, 0.05);
    }

    .tier-comparison-table tbody tr:last-child td {
      border-bottom: 1px solid #e5e7eb;
    }

    .tier-comparison-table tbody tr:last-child td:nth-child(3) {
      border-bottom: 2px solid #2061B7;
    }

    .tier-comparison-table tbody tr:last-child td:first-child {
      border-bottom-left-radius: 0.75rem;
    }

    .tier-comparison-table tbody tr:last-child td:last-child {
      border-bottom-right-radius: 0.75rem;
    }

    .tier-detail-cta {
      text-align: center;
      max-width: 1000px;
      margin: 2rem auto 0;
    }

    @media (max-width: 800px) {
      .tier-comparison-table {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      .tier-comparison-table table {
        min-width: 650px;
      }
    }
  </style>


  <StatBar
    stats={[
      { value: '70-90%', label: 'Average bill reduction' },
      { value: '10yr', label: 'Workmanship warranty' },
      { value: '25yr', label: 'Panel warranty' },
      { value: '1 day', label: 'Typical install time' },
    ]}
  />

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_21_TopCut_.webp" alt="EES solar panels installed on residential roof" reverse bg="white">
    <p class="section-label">Rebates & Incentives</p>
    <h2>Government Support to Lower Your Costs</h2>
    <p>
      The federal government provides an upfront discount on solar installations through Small-scale Technology Certificates (STCs). This is applied as a point-of-sale discount — you don't need to claim it separately.
    </p>
    <p>
      Additional Victorian Government rebates may be available depending on your property and household income. As a Solar Victoria approved retailer, we confirm your eligibility and handle the application process.
    </p>
  </SplitFeature>

  <ProcessTimeline
    label="How It Works"
    heading="From Enquiry to Savings"
    steps={[
      { title: 'Consultation', description: 'We assess your property, review your bills, and discuss your goals.' },
      { title: 'Design', description: 'We design a system tailored to your roof and energy profile.' },
      { title: 'Paperwork', description: 'We handle the rebate application, grid connection approval, and permits.' },
      { title: 'Installation', description: 'Our CEC-accredited electricians install the system, typically in one day.' },
      { title: 'Commissioning', description: 'We test everything, connect monitoring, and walk you through the system.' },
    ]}
  />

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_19_TopCut_.webp" alt="EES headquarters in Moolap, Geelong" bg="light">
    <p class="section-label">Warranty & Support</p>
    <h2>We Stand Behind Every Install</h2>
    <p>
      Every installation comes with our <strong>10-year workmanship warranty</strong>, covering the installation itself — not just the products. If something goes wrong with how the system was installed, we fix it.
    </p>
    <p>
      Panel and inverter manufacturer warranties apply on top of this, typically 25 years for panels and 10-15 years for inverters. We're a local team based in Moolap — here for the long term, not a fly-in-fly-out installer.
    </p>
  </SplitFeature>

  <RelatedNav
    links={[
      { href: '/services/residential/battery-systems', title: 'Battery Storage', description: 'Store solar energy for use after dark' },
      { href: '/services/residential/heat-pump-systems', title: 'Heat Pump Systems', description: 'Efficient hot water and climate control' },
      { href: '/services/financing', title: 'Financing & Rebates', description: 'Payment plans and government incentives' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to get a solar system designed for your home?</p>
      <a href="/services/consultation" class="btn btn-primary">Book a Free Consultation</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>
