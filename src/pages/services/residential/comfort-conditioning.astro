---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../../components/ScrollIndicator.astro';
import SplitFeature from '../../../components/sections/SplitFeature.astro';
import StatBar from '../../../components/sections/StatBar.astro';
import RelatedNav from '../../../components/sections/RelatedNav.astro';
import IconFeatureGrid from '../../../components/sections/IconFeatureGrid.astro';
---

<BaseLayout
  title="Comfort Conditioning | EES"
  description="Hydronic radiant ceiling panels for healthier, more efficient heating and cooling in your home — operating at a fraction of the cost of conventional systems."
>
  <section class="page-header">
    <div class="container">
      <h1>Comfort Conditioning</h1>
      <p>Healthier, more efficient heating and cooling for your home.</p>
    </div>
  </section>

  <SplitFeature image="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-installed-ceiling-residential.webp" alt="Hydronic radiant ceiling panel installed in a residential home" bg="white">
    <p class="section-label">Our Approach</p>
    <h2>How We Condition Your Home</h2>
    <p>
      We use hydronic radiant ceiling panels — a fundamentally different approach to heating and cooling compared to conventional ducted systems or split units.
    </p>
    <p>
      Rather than blowing hot or cold air around the room, our system radiates energy directly from the ceiling. This is how the sun warms the earth, and it's how the human body naturally exchanges heat with its surroundings.
    </p>
    <p>
      Your body exchanges energy through three mechanisms: radiation, convection, and breathing. Of these, <strong>radiant transfer has the greatest impact on comfort</strong>. Radiant systems deliver both radiant and convective conditioning simultaneously, making them the most effective form of environmental conditioning available.
    </p>
  </SplitFeature>

  <StatBar
    stats={[
      { value: '1/3', label: 'Running cost vs conventional' },
      { value: '600x1200mm', label: 'Standard panel size' },
      { value: '24V DC', label: 'Low voltage operation' },
      { value: '0 dB', label: 'Silent operation' },
    ]}
  />

  <IconFeatureGrid
    label="The Difference"
    heading="Why Radiant Is Better"
    bg="light"
    features={[
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><circle cx="9" cy="9" r="1"/><circle cx="15" cy="9" r="1"/></svg>',
        title: 'Healthier',
        description: 'No dust circulation, no dry air, no noise. Radiant conditioning avoids the problems associated with forced-air systems.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
        title: 'More Hygienic',
        description: 'Ceiling-mounted panels don\'t collect or disturb floor dust. No filters to change, no ducts to clean.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
        title: 'More Efficient',
        description: 'Operating at roughly one-third the cost of conventional systems. Lower energy consumption means lower bills and lower emissions.'
      },
      {
        icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3-9 4 18 3-9h4"/></svg>',
        title: 'More Comfortable',
        description: 'Even temperature distribution without hot or cold spots. No draughts, no noise — just consistent, natural comfort.'
      },
    ]}
    columns={2}
  />

  <SplitFeature image="/image/WIP/Hydronic_Ceiling_Panels_StoryOff/panel-serpentine-tube-pattern.webp" alt="Hydronic ceiling panel showing serpentine tube pattern" reverse bg="white">
    <p class="section-label">The Panels</p>
    <h2>What We Install</h2>
    <p>
      Our suspended hydronic ceiling panels provide heating and cooling in a single system. Each panel is:
    </p>
    <ul>
      <li><strong>600 x 1200mm</strong> — fits standard Australian suspended ceiling grids</li>
      <li><strong>Modular</strong> — easy to install, modify, and maintain</li>
      <li>Available with <strong>multiple finishing surfaces</strong> to match your interior</li>
    </ul>
    <p>
      The system runs on low-voltage (24V DC) components including variable speed pumps, actuators, and mixing valves. It's quiet, safe, and simple.
    </p>
  </SplitFeature>

  <SplitFeature image="/image/WIP/environmental-service-pod/esp-hydronic-manifold-photo.webp" alt="Hydronic manifold connected to renewable energy system" bg="light">
    <p class="section-label">Renewable Integration</p>
    <h2>Paired With Renewable Energy</h2>
    <p>
      Our conditioning system is designed to work hand-in-hand with solar PV, battery storage, and our polyvalent heat pump. This means your heating and cooling can run primarily — or entirely — on renewable energy.
    </p>
  </SplitFeature>

  <RelatedNav
    links={[
      { href: '/services/residential/heat-pump-systems', title: 'Heat Pump Systems', description: 'The polyvalent heat pump that powers our conditioning system' },
      { href: '/services/residential/solar-systems', title: 'Solar Systems', description: 'Solar panel installation designed for your home' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to see how radiant conditioning can work in your home?</p>
      <a href="/contact" class="btn btn-primary">Request a Free Consultation</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>
