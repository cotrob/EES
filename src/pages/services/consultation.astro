---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import SplitFeature from '../../components/sections/SplitFeature.astro';
import ProcessTimeline from '../../components/sections/ProcessTimeline.astro';
import IconFeatureGrid from '../../components/sections/IconFeatureGrid.astro';
import RelatedNav from '../../components/sections/RelatedNav.astro';
import { hugeIconToSvg } from '../../lib/hugeicon-svg';
import Layout01Icon from '@hugeicons/core-free-icons/Layout01Icon';
import ChartBarIncreasingIcon from '@hugeicons/core-free-icons/ChartBarIncreasingIcon';
import Dollar01Icon from '@hugeicons/core-free-icons/Dollar01Icon';
import File01Icon from '@hugeicons/core-free-icons/File01Icon';
import CreditCardIcon from '@hugeicons/core-free-icons/CreditCardIcon';
import UserAdd01Icon from '@hugeicons/core-free-icons/UserAdd01Icon';
---

<BaseLayout
  title="Free Solar & Energy Consultation Geelong | Book Online | EES"
  description="Free no-obligation energy consultation in Geelong. We assess your property and recommend the best solar, battery or heat pump solution."
>
  <section class="page-header">
    <div class="container">
      <h1>Free Energy Consultation</h1>
      <p>No-obligation assessment of your property and energy needs.</p>
    </div>
  </section>

  <SplitFeature image="/image/photography/01_Hero_Images_OG/Frontage_18_TopCut_.webp" alt="EES team conducting a property energy assessment" bg="white">
    <p class="section-label">What to Expect</p>
    <h2>It Starts With a Quick Phone Call</h2>
    <p>
      When you enquire, we'll call you for a 5 to 10 minute discovery call. We want to understand what you've currently got, what phases your property is on, and whether you're planning to stay in the home for the next few years. If your electricity bill is around $100 or more a month, a system will usually make sense.
    </p>
    <p>
      If it looks like a good fit, we'll book a <strong>one-hour in-person consultation</strong> at your property. This isn't a sales pitch. It's a proper energy assessment conducted by Lincoln or a qualified member of our team, not a subcontractor or third-party agent.
    </p>
  </SplitFeature>

  <ProcessTimeline
    label="During Your Consultation"
    heading="What Happens When We Visit"
    steps={[
      { title: 'Understand Your Situation', description: 'We find out where your knowledge is and meet you there. Whether you\'re an electrical engineer or have no idea how solar works, we walk you through everything at your pace.' },
      { title: 'Analyse Your Energy Data', description: 'Using your NMI number and smart meter, we pull your interval metering data down to half-hour increments. We see exactly where your power goes, when you\'re using it, and how much you\'re sending back to the grid.' },
      { title: 'Assess Your Property', description: 'Roof orientation, pitch, shading, switchboard capacity, existing wiring, and what phase you\'re on. For architectural homes, we also look at how cabling and equipment can be installed without compromising the aesthetics.' },
      { title: 'Consider Your Future', description: 'Are you planning an electric vehicle, induction cooktop, or heat pump? Retiring soon and going to be home more? We size the system around where your consumption is heading, not just where it is today.' },
      { title: 'Design Your System', description: 'Based on your actual data and future plans, we recommend a system sized to cover your own usage first. We never oversize to sell you more panels, and we never design for winter production.' },
    ]}
  />

  <IconFeatureGrid
    label="Your Proposal"
    heading="What You'll Walk Away With"
    bg="light"
    columns={3}
    features={[
      {
        icon: hugeIconToSvg(Layout01Icon),
        title: 'System Design',
        description: 'Detailed design and component specifications tailored to your property, your usage patterns, and your future plans.'
      },
      {
        icon: hugeIconToSvg(ChartBarIncreasingIcon),
        title: 'Realistic Savings',
        description: 'Conservative savings projections based on your actual interval data, not generic estimates. We show you payback periods and return on investment.'
      },
      {
        icon: hugeIconToSvg(Dollar01Icon),
        title: 'Applicable Rebates',
        description: 'STC discount, Victorian Government rebates, and any other incentives you qualify for. We handle the paperwork.'
      },
      {
        icon: hugeIconToSvg(File01Icon),
        title: 'Itemised Pricing',
        description: 'Full cost breakdown with no hidden charges. Product information, warranties on panels, batteries, inverters, and our workmanship standards.'
      },
      {
        icon: hugeIconToSvg(CreditCardIcon),
        title: 'Financing Options',
        description: 'We work with Brighte, Parker Lane, and 28 Finance to find the best payment plan. Or we can help you use your own bank\'s green loan.'
      },
      {
        icon: hugeIconToSvg(UserAdd01Icon),
        title: 'VPP & Automation Strategy',
        description: 'How a virtual power plant can earn you money, and whether home automation could further optimise your system. We don\'t just install and walk away.'
      },
    ]}
  />

  <SplitFeature image="/image/icon/Crednetials_3.webp" alt="Geelong bollards icon - trusted local team" reverse bg="cream" flat>
    <p class="section-label">Service Area</p>
    <h2>Local Geelong Team</h2>
    <p>
      We service Greater Geelong, Torquay, the Surf Coast, Bellarine Peninsula, Golden Plains, and wider regional Victoria. Based in Moolap, we're a local team with local knowledge.
    </p>
    <p>
      EES is a CEC-accredited installer and Solar Victoria approved retailer. Every consultation is conducted by a qualified member of our team.
    </p>
    <p><strong>Phone:</strong> <a href="tel:0427664827">0427 664 827</a></p>
    <p><strong>Email:</strong> <a href="mailto:support@eeservices.io">support@eeservices.io</a></p>
  </SplitFeature>

  <RelatedNav
    links={[
      { href: '/services/residential', title: 'Residential Systems', description: 'Solar, battery, heat pump solutions' },
      { href: '/services/commercial', title: 'Commercial Systems', description: 'Solar and battery for business' },
      { href: '/services/financing', title: 'Financing & Rebates', description: 'Payment plans and government incentives' },
    ]}
  />

  <section class="cta-section">
    <div class="container">
      <p>Ready to find out what's possible for your property?</p>
      <a href="#solar-qualifier" class="btn btn-primary">Start Your Energy Assessment</a>
    </div>
  </section>

  <ScrollIndicator />
</BaseLayout>
