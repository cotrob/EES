            <div class="bento-content">
              <span class="bento-kw">508kWp</span>
              <span class="bento-name">Lyka Pet Foods<br/>Warehouse</span>
              <div class="bento-details">
                <ul>
                  <li>1,120 rooftop modules</li>
                  <li>Full warehouse roof coverage</li>
                  <li>Estimated 70% energy offset</li>
                </ul>
                <p>Large-scale commercial install for a national pet food distributor.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bento-item">
          <img src="/image/photography/01_Hero_Images_OG/Frontage_3.webp" alt="Cold Storage commercial solar installation" />
